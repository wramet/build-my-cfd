# 🔧 เครื่องมือขั้นสูงและการทำงานอัตโนมัติ

## ขั้นที่ 1: เครื่องมือประเมินคุณภาพ Mesh

### 1.1 Script การวิเคราะห์คุณภาพแบบครบวงจร

OpenFOAM มีเครื่องมือตรวจสอบคุณภาพ mesh หลายตัวในตัว แต่การสร้างเวิร์กโฟลว์การวิเคราะห์แบบครบวงจรต้องการการรวมกันของหลายเครื่องมือและสคริปต์ที่กำหนดเอง เครื่องมือวิเคราะห์คุณภาพ mesh แบบ Python ต่อไปนี้มีการประเมินอัตโนมัติของพารามิเตอร์ mesh ที่สำคัญ

```python
#!/usr/bin/env python3
"""
เครื่องมือวิเคราะห์คุณภาพ mesh แบบครบวงจรสำหรับ OpenFOAM meshes
"""

import numpy as np
import sys
import os
import subprocess
import matplotlib.pyplot as plt
from matplotlib.backends.backend_pdf import PdfPages

class MeshQualityAnalyzer:
    def __init__(self, case_dir):
        self.case_dir = case_dir
        self.mesh_data = {}
        self.load_mesh_data()
        
    def load_mesh_data(self):
        """โหลดข้อมูล mesh จากไดเรกทอรี case ของ OpenFOAM"""
        # รัน checkMesh และจับผลลัพธ์
        try:
            result = subprocess.run(
                ['checkMesh', '-case', self.case_dir, '-writeAllSurfaces', '-latestTime'],
                capture_output=True, text=True, check=True
            )
            self.checkmesh_output = result.stdout
        except subprocess.CalledProcessError as e:
            print(f"Error running checkMesh: {e}")
            self.checkmesh_output = ""
            
        # โหลดข้อมูล connectivity ของ mesh
        self.load_connectivity_data()
        
    def load_connectivity_data(self):
        """โหลดข้อมูล face และ cell connectivity"""
        # แยกวิเคราะห์ไฟล์ mesh
        mesh_dir = os.path.join(self.case_dir, "constant", "polyMesh")
        
        # โหลด points
        points_file = os.path.join(mesh_dir, "points")
        self.points = self.parse_openfoam_file(points_file)
        
        # โหลด faces
        faces_file = os.path.join(mesh_dir, "faces")
        self.faces = self.parse_openfoam_file(faces_file)
        
        # โหลดข้อมูล owner
        owner_file = os.path.join(mesh_dir, "owner")
        self.owner = self.parse_openfoam_file(owner_file)
        
        # โหลดข้อมูล neighbor
        neighbor_file = os.path.join(mesh_dir, "neighbour")
        self.neighbour = self.parse_openfoam_file(neighbor_file)
        
    def parse_openfoam_file(self, filepath):
        """แยกวิเคราะห์ไฟล์รูปแบบ OpenFOAM"""
        if not os.path.exists(filepath):
            return []
            
        data = []
        in_data_section = False
        
        with open(filepath, 'r') as f:
            for line in f:
                line = line.strip()
                
                # ข้ามความคิดเห็นและบรรทัดว่าง
                if line.startswith('//') or not line:
                    continue
                    
                # จุดเริ่มต้นของส่วนข้อมูล
                if '(' in line and not in_data_section:
                    in_data_section = True
                    continue
                    
                # จุดสิ้นสุดของส่วนข้อมูล
                if ')' in line and in_data_section:
                    in_data_section = False
                    break
                    
                # แยกวิเคราะห์จุดข้อมูล
                if in_data_section and line and not line.startswith('}'):
                    try:
                        # แยกวิเคราะห์รูปแบบเวกเตอร์: (x y z)
                        if line.startswith('(') and line.endswith(')'):
                            point_str = line[1:-1].strip()
                            point = [float(x) for x in point_str.split()]
                            data.append(point)
                        else:
                            # แยกวิเคราะห์ค่าสเกลาร์
                            data.append(int(line))
                    except ValueError:
                        continue
                        
        return data
        
    def calculate_cell_centers(self):
        """คำนวณศูนย์กลางของเซลล์จาก topology ของ mesh"""
        cell_centers = []
        
        # การประมาณแบบง่ายโดยใช้ face centers
        for cell_id in range(len(self.owner)):
            # หา faces ที่เป็นของเซลล์นี้
            cell_faces = [i for i, owner in enumerate(self.owner) if owner == cell_id]
            
            if cell_faces:
                # คำนวณค่าเฉลี่ย face center
                center = [0.0, 0.0, 0.0]
                for face_id in cell_faces:
                    if face_id < len(self.faces) and self.faces[face_id]:
                        face_vertices = [self.points[pid] for pid in self.faces[face_id] if pid < len(self.points)]
                        if face_vertices:
                            face_center = np.mean(face_vertices, axis=0)
                            center += face_center
                            
                center /= len(cell_faces)
                cell_centers.append(center.tolist())
                
        return cell_centers
        
    def calculate_quality_metrics(self):
        """คำนวณเมตริกคุณภาพ mesh แบบครบวงจร"""
        metrics = {}
        
        # แยกวิเคราะห์ผลลัพธ์ checkMesh สำหรับเมตริกคุณภาพ
        lines = self.checkmesh_output.split('\n')
        for line in lines:
            line = line.strip()
            
            # การวิเคราะห์ non-orthogonality
            if 'non-orthogonal' in line:
                if 'cells with non-orthogonality' in line:
                    metrics['non_orthogonal_cells'] = int(line.split()[0])
                if 'maximum non-orthogonality' in line:
                    metrics['max_non_orthogonality'] = float(line.split()[-1])
                    
            # การวิเคราะห์ skewness
            if 'skewness' in line:
                if 'skewness cells' in line:
                    metrics['skewness_cells'] = int(line.split()[0])
                if 'maximum skewness' in line:
                    metrics['max_skewness'] = float(line.split()[-1])
                    
            # การวิเคราะห์ aspect ratio
            if 'aspect ratio' in line:
                if 'maximum aspect ratio' in line:
                    metrics['max_aspect_ratio'] = float(line.split()[-1])
                    
            # นับเซลล์และสถิติ mesh
            if 'total cells' in line:
                metrics['total_cells'] = int(line.split()[0])
            if 'total faces' in line:
                metrics['total_faces'] = int(line.split()[0])
            if 'total points' in line:
                metrics['total_points'] = int(line.split()[0])
                
        # คำนวณเมตริกที่ได้จาก
        if hasattr(self, 'points') and self.points:
            # คำนวณปริมาตรเซลล์ (แบบย่อ)
            volumes = self.estimate_cell_volumes()
            metrics['cell_volumes'] = volumes
            
            # คำนวณอัตราส่วนคุณภาพ mesh
            if metrics.get('total_cells', 0) > 0:
                metrics['non_orthogonal_ratio'] = metrics.get('non_orthogonal_cells', 0) / metrics['total_cells']
                metrics['skewness_ratio'] = metrics.get('skewness_cells', 0) / metrics['total_cells']
                
        return metrics
        
    def estimate_cell_volumes(self):
        """ประมาณปริมาตรเซลล์โดยใช้แนวทางแบบย่อ"""
        volumes = []
        
        # ใช้การประมาณ bounding box สำหรับเซลล์
        if hasattr(self, 'points') and self.points:
            points_array = np.array(self.points)
            
            # การประมาณปริมาตรแบบง่ายๆ โดยยึดตามการกระจายของเซลล์
            if len(points_array) > 0:
                bounding_volume = np.prod(np.ptp(points_array, axis=0))
                n_cells = len(set(self.owner)) if self.owner else 1
                
                if n_cells > 0:
                    avg_volume = bounding_volume / n_cells
                    volumes = [avg_volume] * n_cells
                    
        return volumes
        
    def identify_problematic_cells(self, quality_metrics):
        """ระบุเซลล์ที่มีปัญหาคุณภาพ"""
        problematic_cells = []
        
        # กำหนดค่าเกณฑ์คุณภาพ
        thresholds = {
            'max_non_orthogonality': 70.0,  # องศา
            'max_skewness': 4.0,
            'max_aspect_ratio': 1000.0
        }
        
        # ตรวจสอบแต่ละเกณฑ์
        if quality_metrics.get('max_non_orthogonality', 0) > thresholds['max_non_orthogonality']:
            problematic_cells.append({
                'type': 'non_orthogonality',
                'value': quality_metrics['max_non_orthogonality'],
                'threshold': thresholds['max_non_orthogonality']
            })
            
        if quality_metrics.get('max_skewness', 0) > thresholds['max_skewness']:
            problematic_cells.append({
                'type': 'skewness', 
                'value': quality_metrics['max_skewness'],
                'threshold': thresholds['max_skewness']
            })
            
        if quality_metrics.get('max_aspect_ratio', 0) > thresholds['max_aspect_ratio']:
            problematic_cells.append({
                'type': 'aspect_ratio',
                'value': quality_metrics['max_aspect_ratio'], 
                'threshold': thresholds['max_aspect_ratio']
            })
            
        return problematic_cells
        
    def create_summary_page(self, pdf):
        """สร้างหน้าสรุปเมตริกคุณภาพ"""
        fig, ax = plt.subplots(figsize=(8, 10))
        ax.axis('off')
        
        # รับเมตริกคุณภาพ
        metrics = self.calculate_quality_metrics()
        
        # สร้างข้อความสรุป
        summary_text = f"""
        สรุปคุณภาพ Mesh
        ===================
        
        สถิติพื้นฐาน:
        - เซลล์ทั้งหมด: {metrics.get('total_cells', 'N/A')}
        - Faces ทั้งหมด: {metrics.get('total_faces', 'N/A')}
        - Points ทั้งหมด: {metrics.get('total_points', 'N/A')}
        
        เมตริกคุณภาพ:
        - เซลล์ที่ไม่ตั้งฉาก: {metrics.get('non_orthogonal_cells', 'N/A')}
        - ค่าไม่ตั้งฉากสูงสุด: {metrics.get('max_non_orthogonality', 'N/A')}°
        - อัตราส่วนไม่ตั้งฉาก: {metrics.get('non_orthogonal_ratio', 'N/A'):.3f}
        
        - เซลล์ที่เบี้ยว: {metrics.get('skewness_cells', 'N/A')}
        - ค่าเบี้ยวสูงสุด: {metrics.get('max_skewness', 'N/A')}
        - อัตราส่วนเบี้ยว: {metrics.get('skewness_ratio', 'N/A'):.3f}
        
        - อัตราส่วนด้านสูงสุด: {metrics.get('max_aspect_ratio', 'N/A')}
        
        พื้นที่ที่มีปัญหา: {len(self.identify_problematic_cells(metrics))}
        """
        
        ax.text(0.05, 0.95, summary_text, transform=ax.transAxes, 
                fontsize=10, verticalalignment='top', family='monospace')
                
        pdf.savefig()
        plt.close()
        
    def create_histograms_page(self, pdf):
        """สร้างฮิสโตแกรมของเมตริกคุณภาพ"""
        fig, axes = plt.subplots(2, 2, figsize=(12, 10))
        fig.suptitle('การกระจายของคุณภาพ Mesh', fontsize=14)
        
        # รับเมตริกคุณภาพ
        metrics = self.calculate_quality_metrics()
        
        # ฮิสโตแกรมปริมาตรเซลล์
        if 'cell_volumes' in metrics and metrics['cell_volumes']:
            axes[0, 0].hist(metrics['cell_volumes'], bins=20, alpha=0.7)
            axes[0, 0].set_title('การกระจายปริมาตรเซลล์')
            axes[0, 0].set_xlabel('ปริมาตร')
            axes[0, 0].set_ylabel('ความถี่')
        else:
            axes[0, 0].text(0.5, 0.5, 'ข้อมูลปริมาตรไม่พร้อมใช้งาน', 
                           ha='center', va='center', transform=axes[0, 0].transAxes)
            axes[0, 0].set_title('การกระจายปริมาตรเซลล์')
            
        # แผนภูมิแท่งอัตราส่วนคุณภาพ
        quality_ratios = [
            ('ไม่ตั้งฉาก', metrics.get('non_orthogonal_ratio', 0)),
            ('เบี้ยว', metrics.get('skewness_ratio', 0))
        ]
        
        if quality_ratios:
            ratios, values = zip(*quality_ratios)
            axes[0, 1].bar(ratios, values, alpha=0.7)
            axes[0, 1].set_title('อัตราส่วนเซลล์ที่มีปัญหา')
            axes[0, 1].set_ylabel('อัตราส่วน')
            axes[0, 1].tick_params(axis='x', rotation=45)
            
        # การประเมินคุณภาพโดยรวม
        axes[1, 0].axis('off')
        
        problematic_cells = self.identify_problematic_cells(metrics)
        assessment_text = "การประเมินคุณภาพโดยรวม:\n\n"
        
        if not problematic_cells:
            assessment_text += "✅ คุณภาพ mesh ดี\n"
            assessment_text += "ไม่พบปัญหาร้ายแรง"
        else:
            assessment_text += "⚠️  คุณภาพ mesh ต้องการความสนใจ\n\n"
            assessment_text += "ปัญหาที่พบ:\n"
            for issue in problematic_cells:
                assessment_text += f"- {issue['type'].replace('_', ' ').title()}: "
                assessment_text += f"{issue['value']:.2f} (ขีดจำกัด: {issue['threshold']})\n"
                
        axes[1, 0].text(0.05, 0.95, assessment_text, transform=axes[1, 0].transAxes,
                       fontsize=10, verticalalignment='top')
        axes[1, 0].set_title('การประเมินคุณภาพ')
        
        # คำแนะนำ
        axes[1, 1].axis('off')
        recommendations = self.generate_recommendations(problematic_cells)
        axes[1, 1].text(0.05, 0.95, recommendations, transform=axes[1, 1].transAxes,
                       fontsize=10, verticalalignment='top')
        axes[1, 1].set_title('คำแนะนำ')
        
        plt.tight_layout()
        pdf.savefig()
        plt.close()
        
    def generate_recommendations(self, problematic_cells):
        """สร้างคำแนะนำโดยยึดตามปัญหาคุณภาพ"""
        recommendations = "คำแนะนำ:\n\n"
        
        if not problematic_cells:
            recommendations += "✓ คุณภาพ mesh เป็นที่ยอมรับได้\n"
            recommendations += "✓ ไม่จำเป็นต้องดำเนินการทันที"
        else:
            for issue in problematic_cells:
                if issue['type'] == 'non_orthogonality':
                    recommendations += "ความไม่ตั้งฉาก:\n"
                    recommendations += "- พิจารณาการแบ่งย่อย mesh\n" 
                    recommendations += "- ตรวจสอบความละเอียดของ boundary layer\n"
                    recommendations += "- ใช้ orthogonal mesher หากเป็นไปได้\n\n"
                    
                elif issue['type'] == 'skewness':
                    recommendations += "ความเบี้ยว:\n"
                    recommendations += "- แบ่งย่อยเซลล์ที่เบี้ยว\n"
                    recommendations += "- ตรวจสอบการกระจายของเซลล์\n"
                    recommendations += "- พิจารณาการสร้าง mesh ใหม่ในพื้นที่\n\n"
                    
                elif issue['type'] == 'aspect_ratio':
                    recommendations += "อัตราส่วนด้าน:\n"
                    recommendations += "- แบ่งย่อยเซลล์ที่ยืดออก\n"
                    recommendations += "- ปรับ mesh grading\n"
                    recommendations += "- ใช้ inflation layers\n\n"
                    
        return recommendations
        
    def create_visualization_page(self, pdf):
        """สร้างสรุปการสร้างภาพ mesh"""
        fig, axes = plt.subplots(2, 2, figsize=(12, 10))
        fig.suptitle('สรุปการสร้างภาพ Mesh', fontsize=14)
        
        # รับเมตริก
        metrics = self.calculate_quality_metrics()
        
        # แผนภูมิวงกลมสถิติ mesh โดยรวม
        total_cells = metrics.get('total_cells', 1)
        problematic_count = metrics.get('non_orthogonal_cells', 0) + metrics.get('skewness_cells', 0)
        good_cells = max(0, total_cells - problematic_count)
        
        if total_cells > 0:
            sizes = [good_cells, problematic_count]
            labels = ['เซลล์ที่ดี', 'เซลล์ที่มีปัญหา']
            colors = ['lightgreen', 'salmon']
            
            axes[0, 0].pie(sizes, labels=labels, colors=colors, autopct='%1.1f%%')
            axes[0, 0].set_title('การกระจายคุณภาพเซลล์')
            
        # เครื่องวัดคุณภาพ mesh (แบบย่อ)
        axes[0, 1].axis('off')
        
        # คำนวณคะแนนคุณภาพโดยรวม
        non_ortho_score = max(0, 100 - metrics.get('max_non_orthogonality', 100))
        skewness_score = max(0, 100 - metrics.get('max_skewness', 100) * 25)
        
        overall_score = (non_ortho_score + skewness_score) / 2
        
        # สร้างภาพเครื่องวัดแบบง่าย
        theta = np.linspace(0, np.pi, 100)
        r = 0.3
        
        # ส่วนโค้งเครื่องวัด
        arc_theta = np.linspace(0, (overall_score/100) * np.pi, 50)
        axes[0, 1].plot(r * np.cos(theta), r * np.sin(theta), 'k-', linewidth=2)
        axes[0, 1].plot(r * np.cos(arc_theta), r * np.sin(arc_theta), 'g-', linewidth=4)
        
        axes[0, 1].set_xlim(-0.4, 0.4)
        axes[0, 1].set_ylim(-0.1, 0.4)
        axes[0, 1].axis('equal')
        axes[0, 1].set_title(f'คะแนนคุณภาพโดยรวม: {overall_score:.1f}%')
        
        # แผนภูมิเรดาร์เมตริกคุณภาพ
        axes[1, 0].axis('off')
        
        # ข้อมูลจำนวนเซลล์
        axes[1, 1].axis('off')
        cell_info = f"""
        สถิติ Mesh:
        ================
        
        เซลล์ทั้งหมด: {metrics.get('total_cells', 'N/A'):,}
        Faces ทั้งหมด: {metrics.get('total_faces', 'N/A'):,}
        Points ทั้งหมด: {metrics.get('total_points', 'N/A'):,}
        
        เมตริกคุณภาพ:
        ================
        
        ความไม่ตั้งฉาก:
        - เซลล์ที่มีปัญหา: {metrics.get('non_orthogonal_cells', 'N/A'):,}
        - สูงสุด: {metrics.get('max_non_orthogonality', 'N/A'):.1f}°
        
        ความเบี้ยว:
        - เซลล์ที่มีปัญหา: {metrics.get('skewness_cells', 'N/A'):,}
        - สูงสุด: {metrics.get('max_skewness', 'N/A'):.2f}
        
        อัตราส่วนด้าน: {metrics.get('max_aspect_ratio', 'N/A'):.1f}
        """
        
        axes[1, 1].text(0.05, 0.95, cell_info, transform=axes[1, 1].transAxes,
                       fontsize=9, verticalalignment='top', family='monospace')
        axes[1, 1].set_title('สถิติโดยละเอียด')
        
        plt.tight_layout()
        pdf.savefig()
        plt.close()
        
    def generate_quality_report(self, filename="mesh_quality_report.pdf"):
        """สร้างรายงาน PDF แบบครบวงจร"""
        try:
            with PdfPages(filename) as pdf:
                # สร้างหน้าสรุป
                self.create_summary_page(pdf)
                
                # สร้างฮิสโตแกรมและการกระจาย
                self.create_histograms_page(pdf)
                
                # สร้างหน้าการสร้างภาพ
                self.create_visualization_page(pdf)
                
            print(f"✅ สร้างรายงานคุณภาพแล้ว: {filename}")
            return True
            
        except Exception as e:
            print(f"❌ ข้อผิดพลาดในการสร้างรายงาน: {e}")
            return False
            

def main():
    """ฟังก์ชันหลักสำหรับการใช้งาน command-line"""
    import argparse
    
    parser = argparse.ArgumentParser(description='เครื่องมือวิเคราะห์คุณภาพ Mesh OpenFOAM')
    parser.add_argument('case_dir', help='ไดเรกทอรี case ของ OpenFOAM')
    parser.add_argument('-o', '--output', default='mesh_quality_report.pdf',
                       help='ชื่อไฟล์รายงานผลลัพธ์')
    
    args = parser.parse_args()
    
    if not os.path.exists(args.case_dir):
        print(f"❌ ไม่พบไดเรกทอรี case: {args.case_dir}")
        return 1
        
    # สร้าง analyzer และสร้างรายงาน
    analyzer = MeshQualityAnalyzer(args.case_dir)
    
    print(f"กำลังวิเคราะห์คุณภาพ mesh สำหรับ: {args.case_dir}")
    quality_metrics = analyzer.calculate_quality_metrics()
    problematic_cells = analyzer.identify_problematic_cells(quality_metrics)
    
    # พิมพ์สรุปไปที่ console
    print(f"\n📊 สรุปคุณภาพ Mesh:")
    print(f"   เซลล์ทั้งหมด: {quality_metrics.get('total_cells', 'N/A')}")
    print(f"   เซลล์ที่ไม่ตั้งฉาก: {quality_metrics.get('non_orthogonal_cells', 'N/A')}")
    print(f"   เซลล์ที่เบี้ยว: {quality_metrics.get('skewness_cells', 'N/A')}")
    print(f"   พบปัญหา: {len(problematic_cells)} แห่ง")
    
    # สร้างรายงานโดยละเอียด
    success = analyzer.generate_quality_report(args.output)
    
    return 0 if success else 1


if __name__ == "__main__":
    sys.exit(main())
```

### 1.2 เครื่องมือปรับปรุง Mesh

สำหรับการปรับปรุงคุณภาพ mesh เราต้องการแนวทางเชิงระบบที่ระบุพื้นที่ที่มีปัญหาและใช้การแบ่งย่อยแบบเจาะจง สคริปต์ bash ต่อไปนี้มีเวิร์กโฟลว์การปรับปรุง mesh แบบครบวงจร:

```bash
#!/bin/bash
# เครื่องมือปรับปรุง mesh สำหรับ OpenFOAM
# การใช้งาน: ./optimize_mesh.sh <case_directory>

set -e  # ออกเมื่อมีข้อผิดพลาดใดๆ

# การกำหนดค่า
CASE_DIR="${1:-.}"
QUALITY_THRESHOLD_NONORTHO=70
QUALITY_THRESHOLD_SKEWNESS=4
QUALITY_THRESHOLD_ASPECT=1000
MAX_ITERATIONS=3

# สีสำหรับ output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# ฟังก์ชันการบันทึก
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# ตรวจสอบว่ามีการ source สภาพแวดล้อม OpenFOAM แล้ว
check_openfoam_env() {
    if ! command -v checkMesh &> /dev/null; then
        log_error "ยังไม่ได้ source สภาพแวดล้อม OpenFOAM กรุณา source etc/bashrc ก่อน"
        exit 1
    fi
}

# การประเมินคุณภาพ mesh เบื้องต้น
assess_initial_quality() {
    log_info "กำลังประเมินคุณภาพ mesh เบื้องต้น..."
    
    local output_file="${CASE_DIR}/quality_initial.log"
    
    checkMesh -case "$CASE_DIR" -meshQuality > "$output_file" 2>&1 || true
    
    # ดึงเมตริกหลัก
    local total_cells=$(grep -o "total cells.*[0-9]\+" "$output_file" | grep -o "[0-9]\+" || echo "0")
    local non_ortho_cells=$(grep -o "non-orthogonal.*cells.*[0-9]\+" "$output_file" | grep -o "[0-9]\+" || echo "0")
    local skewness_cells=$(grep -o "skewness.*cells.*[0-9]\+" "$output_file" | grep -o "[0-9]\+" || echo "0")
    local max_non_ortho=$(grep -o "maximum non-orthogonality.*[0-9.]\+" "$output_file" | grep -o "[0-9.]\+" || echo "0")
    local max_skewness=$(grep -o "maximum skewness.*[0-9.]\+" "$output_file" | grep -o "[0-9.]\+" || echo "0")
    
    echo "TOTAL_CELLS=$total_cells" > "${CASE_DIR}/quality_metrics.txt"
    echo "NON_ORTHO_CELLS=$non_ortho_cells" >> "${CASE_DIR}/quality_metrics.txt"
    echo "SKEWNESS_CELLS=$skewness_cells" >> "${CASE_DIR}/quality_metrics.txt"
    echo "MAX_NON_ORTHO=$max_non_ortho" >> "${CASE_DIR}/quality_metrics.txt"
    echo "MAX_SKEWNESS=$max_skewness" >> "${CASE_DIR}/quality_metrics.txt"
    
    log_info "การประเมินเบื้องต้นเสร็จสิ้น"
    log_info "   เซลล์ทั้งหมด: $total_cells"
    log_info "   เซลล์ที่ไม่ตั้งฉาก: $non_ortho_cells"
    log_info "   เซลล์ที่เบี้ยว: $skewness_cells"
    log_info "   ค่าไม่ตั้งฉากสูงสุด: $max_non_ortho°"
    log_info "   ค่าเบี้ยวสูงสุด: $max_skewness"
}

# ระบุพื้นที่ที่มีปัญหา
identify_problem_regions() {
    log_info "กำลังระบุพื้นที่ที่มีปัญหา..."
    
    # สร้าง refinement dictionary หากไม่มี
    mkdir -p "${CASE_DIR}/system"
    
    cat > "${CASE_DIR}/system/refinementDict" << 'EOF'
/*--------------------------------*- C++ -*----------------------------------*\
| =========                 |                                                 |
| \\      /  F ield         | OpenFOAM: The Open Source CFD Toolbox           |
|  \\    /   O peration     | Version:  v2312                                 |
|   \\  /    A nd           | Website:  www.openfoam.com                      |
|    \\/     M anipulation  |                                                 |
\*---------------------------------------------------------------------------*/
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      refinementDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

refinementSurfaces
{
    ".*"
    {
        level (0 0);
    }
}

refinementRegions
{
    // จะถูกกรอกข้อมูลโดยอัตโนมัติตามการวิเคราะห์คุณภาพ
}

refinementFeatures
{
}

addLayers
{
    // พารามิเตอร์การเพิ่ม layer
}

// ************************************************************************* //
EOF

    # ใช้ checkMesh กับ -writeSets เพื่อระบุเซลล์ที่มีปัญหา
    log_info "กำลังรัน checkMesh พร้อมการสร้าง cell set..."
    checkMesh -case "$CASE_DIR" -writeSets -allTopology -allGeometry > /dev/null 2>&1 || true
    
    # ตรวจสอบว่ามีการสร้าง cell sets หรือไม่
    if [ -f "${CASE_DIR}/constant/polyMesh/sets/nonOrthoCells" ]; then
        log_warning "พบ non-orthogonal cell set - จะถูกเลือกเป้าหมายสำหรับการแบ่งย่อย"
    else
        log_warning "ไม่มีการสร้าง cell sets อัตโนมัติ - ใช้วิธีอื่น"
    fi
}

# สร้าง problem region sets
create_problem_sets() {
    log_info "กำลังสร้าง cell sets สำหรับพื้นที่ที่มีปัญหา..."
    
    # สร้าง topoSet dictionary เพื่อระบุเซลล์ที่มีปัญหา
    cat > "${CASE_DIR}/system/topoSetDict" << EOF
/*--------------------------------*- C++ -*----------------------------------*\
| =========                 |                                                 |
| \\      /  F ield         | OpenFOAM: The Open Source CFD Toolbox           |
|  \\    /   O peration     | Version:  v2312                                 |
|   \\  /    A nd           | Website:  www.openfoam.com                      |
|    \\/     M anipulation  |                                                 |
\*---------------------------------------------------------------------------*/
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      topoSetDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

actions
(
    // สร้าง set ของเซลล์ทั้งหมดสำหรับการเลือกเริ่มต้น
    {
        name    allCells;
        type    cellSet;
        action  new;
        source  all;
    }
    
    // ลบเซลล์ที่มีคุณภาพดีอยู่แล้ว
    {
        name    problemCells;
        type    cellSet;
        action  new;
        source  all;
    }
    
    // สร้าง set ตามค่าเกณฑ์ non-orthogonality
    {
        name    highNonOrthoCells;
        type    cellSet;
        action  new;
        source  expression;
        expression "nonOrtho > ${QUALITY_THRESHOLD_NONORTHO}";
    }
    
    // สร้าง set ตามค่าเกณฑ์ skewness
    {
        name    highSkewnessCells;
        type    cellSet;
        action  new;
        source  expression;
        expression "skewness > ${QUALITY_THRESHOLD_SKEWNESS}";
    }
    
    // สหภาพของเซลล์ที่มีปัญหาทั้งหมด
    {
        name    allProblemCells;
        type    cellSet;
        action  new;
        source  set;
        sets    (highNonOrthoCells highSkewnessCells);
    }
);

// ************************************************************************* //
EOF

    # รัน topoSet เพื่อสร้าง cell sets
    topoSet -case "$CASE_DIR" > /dev/null 2>&1 || true
    
    log_info "การสร้าง cell set เสร็จสิ้น"
}

# ใช้การแบ่งย่อยในพื้นที่สำหรับพื้นที่ที่มีปัญหา
apply_local_refinement() {
    log_info "กำลังใช้การแบ่งย่อย mesh ในพื้นที่..."
    
    # ตรวจสอบว่ามีเซลล์ที่มีปัญหาที่จะแบ่งย่อยหรือไม่
    if [ ! -d "${CASE_DIR}/constant/polyMesh/sets" ]; then
        log_warning "ไม่พบ cell sets - ข้ามการแบ่งย่อยในพื้นที่"
        return 1
    fi
    
    # สร้าง refineMeshDict สำหรับการแบ่งย่อยแบบเจาะจง
    cat > "${CASE_DIR}/system/refineMeshDict" << EOF
/*--------------------------------*- C++ -*----------------------------------*\
| =========                 |                                                 |
| \\      /  F ield         | OpenFOAM: The Open Source CFD Toolbox           |
|  \\    /   O peration     | Version:  v2312                                 |
|   \\  /    A nd           | Website:  www.openfoam.com                      |
|    \\/     M anipulation  |                                                 |
\*---------------------------------------------------------------------------*/
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      refineMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

set             allProblemCells;

// ใช้การแบ่งย่อย 3D
directions      3;

// ทำให้หยาบหลังการแบ่งย่อย
coarsen          false;

// เขียน mesh ที่แบ่งย่อยแล้วเป็น time step ใหม่
writeMesh        true;

// ************************************************************************* //
EOF

    # ใช้การแบ่งย่อย
    if refineMesh -case "$CASE_DIR" -overwrite > "${CASE_DIR}/refinement.log" 2>&1; then
        log_success "การแบ่งย่อยในพื้นที่เสร็จสิ้น"
        return 0
    else
        log_warning "การแบ่งย่อยในพื้นที่ล้มเหลว - ดำเนินการต่อด้วย mesh ทั่วไป"
        return 1
    fi
}

# ใช้การทำให้ mesh เรียบหากมี
apply_mesh_smoothing() {
    log_info "กำลังพยายามทำให้ mesh เรียบ..."
    
    # ตรวจสอบว่ามีเครื่องมือทำให้ mesh เรียบหรือไม่
    if command -v collapseEdges &> /dev/null; then
        log_info "กำลังใช้การยุบขอบสำหรับการทำให้ mesh เรียบ..."
        collapseEdges -case "$CASE_DIR" -latestTime > /dev/null 2>&1 || true
    fi
    
    # ลองการทำให้ mesh เรียบแบบ dual หากมี
    if command -v refineWallLayer &> /dev/null; then
        log_info "กำลังใช้การแบ่งย่อย wall layer..."
        # ต้องการข้อมูล boundary mesh
        refineWallLayer -case "$CASE_DIR" ".*" 1 > /dev/null 2>&1 || true
    fi
}

# สร้างสคริปต์การสร้าง mesh ใหม่สำหรับพื้นที่ที่มีปัญหา
generate_remesh_script() {
    local region_name="$1"
    
    cat > "${CASE_DIR}/remesh_${region_name}.sh" << EOF
#!/bin/bash
# สคริปต์การสร้าง mesh ใหม่สำหรับพื้นที่ที่มีปัญหา: ${region_name}

set -e

# ดึงพื้นที่ที่มีปัญหาออกมา
echo "กำลังดึงพื้นที่: ${region_name}"
topoSet -case "${CASE_DIR}" -dict system/region_${region_name}_topoSetDict

# สร้าง surface mesh สำหรับการสร้าง mesh ใหม่
echo "กำลังสร้าง surface mesh"
surfaceSmooth -case "${CASE_DIR}" "${region_name}"

# สร้าง mesh ใหม่สำหรับพื้นที่
echo "กำลังสร้าง mesh ใหม่สำหรับพื้นที่"
blockMesh -case "${CASE_DIR}" -region ${region_name}

# ผสานกลับเข้าสู่ mesh หลัก
echo "กำลังผสาน mesh พื้นที่กลับ"
mergeMeshes "${CASE_DIR}" "${CASE_DIR}/region_${region_name}" > /dev/null 2>&1 || true

echo "การสร้าง mesh ใหม่ของพื้นที่เสร็จสิ้น"
EOF

    chmod +x "${CASE_DIR}/remesh_${region_name}.sh"
}

# ปรับปรุง mesh ผ่านกระบวนการทำซ้ำ
optimize_mesh_iteratively() {
    log_info "กำลังเริ่มการปรับปรุง mesh แบบทำซ้ำ..."
    
    local iteration=1
    local improved=false
    
    while [ $iteration -le $MAX_ITERATIONS ]; do
        log_info "การวนซ้ำการปรับปรุง $iteration/$MAX_ITERATIONS"
        
        # ประเมินคุณภาพปัจจุบัน
        assess_current_quality
        
        # อ่านเมตริกปัจจุบัน
        source "${CASE_DIR}/quality_metrics.txt"
        
        # ตรวจสอบว่าคุณภาพตรงตามค่าเกณฑ์หรือไม่
        local needs_optimization=false
        
        if [ "$MAX_NON_ORTHO" != "0" ] && (( $(echo "$MAX_NON_ORTHO > $QUALITY_THRESHOLD_NONORTHO" | bc -l) )); then
            log_warning "ความไม่ตั้งฉาก ($MAX_NON_ORTHO°) เกินค่าเกณฑ์ ($QUALITY_THRESHOLD_NONORTHO°)"
            needs_optimization=true
        fi
        
        if [ "$MAX_SKEWNESS" != "0" ] && (( $(echo "$MAX_SKEWNESS > $QUALITY_THRESHOLD_SKEWNESS" | bc -l) )); then
            log_warning "ความเบี้ยว ($MAX_SKEWNESS) เกินค่าเกณฑ์ ($QUALITY_THRESHOLD_SKEWNESS)"
            needs_optimization=true
        fi
        
        if [ "$needs_optimization" = "true" ]; then
            log_info "กำลังใช้เทคนิคการปรับปรุง..."
            
            # ลองการแบ่งย่อยในพื้นที่ก่อน
            if apply_local_refinement; then
                improved=true
            else
                # ลองการทำให้ mesh เรียบ
                apply_mesh_smoothing
                improved=true
            fi
            
        else
            log_success "คุณภาพ mesh เป็นไปตามค่าเกณฑ์ทั้งหมด"
            break
        fi
        
        iteration=$((iteration + 1))
    done
    
    if [ "$improved" = "true" ]; then
        log_success "การปรับปรุง mesh เสร็จสิ้น"
    else
        log_warning "ไม่สามารถปรับปรุงต่อไปได้หรือไม่จำเป็นต้องปรับปรุง"
    fi
}

# ประเมินคุณภาพ mesh ปัจจุบัน
assess_current_quality() {
    local output_file="${CASE_DIR}/quality_current.log"
    
    checkMesh -case "$CASE_DIR" -meshQuality > "$output_file" 2>&1 || true
    
    # อัปเดตไฟล์เมตริก
    local total_cells=$(grep -o "total cells.*[0-9]\+" "$output_file" | grep -o "[0-9]\+" || echo "0")
    local non_ortho_cells=$(grep -o "non-orthogonal.*cells.*[0-9]\+" "$output_file" | grep -o "[0-9]\+" || echo "0")
    local skewness_cells=$(grep -o "skewness.*cells.*[0-9]\+" "$output_file" | grep -o "[0-9]\+" || echo "0")
    local max_non_ortho=$(grep -o "maximum non-orthogonality.*[0-9.]\+" "$output_file" | grep -o "[0-9.]\+" || echo "0")
    local max_skewness=$(grep -o "maximum skewness.*[0-9.]\+" "$output_file" | grep -o "[0-9.]\+" || echo "0")
    
    echo "TOTAL_CELLS=$total_cells" > "${CASE_DIR}/quality_metrics.txt"
    echo "NON_ORTHO_CELLS=$non_ortho_cells" >> "${CASE_DIR}/quality_metrics.txt"
    echo "SKEWNESS_CELLS=$skewness_cells" >> "${CASE_DIR}/quality_metrics.txt"
    echo "MAX_NON_ORTHO=$max_non_ortho" >> "${CASE_DIR}/quality_metrics.txt"
    echo "MAX_SKEWNESS=$max_skewness" >> "${CASE_DIR}/quality_metrics.txt"
}

# สร้างรายงานคุณภาพสุดท้าย
generate_quality_report() {
    log_info "กำลังสร้างรายงานคุณภาพสุดท้าย..."
    
    local report_file="${CASE_DIR}/mesh_optimization_report.txt"
    
    # อ่านเมตริกเบื้องต้น
    local initial_total_cells=0
    local initial_non_ortho=0
    local initial_skewness=0
    
    if [ -f "${CASE_DIR}/quality_initial.log" ]; then
        initial_total_cells=$(grep -o "total cells.*[0-9]\+" "${CASE_DIR}/quality_initial.log" | grep -o "[0-9]\+" || echo "0")
        initial_non_ortho=$(grep -o "non-orthogonal.*cells.*[0-9]\+" "${CASE_DIR}/quality_initial.log" | grep -o "[0-9]\+" || echo "0")
        initial_skewness=$(grep -o "skewness.*cells.*[0-9]\+" "${CASE_DIR}/quality_initial.log" | grep -o "[0-9]\+" || echo "0")
    fi
    
    # อ่านเมตริกสุดท้าย
    source "${CASE_DIR}/quality_metrics.txt"
    
    cat > "$report_file" << EOF
รายงานการปรับปรุง MESH
========================

ไดเรกทอรี Case: $CASE_DIR
วันที่ปรับปรุง: $(date)

สถานะ MESH เบื้องต้น:
- เซลล์ทั้งหมด: $initial_total_cells
- เซลล์ที่ไม่ตั้งฉาก: $initial_non_ortho
- เซลล์ที่เบี้ยว: $initial_skewness

สถานะ MESH สุดท้าย:
- เซลล์ทั้งหมด: $TOTAL_CELLS
- เซลล์ที่ไม่ตั้งฉาก: $NON_ORTHO_CELLS
- เซลล์ที่เบี้ยว: $SKEWNESS_CELLS
- ค่าไม่ตั้งฉากสูงสุด: $MAX_NON_ORTHO°
- ค่าเบี้ยวสูงสุด: $MAX_SKEWNESS

การปรับปรุงคุณภาพ:
- การเปลี่ยนแปลงจำนวนเซลล์: $((TOTAL_CELLS - initial_total_cells)) เซลล์
- การลดลงของเซลล์ที่ไม่ตั้งฉาก: $((initial_non_ortho - NON_ORTHO_CELLS)) เซลล์
- การลดลงของเซลล์ที่เบี้ยว: $((initial_skewness - SKEWNESS_CELLS)) เซลล์

การประเมินคุณภาพ:
EOF

    # เพิ่มการประเมินคุณภาพ
    if (( $(echo "$MAX_NON_ORTHO <= $QUALITY_THRESHOLD_NONORTHO" | bc -l) )); then
        echo "- ความไม่ตั้งฉาก: ✅ ผ่าน (ค่าเกณฑ์: $QUALITY_THRESHOLD_NONORTHO°)" >> "$report_file"
    else
        echo "- ความไม่ตั้งฉาก: ❌ ไม่ผ่าน (ค่าเกณฑ์: $QUALITY_THRESHOLD_NONORTHO°)" >> "$report_file"
    fi
    
    if (( $(echo "$MAX_SKEWNESS <= $QUALITY_THRESHOLD_SKEWNESS" | bc -l) )); then
        echo "- ความเบี้ยว: ✅ ผ่าน (ค่าเกณฑ์: $QUALITY_THRESHOLD_SKEWNESS)" >> "$report_file"
    else
        echo "- ความเบี้ยว: ❌ ไม่ผ่าน (ค่าเกณฑ์: $QUALITY_THRESHOLD_SKEWNESS)" >> "$report_file"
    fi
    
    # เพิ่มคำแนะนำ
    cat >> "$report_file" << EOF

คำแนะนำ:
EOF

    if [ "$NON_ORTHO_CELLS" -gt 0 ]; then
        echo "- พิจารณาการแบ่งย่อยเพิ่มเติมสำหรับเซลล์ที่ไม่ตั้งฉาก" >> "$report_file"
    fi
    
    if [ "$SKEWNESS_CELLS" -gt 0 ]; then
        echo "- พิจารณาการทำให้ mesh เรียบสำหรับเซลล์ที่เบี้ยว" >> "$report_file"
    fi
    
    if [ "$TOTAL_CELLS" -gt $((initial_total_cells * 2)) ]; then
        echo "- คำเตือน: จำนวนเซลล์เพิ่มขึ้นอย่างมีนัยสำคัญ - พิจารณาการแบ่งย่อยแบบน้อยลง" >> "$report_file"
    fi
    
    if [ "$NON_ORTHO_CELLS" -eq 0 ] && [ "$SKEWNESS_CELLS" -eq 0 ]; then
        echo "- คุณภาพ mesh ยอดเยี่ยม - พร้อมสำหรับการจำลอง" >> "$report_file"
    fi
    
    log_success "บันทึกรายงานคุณภาพที่: $report_file"
}

# ฟังก์ชันหลักการปรับปรุง
main() {
    log_info "กำลังเริ่มการปรับปรุง mesh สำหรับ case: $CASE_DIR"
    
    # ตรวจสอบไดเรกทอรี case
    if [ ! -d "$CASE_DIR" ]; then
        log_error "ไม่พบไดเรกทอรี case: $CASE_DIR"
        exit 1
    fi
    
    # ตรวจสอบสภาพแวดล้อม OpenFOAM
    check_openfoam_env
    
    # ตรวจสอบว่ามี mesh หรือไม่
    if [ ! -f "${CASE_DIR}/constant/polyMesh/points" ]; then
        log_error "ไม่พบ mesh ในไดเรกทอรี case กรุณาสร้าง mesh ก่อน"
        exit 1
    fi
    
    # สำรอง mesh ต้นฉบับ
    if [ ! -d "${CASE_DIR}/constant/polyMesh.bak" ]; then
        log_info "กำลังสำรอง mesh ต้นฉบับ..."
        cp -r "${CASE_DIR}/constant/polyMesh" "${CASE_DIR}/constant/polyMesh.bak"
    fi
    
    # เวิร์กโฟลว์การปรับปรุงหลัก
    assess_initial_quality
    identify_problem_regions
    create_problem_sets
    optimize_mesh_iteratively
    generate_quality_report
    
    log_success "การปรับปรุง mesh เสร็จสิ้นสำเร็จ!"
    log_info "ตรวจสอบรายงานคุณภาพสำหรับผลลัพธ์โดยละเอียด"
}

# จุดเริ่มต้นของสคริปต์
if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    main "$@"
fi
```

## ขั้นที่ 2: การตั้งค่าและรัน Case แบบกลุ่ม

### 2.1 การสร้าง Case แบบอัตโนมัติ

สำหรับการศึกษาพารามิเตอร์แบบเป็นระบบและการปรับแต่งการออกแบบ การสร้าง case แบบอัตโนมัติเป็นสิ่งจำเป็น เฟรมเวิร์ก Python ต่อไปนี้มีเครื่องมือครบวงจรสำหรับการสร้างและจัดการหลาย cases ของ OpenFOAM:

```python
#!/usr/bin/env python3
"""
เครื่องมือสร้าง case ของ OpenFOAM แบบอัตโนมัติพร้อมการศึกษาพารามิเตอร์
"""

import yaml
import shutil
import os
import sys
import subprocess
import json
from pathlib import Path
from typing import Dict, List, Any, Optional
import logging

# กำหนดค่าการบันทึก
logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')
logger = logging.getLogger(__name__)

class CaseGenerator:
    def __init__(self, config_file: str):
        """
        กำหนดค่าเครื่องมือสร้าง case ด้วยไฟล์คอนฟิกูเรชัน
        
        Args:
            config_file: พาธไปยังไฟล์คอนฟิกูเรชัน YAML
        """
        self.config_file = config_file
        self.config = self.load_config()
        
        # ตรวจสอบคอนฟิกูเรชัน
        self.validate_config()
        
    def load_config(self) -> Dict[str, Any]:
        """โหลดคอนฟิกูเรชันจากไฟล์ YAML"""
        try:
            with open(self.config_file, 'r') as f:
                config = yaml.safe_load(f)
            logger.info(f"โหลดคอนฟิกูเรชันจาก: {self.config_file}")
            return config
        except FileNotFoundError:
            logger.error(f"ไม่พบไฟล์คอนฟิกูเรชัน: {self.config_file}")
            raise
        except yaml.YAMLError as e:
            logger.error(f"ข้อผิดพลาดในการแยกวิเคราะห์ YAML: {e}")
            raise
            
    def validate_config(self):
        """ตรวจสอบคอนฟิกูเรชันที่โหลดมา"""
        required_sections = ['base_directory', 'cases']
        
        for section in required_sections:
            if section not in self.config:
                raise ValueError(f"ส่วนที่จำเป็นในคอนฟิกูเรชันไม่พบ: {section}")
                
        # ตรวจสอบไดเรกทอรีฐาน
        if not os.path.isabs(self.config['base_directory']):
            self.config['base_directory'] = os.path.abspath(self.config['base_directory'])
            
        logger.info(f"ไดเรกทอรี case ฐาน: {self.config['base_directory']}")
        
    def generate_case(self, case_name: str, params: Dict[str, Any]) -> str:
        """
        สร้าง case ของ OpenFOAM แบบสมบูรณ์
        
        Args:
            case_name: ชื่อของ case ที่จะสร้าง
            params: พารามิเตอร์สำหรับคอนฟิกูเรชัน case
            
        Returns:
            พาธไปยังไดเรกทอรี case ที่สร้างแล้ว
        """
        case_dir = os.path.join(self.config['base_directory'], case_name)
        
        logger.info(f"กำลังสร้าง case: {case_name}")
        
        # สร้างโครงสร้างไดเรกทอรี
        self.create_directory_structure(case_dir)
        
        # สร้างไฟล์ case ทั้งหมด
        self.generate_blockmesh_dict(case_dir, params.get('meshing', {}))
        self.generate_control_dict(case_dir, params.get('solver', {}))
        self.generate_fv_schemes(case_dir, params.get('numerics', {}))
        self.generate_fv_solution(case_dir, params.get('solver', {}))
        self.generate_thermophysical_properties(case_dir, params.get('fluid', {}))
        self.generate_turbulence_properties(case_dir, params.get('turbulence', {}))
        self.generate_boundary_conditions(case_dir, params.get('boundary', {}))
        self.generate_mesh_quality_controls(case_dir, params.get('meshing', {}))
        
        # คัดลอกไฟล์เพิ่มเติมหากระบุ
        if 'copy_files' in params:
            self.copy_additional_files(case_dir, params['copy_files'])
            
        # สร้าง README
        self.generate_readme(case_dir, case_name, params)
        
        logger.info(f"การสร้าง case เสร็จสิ้น: {case_dir}")
        return case_dir
        
    def create_directory_structure(self, case_dir: str):
        """สร้างโครงสร้างไดเรกทอรี case มาตรฐานของ OpenFOAM"""
        subdirs = ['0', 'constant', 'system', 'postProcessing', 'scripts']
        
        for subdir in subdirs:
            dir_path = os.path.join(case_dir, subdir)
            os.makedirs(dir_path, exist_ok=True)
            logger.debug(f"สร้างไดเรกทอรี: {dir_path}")
            
    def generate_blockmesh_dict(self, case_dir: str, mesh_params: Dict[str, Any]):
        """สร้างไฟล์ blockMeshDict"""
        output_file = os.path.join(case_dir, 'constant', 'polyMesh', 'blockMeshDict')
        
        # พารามิเตอร์เริ่มต้น
        nx = mesh_params.get('nx', 50)
        ny = mesh_params.get('ny', 50)
        nz = mesh_params.get('nz', 20)
        lx = mesh_params.get('lx', 1.0)
        ly = mesh_params.get('ly', 1.0)
        lz = mesh_params.get('lz', 1.0)
        
        # คำนวณ grading หากระบุ
        grading_x = mesh_params.get('grading_x', 'simple')
        grading_y = mesh_params.get('grading_y', 'simple')
        grading_z = mesh_params.get('grading_z', 'simple')
        
        blockmesh_content = f"""/*--------------------------------*- C++ -*----------------------------------*\\
| =========                 |                                                 |
| \\\\      /  F ield         | OpenFOAM: The Open Source CFD Toolbox           |
|  \\\\    /   O peration     | Version:  v2312                                 |
|   \\\\  /    A nd           | Website:  www.openfoam.com                      |
|    \\\\/     M anipulation  |                                                 |
\\*---------------------------------------------------------------------------*/
FoamFile
{{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

convertToMeters 1;

vertices
(
    (0 0 0)
    ({lx} 0 0)
    ({lx} {ly} 0)
    (0 {ly} 0)
    (0 0 {lz})
    ({lx} 0 {lz})
    ({lx} {ly} {lz})
    (0 {ly} {lz})
);

blocks
(
    hex (0 1 2 3 4 5 6 7) ({nx} {ny} {nz}) simpleGrading ({grading_x} {grading_y} {grading_z})
);

edges
(
);

boundary
(
    minX
    {{
        type fixedValue;
        faces
        (
            (0 4 7 3)
        );
    }}
    maxX
    {{
        type fixedValue;
        faces
        (
            (1 5 6 2)
        );
    }}
    minY
    {{
        type symmetryPlane;
        faces
        (
            (0 1 5 4)
        );
    }}
    maxY
    {{
        type symmetryPlane;
        faces
        (
            (3 2 6 7)
        );
    }}
    minZ
    {{
        type symmetryPlane;
        faces
        (
            (0 3 2 1)
        );
    }}
    maxZ
    {{
        type symmetryPlane;
        faces
        (
            (4 5 6 7)
        );
    }}
);

// ************************************************************************* //"""

        # เขียน blockMeshDict
        with open(output_file, 'w') as f:
            f.write(blockmesh_content)
            
        logger.debug(f"สร้าง blockMeshDict: {output_file}")
        
    def generate_control_dict(self, case_dir: str, solver_params: Dict[str, Any]):
        """สร้างไฟล์ controlDict"""
        output_file = os.path.join(case_dir, 'system', 'controlDict')
        
        # พารามิเตอร์เริ่มต้น
        solver_type = solver_params.get('type', 'simpleFoam')
        start_time = solver_params.get('start_time', 0)
        end_time = solver_params.get('end_time', 1000)
        delta_t = solver_params.get('delta_t', 1)
        write_control = solver_params.get('write_control', 'timeStep')
        write_interval = solver_params.get('write_interval', 100)
        purge_write = solver_params.get('purge_write', 0)
        
        control_dict_content = f"""/*--------------------------------*- C++ -*----------------------------------*\\
| =========                 |                                                 |
| \\\\      /  F ield         | OpenFOAM: The Open Source CFD Toolbox           |
|  \\\\    /   O peration     | Version:  v2312                                 |
|   \\\\  /    A nd           | Website:  www.openfoam.com                      |
|    \\\\/     M anipulation  |                                                 |
\\*---------------------------------------------------------------------------*/
FoamFile
{{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     {solver_type};

startFrom       startTime;

startTime       {start_time};

stopAt          endTime;

endTime         {end_time};

deltaT          {delta_t};

adjustTimeStep  no;

maxCo           1.0;

maxAlphaCo      1.0;

maxDeltaT       1;

writeControl    {write_control};

writeInterval   {write_interval};

purgeWrite      {purge_write};

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

functions
{{
    #includeFunc    residuals
    #includeFunc    wallShearStress
    #includeFunc    yPlus
}}

// ************************************************************************* //"""

        with open(output_file, 'w') as f:
            f.write(control_dict_content)
            
        logger.debug(f"สร้าง controlDict: {output_file}")
        
    def generate_fv_schemes(self, case_dir: str, numerics_params: Dict[str, Any]):
        """สร้างไฟล์ fvSchemes"""
        output_file = os.path.join(case_dir, 'system', 'fvSchemes')
        
        # รูปแบบการกระจายเริ่มต้น
        grad_scheme = numerics_params.get('grad_scheme', 'Gauss linear')
        div_scheme = numerics_params.get('div_scheme', 'Gauss upwind')
        laplacian_scheme = numerics_params.get('laplacian_scheme', 'Gauss linear corrected')
        interpolation_scheme = numerics_params.get('interpolation_scheme', 'linear')
        sn_grad_scheme = numerics_params.get('sn_grad_scheme', 'corrected')
        
        fv_schemes_content = f"""/*--------------------------------*- C++ -*----------------------------------*\\
| =========                 |                                                 |
| \\\\      /  F ield         | OpenFOAM: The Open Source CFD Toolbox           |
|  \\\\    /   O peration     | Version:  v2312                                 |
|   \\\\  /    A nd           | Website:  www.openfoam.com                      |
|    \\\\/     M anipulation  |                                                 |
\\*---------------------------------------------------------------------------*/
FoamFile
{{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{{
    default         steadyState;
}}

gradSchemes
{{
    default         {grad_scheme};
}}

divSchemes
{{
    default         {div_scheme};
    div(phi,U)      {div_scheme};
    div(phi,k)      {div_scheme};
    div(phi,epsilon) {div_scheme};
    div(phi,R)      {div_scheme};
    div(R)          {div_scheme};
    div((nuEff*dev2(T(grad(U))))) Gauss linear;
}}

laplacianSchemes
{{
    default         {laplacian_scheme};
    laplacian(nuEff,U) {laplacian_scheme};
    laplacian((1|A(U)),p) {laplacian_scheme};
    laplacian(Dk,k) {laplacian_scheme};
    laplacian(Depsilon,epsilon) {laplacian_scheme};
}}

interpolationSchemes
{{
    default         {interpolation_scheme};
}}

snGradSchemes
{{
    default         {sn_grad_scheme};
}}

// ************************************************************************* //"""

        with open(output_file, 'w') as f:
            f.write(fv_schemes_content)
            
        logger.debug(f"สร้าง fvSchemes: {output_file}")
        
    def generate_fv_solution(self, case_dir: str, solver_params: Dict[str, Any]):
        """สร้างไฟล์ fvSolution"""
        output_file = os.path.join(case_dir, 'system', 'fvSolution')
        
        # พารามิเตอร์ solver
        solver_type = solver_params.get('type', 'simpleFoam')
        n_iterations = solver_params.get('n_iterations', 1000)
        tolerance = solver_params.get('tolerance', 1e-6)
        rel_tol = solver_params.get('rel_tol', 0.1)
        
        # พารามิเตอร์อัลกอริทึม SIMPLE
        n_correctors = solver_params.get('n_correctors', 2)
        n_non_orthogonal_correctors = solver_params.get('n_non_orthogonal_correctors', 0)
        p_ref_cell = solver_params.get('p_ref_cell', 0)
        p_ref_value = solver_params.get('p_ref_value', 0)
        
        # ปัจจัยการผ่อนคลาย
        p_relaxation = solver_params.get('p_relaxation', 0.3)
        u_relaxation = solver_params.get('u_relaxation', 0.7)
        k_relaxation = solver_params.get('k_relaxation', 0.7)
        epsilon_relaxation = solver_params.get('epsilon_relaxation', 0.7)
        
        fv_solution_content = f"""/*--------------------------------*- C++ -*----------------------------------*\\
| =========                 |                                                 |
| \\\\      /  F ield         | OpenFOAM: The Open Source CFD Toolbox           |
|  \\\\    /   O peration     | Version:  v2312                                 |
|   \\\\  /    A nd           | Website:  www.openfoam.com                      |
|    \\\\/     M anipulation  |                                                 |
\\*---------------------------------------------------------------------------*/
FoamFile
{{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{{
    p
    {{
        solver          GAMG;
        tolerance       {tolerance};
        relTol          {rel_tol};
        smoother        GaussSeidel;
        nPreSweeps      0;
        nPostSweeps     2;
        cacheAgglomeration true;
        nCellsInCoarsestLevel 10;
        agglomerator    faceAreaPair;
        mergeLevels     1;
    }}
    
    U
    {{
        solver          smoothSolver;
        smoother        GaussSeidel;
        tolerance       1e-6;
        relTol          0.1;
        nSweeps         1;
    }}
    
    "(k|epsilon|R)"
    {{
        solver          smoothSolver;
        smoother        GaussSeidel;
        tolerance       1e-6;
        relTol          0.1;
        nSweeps         1;
    }}
}}

SIMPLE
{{
    nCorrectors      {n_correctors};
    nNonOrthogonalCorrectors {n_non_orthogonal_correctors};
    
    pRefCell         {p_ref_cell};
    pRefValue        {p_ref_value};
    
    residualControl
    {{
        p               1e-5;
        U               1e-5;
        "(k|epsilon)"   1e-5;
    }}
}}

relaxationFactors
{{
    fields
    {{
        p               {p_relaxation};
    }}
    equations
    {{
        U               {u_relaxation};
        k               {k_relaxation};
        epsilon         {epsilon_relaxation};
    }}
}}

// ************************************************************************* //"""

        with open(output_file, 'w') as f:
            f.write(fv_solution_content)
            
        logger.debug(f"สร้าง fvSolution: {output_file}")
        
    def generate_thermophysical_properties(self, case_dir: str, fluid_params: Dict[str, Any]):
        """สร้างไฟล์คุณสมบัติทางอุณหพลศาสตร์"""
        # ตรวจสอบว่าระบุคุณสมบัติของ fluid หรือไม่
        if not fluid_params:
            logger.warning("ไม่ได้ระบุคุณสมบัติของ fluid - ข้าม thermophysicalProperties")
            return
            
        output_file = os.path.join(case_dir, 'constant', 'thermophysicalProperties')
        
        fluid_type = fluid_params.get('type', 'water')
        density = fluid_params.get('rho', 1000)
        viscosity = fluid_params.get('mu', 0.001)
        
        thermo_props_content = f"""/*--------------------------------*- C++ -*----------------------------------*\\
| =========                 |                                                 |
| \\\\      /  F ield         | OpenFOAM: The Open Source CFD Toolbox           |
|  \\\\    /   O peration     | Version:  v2312                                 |
|   \\\\  /    A nd           | Website:  www.openfoam.com                      |
|    \\\\/     M anipulation  |                                                 |
\\*---------------------------------------------------------------------------*/
FoamFile
{{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties;
}}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{{
    type            incompressiblePerfectGas;
}}

mixture
{{
    species
    (
        {fluid_type}
    );
    
    {fluid_type}
    {{
        specie
        {{
            molWeight       18.015;
        }}
        transport
        {{
            As              1.672;
            Ts              291.7;
        }}
        thermodynamics
        {{
            Cp              4186;
            Hf              0;
        }}
        equationOfState
        {{
            rho             {density};
        }}
    }}
}}

// ************************************************************************* //"""

        with open(output_file, 'w') as f:
            f.write(thermo_props_content)
            
        logger.debug(f"สร้าง thermophysicalProperties: {output_file}")
        
    def generate_turbulence_properties(self, case_dir: str, turb_params: Dict[str, Any]):
        """สร้างไฟล์คุณสมบัติความปั่นป่วน"""
        output_file = os.path.join(case_dir, 'constant', 'turbulenceProperties')
        
        model_type = turb_params.get('model', 'kEpsilon')
        intensity = turb_params.get('intensity', 0.05)
        length_scale = turb_params.get('length_scale', 0.1)
        
        turb_props_content = f"""/*--------------------------------*- C++ -*----------------------------------*\\
| =========                 |                                                 |
| \\\\      /  F ield         | OpenFOAM: The Open Source CFD Toolbox           |
|  \\\\    /   O peration     | Version:  v2312                                 |
|   \\\\  /    A nd           | Website:  www.openfoam.com                      |
|    \\\\/     M anipulation  |                                                 |
\\*---------------------------------------------------------------------------*/
FoamFile
{{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      turbulenceProperties;
}}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

simulationType  RAS;

RAS
{{
    RASModel        {model_type};
    
    turbulence      on;
    
    printCoeffs     on;
    
    // เงื่อนไขเริ่มต้น
    I               {intensity};
    l               {length_scale};
}}

// ************************************************************************* //"""

        with open(output_file, 'w') as f:
            f.write(turb_props_content)
            
        logger.debug(f"สร้าง turbulenceProperties: {output_file}")
        
    def generate_boundary_conditions(self, case_dir: str, boundary_params: Dict[str, Any]):
        """สร้างไฟล์เงื่อนไขขอบในไดเรกทอรี 0/"""
        zero_dir = os.path.join(case_dir, '0')
        
        # เงื่อนไขขอบความเร็ว
        velocity_file = os.path.join(zero_dir, 'U')
        inlet_velocity = boundary_params.get('inlet_velocity', 1.0)
        
        velocity_content = f"""/*--------------------------------*- C++ -*----------------------------------*\\
| =========                 |                                                 |
| \\\\      /  F ield         | OpenFOAM: The Open Source CFD Toolbox           |
|  \\\\    /   O peration     | Version:  v2312                                 |
|   \\\\  /    A nd           | Website:  www.openfoam.com                      |
|    \\\\/     M anipulation  |                                                 |
\\*---------------------------------------------------------------------------*/
FoamFile
{{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform ({inlet_velocity} 0 0);

boundaryField
{{
    minX
    {{
        type            fixedValue;
        value           uniform ({inlet_velocity} 0 0);
    }}
    
    maxX
    {{
        type            zeroGradient;
    }}
    
    minY
    {{
        type            symmetryPlane;
    }}
    
    maxY
    {{
        type            symmetryPlane;
    }}
    
    minZ
    {{
        type            symmetryPlane;
    }}
    
    maxZ
    {{
        type            symmetryPlane;
    }}
}}

// ************************************************************************* //"""

        with open(velocity_file, 'w') as f:
            f.write(velocity_content)
            
        # เงื่อนไขขอบความดัน
        pressure_file = os.path.join(zero_dir, 'p')
        outlet_pressure = boundary_params.get('outlet_pressure', 0)
        
        pressure_content = f"""/*--------------------------------*- C++ -*----------------------------------*\\
| =========                 |                                                 |
| \\\\      /  F ield         | OpenFOAM: The Open Source CFD Toolbox           |
|  \\\\    /   O peration     | Version:  v2312                                 |
|   \\\\  /    A nd           | Website:  www.openfoam.com                      |
|    \\\\/     M anipulation  |                                                 |
\\*---------------------------------------------------------------------------*/
FoamFile
{{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform {outlet_pressure};

boundaryField
{{
    minX
    {{
        type            zeroGradient;
    }}
    
    maxX
    {{
        type            fixedValue;
        value           uniform {outlet_pressure};
    }}
    
    minY
    {{
        type            symmetryPlane;
    }}
    
    maxY
    {{
        type            symmetryPlane;
    }}
    
    minZ
    {{
        type            symmetryPlane;
    }}
    
    maxZ
    {{
        type            symmetryPlane;
    }}
}}

// ************************************************************************* //"""

        with open(pressure_file, 'w') as f:
            f.write(pressure_content)
            
        # เงื่อนไขขอบความปั่นป่วนหากใช้แบบจำลอง RAS
        turb_params = self.config.get('cases', [{}])[0].get('turbulence', {})
        if turb_params.get('model'):
            self.generate_turbulence_boundary_conditions(zero_dir, boundary_params, turb_params)
            
        logger.debug(f"สร้างเงื่อนไขขอบใน: {zero_dir}")
        
    def generate_turbulence_boundary_conditions(self, zero_dir: str, boundary_params: Dict[str, Any], turb_params: Dict[str, Any]):
        """สร้างเงื่อนไขขอบแบบจำลองความปั่นป่วน"""
        
        # k (พลังงานจลน์ความปั่นป่วน)
        k_file = os.path.join(zero_dir, 'k')
        inlet_velocity = boundary_params.get('inlet_velocity', 1.0)
        intensity = turb_params.get('intensity', 0.05)
        
        # คำนวณ k จากความเข้มความปั่นป่วน
        k_value = 1.5 * (inlet_velocity * intensity) ** 2
        
        k_content = f"""/*--------------------------------*- C++ -*----------------------------------*\\
| =========                 |                                                 |
| \\\\      /  F ield         | OpenFOAM: The Open Source CFD Toolbox           |
|  \\\\    /   O peration     | Version:  v2312                                 |
|   \\\\  /    A nd           | Website:  www.openfoam.com                      |
|    \\\\/     M anipulation  |                                                 |
\\*---------------------------------------------------------------------------*/
FoamFile
{{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform {k_value};

boundaryField
{{
    minX
    {{
        type            fixedValue;
        value           uniform {k_value};
    }}
    
    maxX
    {{
        type            zeroGradient;
    }}
    
    minY
    {{
        type            symmetryPlane;
    }}
    
    maxY
    {{
        type            symmetryPlane;
    }}
    
    minZ
    {{
        type            symmetryPlane;
    }}
    
    maxZ
    {{
        type            symmetryPlane;
    }}
}}

// ************************************************************************* //"""

        with open(k_file, 'w') as f:
            f.write(k_content)
            
        # epsilon (อัตราการสลายตัวความปั่นป่วน)
        epsilon_file = os.path.join(zero_dir, 'epsilon')
        length_scale = turb_params.get('length_scale', 0.1)
        c_mu = 0.09
        
        # คำนวณ epsilon
        epsilon_value = c_mu ** 0.75 * k_value ** 1.5 / length_scale
        
        epsilon_content = f"""/*--------------------------------*- C++ -*----------------------------------*\\
| =========                 |                                                 |
| \\\\      /  F ield         | OpenFOAM: The Open Source CFD Toolbox           |
|  \\\\    /   O peration     | Version:  v2312                                 |
|   \\\\  /    A nd           | Website:  www.openfoam.com                      |
|    \\\\/     M anipulation  |                                                 |
\\*---------------------------------------------------------------------------*/
FoamFile
{{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      epsilon;
}}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform {epsilon_value};

boundaryField
{{
    minX
    {{
        type            fixedValue;
        value           uniform {epsilon_value};
    }}
    
    maxX
    {{
        type            zeroGradient;
    }}
    
    minY
    {{
        type            symmetryPlane;
    }}
    
    maxY
    {{
        type            symmetryPlane;
    }}
    
    minZ
    {{
        type            symmetryPlane;
    }}
    
    maxZ
    {{
        type            symmetryPlane;
    }}
}}

// ************************************************************************* //"""

        with open(epsilon_file, 'w') as f:
            f.write(epsilon_content)
            
        logger.debug("สร้างเงื่อนไขขอบความปั่นป่วน")
        
    def generate_mesh_quality_controls(self, case_dir: str, mesh_params: Dict[str, Any]):
        """สร้างไฟล์ควบคุมคุณภาพ mesh"""
        # สร้าง dictionary ควบคุมคุณภาพ
        quality_file = os.path.join(case_dir, 'system', 'meshQualityDict')
        
        max_non_ortho = mesh_params.get('max_non_orthogonal', 70)
        max_skewness = mesh_params.get('max_skewness', 4)
        max_aspect_ratio = mesh_params.get('max_aspect_ratio', 1000)
        
        quality_content = f"""/*--------------------------------*- C++ -*----------------------------------*\\
| =========                 |                                                 |
| \\\\      /  F ield         | OpenFOAM: The Open Source CFD Toolbox           |
|  \\\\    /   O peration     | Version:  v2312                                 |
|   \\\\  /    A nd           | Website:  www.openfoam.com                      |
|    \\\\/     M anipulation  |                                                 |
\\*---------------------------------------------------------------------------*/
FoamFile
{{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      meshQualityDict;
}}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// ค่าความไม่ตั้งฉากสูงสุดที่อนุญาต
maxNonOrthogonal {max_non_ortho};

// ค่าเบี้ยวสูงสุดที่อนุญาต
maxSkewness     {max_skewness};

// อัตราส่วนด้านสูงสุดที่อนุญาต
maxAspectRatio  {max_aspect_ratio};

// การตรวจสอบคุณภาพ mesh
checkMesh       on;

// เขียนข้อมูลคุณภาพ mesh ออกมา
writeMeshQuality    on;

// ************************************************************************* //"""

        with open(quality_file, 'w') as f:
            f.write(quality_content)
            
        logger.debug(f"สร้างควบคุมคุณภาพ mesh: {quality_file}")
        
    def copy_additional_files(self, case_dir: str, copy_files: List[str]):
        """คัดลอกไฟล์เพิ่มเติมไปยังไดเรกทอรี case"""
        for file_spec in copy_files:
            if isinstance(file_spec, str):
                # การคัดลอกไฟล์แบบง่าย
                src_file = file_spec
                dst_file = os.path.join(case_dir, os.path.basename(file_spec))
            elif isinstance(file_spec, dict):
                # Dictionary พร้อมต้นทางและปลายทาง
                src_file = file_spec['src']
                dst_file = os.path.join(case_dir, file_spec['dst'])
            else:
                logger.warning(f"ข้อมูลจำเพาะไฟล์ไม่ถูกต้อง: {file_spec}")
                continue
                
            try:
                shutil.copy2(src_file, dst_file)
                logger.debug(f"คัดลอกไฟล์: {src_file} -> {dst_file}")
            except Exception as e:
                logger.error(f"ล้มเหลวในการคัดลอกไฟล์ {src_file}: {e}")
                
    def generate_readme(self, case_dir: str, case_name: str, params: Dict[str, Any]):
        """สร้างไฟล์ README สำหรับ case"""
        readme_file = os.path.join(case_dir, 'README.md')
        
        readme_content = f"""# {case_name}

## คำอธิบาย Case
สร้างโดยอัตโนมัติโดยใช้เครื่องมือสร้าง case ของ OpenFOAM

## พารามิเตอร์

### พารามิเตอร์ Mesh
- Grid: {params.get('meshing', {}).get('nx', 50)} × {params.get('meshing', {}).get('ny', 50)} × {params.get('meshing', {}).get('nz', 20)}
- โดเมน: {params.get('meshing', {}).get('lx', 1.0)} × {params.get('meshing', {}).get('ly', 1.0)} × {params.get('meshing', {}).get('lz', 1.0)}

### พารามิเตอร์ Solver
- Solver: {params.get('solver', {}).get('type', 'simpleFoam')}
- เวลาสิ้นสุด: {params.get('solver', {}).get('end_time', 1000)}
- ช่วงเวลา: {params.get('solver', {}).get('delta_t', 1)}

### พารามิเตอร์การไหล
- ความเร็วอินเลต: {params.get('boundary', {}).get('inlet_velocity', 1.0)} m/s
- ความดันเอาต์เลต: {params.get('boundary', {}).get('outlet_pressure', 0)} Pa

### คุณสมบัติของ Fluid
- ความหนาแน่น: {params.get('fluid', {}).get('rho', 1000)} kg/m³
- ความหนืด: {params.get('fluid', {}).get('mu', 0.001)} Pa·s

### แบบจำลองความปั่นป่วน
- แบบจำลอง: {params.get('turbulence', {}).get('model', 'None')}
- ความเข้ม: {params.get('turbulence', {}).get('intensity', 0.05)}
- มาตราส่วนความยาว: {params.get('turbulence', {}).get('length_scale', 0.1)} m

## การใช้งาน

1. สร้าง mesh:
```bash
cd {case_name}
blockMesh
```

2. รัน solver:
```bash
{params.get('solver', {}).get('type', 'simpleFoam')}
```

3. ประมวลผลหลัง:
```bash
paraFoam
```

## ไฟล์ที่สร้างขึ้น
- `constant/polyMesh/blockMeshDict` - คำจำกัดความ mesh
- `system/controlDict` - พารามิเตอร์ควบคุม solver
- `system/fvSchemes` - รูปแบบเชิงตัวเลข
- `system/fvSolution` - การตั้งค่า solver เชิงเส้น
- `0/U`, `0/p` - เงื่อนไขเริ่มต้นและเงื่อนไขขอบ
- `constant/thermophysicalProperties` - คุณสมบัติของ fluid
- `constant/turbulenceProperties` - การตั้งค่าแบบจำลองความปั่นป่วน

## หมายเหตุ
case นี้สร้างโดยอัตโนมัติ ตรวจสอบการตั้งค่าทั้งหมดก่อนรันการจำลอง

## ประวัติ
- สร้าง: {subprocess.check_output(['date'], text=True).strip()}
- เครื่องมือสร้าง: เครื่องมือสร้าง case ของ OpenFOAM v1.0
"""

        with open(readme_file, 'w') as f:
            f.write(readme_content)
            
        logger.debug(f"สร้าง README: {readme_file}")
        
    def batch_generate(self) -> List[str]:
        """สร้างหลาย cases จากการสแกนพารามิเตอร์"""
        logger.info("กำลังเริ่มการสร้าง case แบบกลุ่ม...")
        
        case_matrix = self.config['cases']
        generated_cases = []
        
        for i, case_config in enumerate(case_matrix):
            case_name = case_config['name']
            logger.info(f"กำลังสร้าง case {i+1}/{len(case_matrix)}: {case_name}")
            
            try:
                case_path = self.generate_case(case_name, case_config)
                generated_cases.append(case_path)
                logger.info(f"✓ สร้างสำเร็จ: {case_name}")
            except Exception as e:
                logger.error(f"✗ ล้มเหลวในการสร้าง case {case_name}: {e}")
                continue
                
        logger.info(f"การสร้างแบบกลุ่มเสร็จสิ้น {len(generated_cases)}/{len(case_matrix)} cases ที่สร้าง")
        return generated_cases
        
    def submit_cases_to_cluster(self, cases: Optional[List[str]] = None) -> List[str]:
        """ส่ง cases ที่สร้างแล้วไปยังคลัสเตอร์ HPC"""
        if cases is None:
            # หาไดเรกทอรี case ทั้งหมด
            cases = []
            for case_name in os.listdir(self.config['base_directory']):
                case_path = os.path.join(self.config['base_directory'], case_name)
                if os.path.isdir(case_path):
                    cases.append(case_path)
                    
        submitted_jobs = []
        
        for case_dir in cases:
            case_name = os.path.basename(case_dir)
            
            # ตรวจสอบว่า case ถูกส่งแล้วหรือไม่
            if os.path.exists(os.path.join(case_dir, '.submitted')):
                logger.info(f"Case {case_name} ถูกส่งแล้ว - ข้าม")
                continue
                
            logger.info(f"กำลังส่ง case ไปยังคลัสเตอร์: {case_name}")
            
            try:
                job_id = self.submit_job(case_name, case_dir)
                if job_id:
                    submitted_jobs.append(job_id)
                    
                    # ทำเครื่องหมาย case ว่าถูกส่งแล้ว
                    with open(os.path.join(case_dir, '.submitted'), 'w') as f:
                        f.write(f"ส่งแล้ว: {subprocess.check_output(['date'], text=True).strip()}\n")
                        f.write(f"Job ID: {job_id}\n")
                        
            except Exception as e:
                logger.error(f"ล้มเหลวในการส่ง case {case_name}: {e}")
                continue
                
        logger.info(f"การส่งไปยังคลัสเตอร์เสร็จสิ้น {len(submitted_jobs)} jobs ที่ส่ง")
        return submitted_jobs
        
    def submit_job(self, case_name: str, case_dir: str) -> Optional[str]:
        """ส่ง job เดี่ยวไปยัง scheduler คลัสเตอร์"""
        
        # ตรวจสอบ scheduler ที่มี
        scheduler = None
        if command_exists('sbatch'):
            scheduler = 'slurm'
        elif command_exists('qsub'):
            scheduler = 'pbs'
        elif command_exists('bsub'):
            scheduler = 'lsf'
            
        if not scheduler:
            logger.warning("ไม่พบ scheduler ของคลัสเตอร์ - รันในเครื่อง")
            return self.run_locally(case_name, case_dir)
            
        # สร้าง job script ตาม scheduler
        job_script = os.path.join(case_dir, 'submit_job.sh')
        
        # อ่านประเภท solver จาก controlDict
        control_dict_path = os.path.join(case_dir, 'system', 'controlDict')
        solver_type = 'simpleFoam'  # ค่าเริ่มต้น
        
        if os.path.exists(control_dict_path):
            try:
                with open(control_dict_path, 'r') as f:
                    content = f.read()
                    import re
                    match = re.search(r'application\s+(\w+)', content)
                    if match:
                        solver_type = match.group(1)
            except Exception:
                pass
                
        # สร้าง job script
        if scheduler == 'slurm':
            self.generate_slurm_script(job_script, case_name, solver_type)
        elif scheduler == 'pbs':
            self.generate_pbs_script(job_script, case_name, solver_type)
        elif scheduler == 'lsf':
            self.generate_lsf_script(job_script, case_name, solver_type)
            
        # ส่ง job
        try:
            if scheduler == 'slurm':
                result = subprocess.run(['sbatch', job_script], capture_output=True, text=True)
                if result.returncode == 0:
                    job_id = result.stdout.split()[-1]
                    logger.info(f"ส่ง SLURM job {job_id}")
                    return job_id
            elif scheduler == 'pbs':
                result = subprocess.run(['qsub', job_script], capture_output=True, text=True)
                if result.returncode == 0:
                    job_id = result.stdout.strip()
                    logger.info(f"ส่ง PBS job {job_id}")
                    return job_id
            elif scheduler == 'lsf':
                result = subprocess.run(['bsub', '<', job_script], shell=True, capture_output=True, text=True)
                if result.returncode == 0:
                    # ดึง job ID จากผลลัพธ์ LSF
                    import re
                    match = re.search(r'Job <(\d+)>', result.stdout)
                    if match:
                        job_id = match.group(1)
                        logger.info(f"ส่ง LSF job {job_id}")
                        return job_id
                        
        except Exception as e:
            logger.error(f"ล้มเหลวในการส่ง job ผ่าน {scheduler}: {e}")
            
        return None
        
    def generate_slurm_script(self, job_script: str, case_name: str, solver_type: str):
        """สร้าง job script ของ SLURM"""
        script_content = f"""#!/bin/bash
#SBATCH --job-name={case_name}
#SBATCH --output={case_name}_%j.out
#SBATCH --error={case_name}_%j.err
#SBATCH --ntasks=16
#SBATCH --time=24:00:00
#SBATCH --partition=normal

# โหลดสภาพแวดล้อม OpenFOAM
source /opt/openfoam/etc/bashrc

# เปลี่ยนไปยังไดเรกทอรี case
cd $SLURM_SUBMIT_DIR

# สร้าง mesh
echo "กำลังสร้าง mesh..."
blockMesh

# ตรวจสอบคุณภาพ mesh
echo "กำลังตรวจสอบคุณภาพ mesh..."
checkMesh

# รัน solver
echo "กำลังรัน {solver_type}..."
{solver_type}

echo "การจำลองเสร็จสิ้น!"
"""

        with open(job_script, 'w') as f:
            f.write(script_content)
        os.chmod(job_script, 0o755)
        
    def generate_pbs_script(self, job_script: str, case_name: str, solver_type: str):
        """สร้าง job script ของ PBS"""
        script_content = f"""#!/bin/bash
#PBS -N {case_name}
#PBS -o {case_name}.$PBS_JOBID.out
#PBS -e {case_name}.$PBS_JOBID.err
#PBS -l nodes=2:ppn=8
#PBS -l walltime=24:00:00

# โหลดสภาพแวดล้อม OpenFOAM
source /opt/openfoam/etc/bashrc

# เปลี่ยนไปยังไดเรกทอรี case
cd $PBS_O_WORKDIR

# สร้าง mesh
echo "กำลังสร้าง mesh..."
blockMesh

# ตรวจสอบคุณภาพ mesh
echo "กำลังตรวจสอบคุณภาพ mesh..."
checkMesh

# รัน solver
echo "กำลังรัน {solver_type}..."
{solver_type}

echo "การจำลองเสร็จสิ้น!"
"""

        with open(job_script, 'w') as f:
            f.write(script_content)
        os.chmod(job_script, 0o755)
        
    def generate_lsf_script(self, job_script: str, case_name: str, solver_type: str):
        """สร้าง job script ของ LSF"""
        script_content = f"""#!/bin/bash
#BSUB -J {case_name}
#BSUB -o {case_name}_%J.out
#BSUB -e {case_name}_%J.err
#BSUB -n 16
#BSUB -W 24:00

# โหลดสภาพแวดล้อม OpenFOAM
source /opt/openfoam/etc/bashrc

# เปลี่ยนไปยังไดเรกทอรี case
cd $LS_SUBCWD

# สร้าง mesh
echo "กำลังสร้าง mesh..."
blockMesh

# ตรวจสอบคุณภาพ mesh
echo "กำลังตรวจสอบคุณภาพ mesh..."
checkMesh

# รัน solver
echo "กำลังรัน {solver_type}..."
{solver_type}

echo "การจำลองเสร็จสิ้น!"
"""

        with open(job_script, 'w') as f:
            f.write(script_content)
        os.chmod(job_script, 0o755)
        
    def run_locally(self, case_name: str, case_dir: str) -> Optional[str]:
        """รัน case ในเครื่อง (background process)"""
        try:
            # สร้าง run script
            run_script = os.path.join(case_dir, 'run_local.sh')
            
            script_content = f"""#!/bin/bash
# สคริปต์การรันในเครื่องสำหรับ {case_name}

# โหลดสภาพแวดล้อม OpenFOAM
source $HOME/OpenFOAM/OpenFOAM-10/etc/bashrc

# เปลี่ยนไปยังไดเรกทอรี case
cd "{case_dir}"

# สร้าง mesh
echo "กำลังสร้าง mesh..."
blockMesh

# ตรวจสอบคุณภาพ mesh
echo "กำลังตรวจสอบคุณภาพ mesh..."
checkMesh

# อ่านประเภท solver จาก controlDict
if [ -f "system/controlDict" ]; then
    SOLVER=$(grep "application" system/controlDict | awk '{{print $2}}')
else
    SOLVER="simpleFoam"
fi

# รัน solver ใน background
echo "กำลังรัน $SOLVER ใน background..."
nohup $SOLVER > simulation.log 2>&1 &

# รับ background process ID
PID=$!
echo "การจำลองเริ่มต้นด้วย PID: $PID"
echo "ติดตามความคืบหน้าด้วย: tail -f simulation.log"

# บันทึก PID ไปยังไฟล์
echo $PID > .simulation_pid
"""

            with open(run_script, 'w') as f:
                f.write(script_content)
            os.chmod(run_script, 0o755)
            
            # เริ่ม process
            result = subprocess.Popen([run_script], cwd=case_dir, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
            
            # ส่งคืน process ID เป็น job identifier
            job_id = f"local_{result.pid}"
            logger.info(f"เริ่ม local job {job_id}")
            
            return job_id
            
        except Exception as e:
            logger.error(f"ล้มเหลวในการเริ่ม local job: {e}")
            return None


def command_exists(command):
    """ตรวจสอบว่าคำสั่งมีอยู่ใน PATH ของระบบหรือไม่"""
    return shutil.which(command) is not None


def main():
    """ฟังก์ชันหลักสำหรับการใช้งาน command-line"""
    import argparse
    
    parser = argparse.ArgumentParser(description='เครื่องมือสร้าง case ของ OpenFOAM แบบอัตโนมัติ')
    parser.add_argument('config', help='ไฟล์คอนฟิกูเรชัน YAML')
    parser.add_argument('--generate-only', action='store_true', 
                       help='สร้าง cases เท่านั้น ไม่ต้องส่งไปยังคลัสเตอร์')
    parser.add_argument('--submit-only', action='store_true',
                       help='ส่ง cases ที่มีอยู่แล้วไปยังคลัสเตอร์เท่านั้น')
    parser.add_argument('--dry-run', action='store_true',
                       help='แสดงว่าจะทำอะไรโดยไม่ต้องดำเนินการ')
    
    args = parser.parse_args()
    
    # กำหนดค่าเครื่องมือสร้าง
    try:
        generator = CaseGenerator(args.config)
    except Exception as e:
        logger.error(f"ล้มเหลวในการกำหนดค่าเครื่องมือสร้าง case: {e}")
        return 1
        
    if args.dry_run:
        logger.info("โหมด DRY RUN - จะไม่สร้างไฟล์จริง")
        
    # รันการสร้างหรือการส่งตามอาร์กิวเมนต์
    if not args.submit_only:
        logger.info("กำลังเริ่มการสร้าง case...")
        
        if args.dry_run:
            logger.info(f"จะสร้าง {len(generator.config['cases'])} cases ในไดเรกทอรี: {generator.config['base_directory']}")
            for case_config in generator.config['cases']:
                logger.info(f"  - {case_config['name']}")
        else:
            generated_cases = generator.batch_generate()
            
            if not args.generate_only:
                logger.info("กำลังส่ง cases ไปยังคลัสเตอร์...")
                generator.submit_cases_to_cluster(generated_cases)
                
    elif args.submit_only:
        logger.info("กำลังส่ง cases ที่มีอยู่แล้วไปยังคลัสเตอร์...")
        if not args.dry_run:
            generator.submit_cases_to_cluster()
        else:
            logger.info("จะส่ง cases ที่มีอยู่แล้วไปยังคลัสเตอร์")
            
    logger.info("การสร้างและส่ง case เสร็จสิ้น!")
    return 0


if __name__ == "__main__":
    sys.exit(main())
```

### 2.2 ตัวอย่างคอนฟิกูเรชัน

```yaml
# case_study_config.yaml
base_directory: "/home/user/openfoam_cases"

cases:
  - name: "re_100_coarse"
    description: "Reynolds number ต่ำ mesh หยาบ"
    meshing:
      nx: 50
      ny: 50
      nz: 20
      lx: 2.0
      ly: 1.0
      lz: 1.0
      max_non_orthogonal: 70
      max_skewness: 4
    solver:
      type: "simpleFoam"
      end_time: 1000
      n_iterations: 1000
      tolerance: 1e-6
      n_correctors: 2
      p_relaxation: 0.3
      u_relaxation: 0.7
    fluid:
      type: "water"
      rho: 1000
      mu: 0.001
    turbulence:
      model: "kEpsilon"
      intensity: 0.05
      length_scale: 0.1
    boundary:
      inlet_velocity: 1.0
      outlet_pressure: 0
      
  - name: "re_500_medium"
    description: "Reynolds number ปานกลาง mesh กลาง"
    meshing:
      nx: 100
      ny: 75
      nz: 30
      lx: 2.0
      ly: 1.0
      lz: 1.0
      grading_x: 1.2
      max_non_orthogonal: 65
      max_skewness: 3
    solver:
      type: "simpleFoam"
      end_time: 2000
      n_iterations: 2000
      tolerance: 1e-7
      n_correctors: 3
      p_relaxation: 0.2
      u_relaxation: 0.6
    fluid:
      type: "air"
      rho: 1.225
      mu: 1.789e-5
    turbulence:
      model: "kOmegaSST"
      intensity: 0.03
      length_scale: 0.07
    boundary:
      inlet_velocity: 5.0
      outlet_pressure: 0
      
  - name: "re_1000_fine"
    description: "Reynolds number สูง mesh ละเอียด"
    meshing:
      nx: 200
      ny: 150
      nz: 60
      lx: 2.0
      ly: 1.0
      lz: 1.0
      grading_x: 1.5
      max_non_orthogonal: 60
      max_skewness: 2
    solver:
      type: "pimpleFoam"
      end_time: 5.0
      delta_t: 0.001
      write_control: "timeStep"
      write_interval: 500
      n_correctors: 3
      n_non_orthogonal_correctors: 2
      p_relaxation: 0.1
      u_relaxation: 0.5
    fluid:
      type: "air"
      rho: 1.225
      mu: 1.789e-5
    turbulence:
      model: "kOmegaSST"
      intensity: 0.02
      length_scale: 0.05
    boundary:
      inlet_velocity: 10.0
      outlet_pressure: 0
```

เฟรมเวิร์กยูทิลิตี้แบบครบวงจรนี้มี:

1. **การประเมินคุณภาพ mesh แบบอัตโนมัติ** พร้อมรายงานโดยละเอียด
2. **เครื่องมือปรับปรุง mesh** สำหรับการปรับปรุงคุณภาพแบบเป็นระบบ
3. **การสร้าง case แบบกลุ่ม** พร้อมการศึกษาพารามิเตอร์
4. **การส่งไปยังคลัสเตอร์** รองรับ schedulers หลายตัว
5. **การควบคุมคุณภาพ** และการตรวจสอบตลอดทั้งเวิร์กโฟลว์

เครื่องมือเหล่านี้เปิดใช้งานเวิร์กโฟลว์ CFD แบบเป็นระบบสำหรับการวิจัยและแอปพลิเคชันทางวิศวกรรม โดยรับประกันคุณภาพและการทำซ้ำที่สอดคล้องกันในการศึกษาพารามิเตอร์ขนาดใหญ่
