## 🔧 Case Setup Automation

### Automated Boundary Condition Generation

#### Template-based Boundary Condition Setup

**OpenFOAM Code Implementation:**
```python
#!/usr/bin/env python3
"""
Automated boundary condition generator for OpenFOAM cases
"""
import os
import yaml
import numpy as np

class BoundaryConditionGenerator:
    def __init__(self, config_file):
        self.config = self.load_config(config_file)

    def load_config(self, config_file):
        """Load configuration from YAML file"""
        with open(config_file, 'r') as f:
            return yaml.safe_load(f)

    def generate_velocity_field(self, field_name="U"):
        """Generate velocity field with automated boundary conditions"""
        template = f"""/*--------------------------------*- C++ -*----------------------------------*\\
| =========                 |                                                 |
| \\\\      /  F ield         | OpenFOAM: The Open Source CFD Toolbox           |
|  \\\\    /   O peration     | Version:  v2312                                 |
|   \\\\  /    A nd           | Website:  www.openfoam.com                      |
|    \\\\/     M anipulation  |                                                 |
\\*---------------------------------------------------------------------------*/
FoamFile
{{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      {field_name};
}}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform {self.config['internal_velocity']};

boundaryField
{{
"""

        for boundary, bc_data in self.config['boundaries'].items():
            template += self.generate_boundary_block(boundary, bc_data, field_name)

        template += """}\n\n// ************************************************************************* //"""
        return template

    def generate_boundary_block(self, boundary, bc_data, field_name):
        """Generate boundary condition block for specific patch"""
        bc_type = bc_data.get('type', 'fixedValue')

        if bc_type == 'fixedValue':
            value = bc_data.get('value', 'uniform (0 0 0)')
            return f"""    {boundary}
    {{
        type            fixedValue;
        value           {value};
    }}
"""
        elif bc_type == 'zeroGradient':
            return f"""    {boundary}
    {{
        type            zeroGradient;
    }}
"""
        elif bc_type == 'slip':
            return f"""    {boundary}
    {{
        type            slip;
    }}
"""
        elif bc_type == 'wall':
            return f"""    {boundary}
    {{
        type            noSlip;
    }}
"""
        else:
            return f"""    {boundary}
    {{
        type            {bc_type};
    }}
"""

# Example configuration
config = {
    'internal_velocity': 'uniform (10 0 0)',
    'boundaries': {
        'inlet': {
            'type': 'fixedValue',
            'value': 'uniform (10 0 0)'
        },
        'outlet': {
            'type': 'zeroGradient'
        },
        'walls': {
            'type': 'noSlip'
        },
        'symmetry': {
            'type': 'symmetryPlane'
        }
    }
}

# Generate boundary conditions
generator = BoundaryConditionGenerator('bc_config.yaml')
velocity_field = generator.generate_velocity_field()

# Write to file
with open('0/U', 'w') as f:
    f.write(velocity_field)
```

### Automated Mesh Generation Script

**Algorithm Flow:**
```bash
#!/bin/bash
# Automated mesh generation workflow

set -e  # Exit on any error

echo "Starting automated mesh generation workflow..."

# Configuration
CASE_DIR=$(pwd)
GEOMETRY_DIR="${CASE_DIR}/constant/triSurface"
MESH_QUALITY_THRESHOLD=0.8

# Step 1: Clean existing mesh
echo "Cleaning existing mesh..."
rm -rf ${CASE_DIR}/constant/polyMesh/*

# Step 2: Generate background mesh with blockMesh
echo "Generating background mesh..."
blockMesh > log.blockMesh 2>&1
if [ $? -ne 0 ]; then
    echo "ERROR: blockMesh failed. Check log.blockMesh"
    exit 1
fi

# Step 3: Verify geometry files
echo "Checking geometry files..."
if [ ! -f "${GEOMETRY_DIR}/geometry.stl" ]; then
    echo "ERROR: Geometry file not found: ${GEOMETRY_DIR}/geometry.stl"
    exit 1
fi

# Step 4: Run surface feature extraction
echo "Extracting surface features..."
surfaceFeatureExtract > log.surfaceFeatureExtract 2>&1

# Step 5: Execute snappyHexMesh in stages
echo "Stage 1: Castellated mesh generation..."
snappyHexMesh -castellatedMesh > log.snappyHexMesh.castellated 2>&1

echo "Stage 2: Snapping to surface..."
snappyHexMesh -snap > log.snappyHexMesh.snap 2>&1

echo "Stage 3: Adding boundary layers..."
snappyHexMesh -addLayers > log.snappyHexMesh.layers 2>&1

# Step 6: Mesh quality assessment
echo "Assessing mesh quality..."
checkMesh -allGeometry -allTopology > log.checkMesh 2>&1

# Extract mesh quality metrics
NON_ORTHO=$(grep "Non-orthogonality" log.checkMesh | tail -1 | awk '{print $3}')
skewness=$(grep "skewness" log.checkMesh | tail -1 | awk '{print $3}')

# Quality check
if (( $(echo "$NON_ORTHO > 75" | bc -l) )); then
    echo "WARNING: High non-orthogonality detected: $NON_ORTHO"
fi

if (( $(echo "$skewness > 4" | bc -l) )); then
    echo "WARNING: High skewness detected: $skewness"
fi

echo "Mesh generation completed successfully!"
echo "Non-orthogonality: $NON_ORTHO"
echo "Skewness: $skewness"

# Step 7: Generate mesh statistics
echo "Generating mesh statistics..."
meshStats >> log.meshStats

echo "Automated mesh generation workflow completed!"
```

### Advanced Geometry Processing

#### CAD File Conversion and Repair

**OpenFOAM Code Implementation:**
```python
#!/usr/bin/env python3
"""
Advanced geometry processing for OpenFOAM meshing
"""
import os
import numpy as np
import trimesh
from pathlib import Path

class GeometryProcessor:
    def __init__(self, input_file, output_dir):
        self.input_file = Path(input_file)
        self.output_dir = Path(output_dir)
        self.output_dir.mkdir(exist_ok=True)

    def load_and_repair_geometry(self):
        """Load CAD geometry and perform automatic repairs"""
        print(f"Loading geometry: {self.input_file}")

        # Load mesh using trimesh
        mesh = trimesh.load_mesh(str(self.input_file))

        # Basic repairs
        print("Performing mesh repairs...")
        mesh.remove_duplicate_faces()
        mesh.remove_unreferenced_vertices()
        mesh.fix_normals()

        # Check and fix watertightness
        if not mesh.is_watertight:
            print("Mesh is not watertight, attempting repair...")
            mesh.fill_holes()

        # Remove degenerate faces
        mesh.remove_degenerate_faces()

        return mesh

    def optimize_mesh_quality(self, mesh, target_face_count=None):
        """Optimize mesh for CFD applications"""

        if target_face_count is None:
            target_face_count = len(mesh.faces) // 2  # Reduce by 50%

        print(f"Reducing mesh to {target_face_count} faces...")

        # Quadric decimation for mesh simplification
        simplified = mesh.simplify_quadric_decimation(
            target_face_count,
            preserve_attr=True
        )

        # Mesh smoothing
        print("Applying Laplacian smoothing...")
        simplified = simplified.smoothed()

        return simplified

    def extract_feature_edges(self, mesh, angle_threshold=30):
        """Extract sharp edges for refinement"""

        print(f"Extracting feature edges with angle threshold: {angle_threshold}°")

        # Compute face normals
        face_normals = mesh.face_normals

        # Find edges between faces with large normal differences
        feature_edges = []

        for edge_key in mesh.edges_unique:
            faces = mesh.face_adjacency[edge_key]

            if len(faces) == 2:
                normal1, normal2 = face_normals[faces]
                angle = np.degrees(np.arccos(np.clip(np.dot(normal1, normal2), -1, 1)))

                if angle > angle_threshold:
                    feature_edges.append(edge_key)

        return np.array(feature_edges)

    def generate_stl_output(self, mesh, filename):
        """Generate STL file for OpenFOAM"""

        output_file = self.output_dir / f"{filename}.stl"

        print(f"Writing STL file: {output_file}")

        # Export as binary STL
        mesh.export(str(output_file))

        # Verify output file
        verification_mesh = trimesh.load_mesh(str(output_file))

        if verification_mesh.is_watertight:
            print("✓ STL file is watertight")
        else:
            print("⚠ STL file has issues")

        return output_file

    def create_surface_features_dict(self, feature_edges, mesh_name):
        """Create surfaceFeaturesDict for snappyHexMesh"""

        output_file = self.output_dir / "surfaceFeaturesDict"

        features_dict = f"""/*--------------------------------*- C++ -*----------------------------------*\\
| =========                 |                                                 |
| \\\\      /  F ield         | OpenFOAM: The Open Source CFD Toolbox           |
|  \\\\    /   O peration     | Version:  v2312                                 |
|   \\\\  /    A nd           | Website:  www.openfoam.com                      |
|    \\\\/     M anipulation  |                                                 |
\\*---------------------------------------------------------------------------*/
FoamFile
{{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      surfaceFeaturesDict;
}}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

{mesh_name}.stl
{{
    extractionMethod    extractFromSurface;
    extractFromSurfaceCoeffs
    {{
        includedAngle   150;
    }}

    // Optional: explicit feature edges
    explicitFeatureEdges
    {{
        // Feature edges will be automatically added here
    }}

    // Subset features
    subsetFeatures
    {{
        // Define regions for different refinement levels
    }}
}}

// ************************************************************************* //
"""

        with open(output_file, 'w') as f:
            f.write(features_dict)

        return output_file

# Usage example
if __name__ == "__main__":
    processor = GeometryProcessor(
        "input_geometry.step",
        "processed_geometry"
    )

    # Load and repair geometry
    mesh = processor.load_and_repair_geometry()

    # Optimize mesh quality
    optimized_mesh = processor.optimize_mesh_quality(mesh)

    # Extract feature edges
    feature_edges = processor.extract_feature_edges(optimized_mesh)

    # Generate STL files
    stl_file = processor.generate_stl_output(optimized_mesh, "geometry")

    # Create surface features dictionary
    features_dict = processor.create_surface_features_dict(feature_edges, "geometry")

    print("Geometry processing completed!")
```

### Automated Field Initialization

#### Smart Initial Field Generation

**OpenFOAM Code Implementation:**
```python
#!/usr/bin/env python3
"""
Advanced field initialization with physical consistency
"""
import numpy as np
import openfoam
from scipy.interpolate import griddata

class FieldInitializer:
    def __init__(self, mesh_file):
        self.mesh = openfoam.PolyMesh(mesh_file)
        self.cell_centers = self.mesh.cellCenters()
        self.boundary_info = self.mesh.boundaryInfo()

    def create_velocity_profile(self, profile_type='parabolic'):
        """Create physically realistic velocity profiles"""

        n_cells = len(self.cell_centers)
        U = np.zeros((n_cells, 3))

        if profile_type == 'parabolic':
            # Parabolic profile for channel flow
            y_coords = self.cell_centers[:, 1]
            y_min, y_max = np.min(y_coords), np.max(y_coords)
            y_norm = (y_coords - y_min) / (y_max - y_min)

            # Parabolic velocity profile: u = 4*U_max*y*(H-y)/H^2
            U_max = 1.0  # Maximum velocity
            U[:, 0] = 4 * U_max * y_norm * (1 - y_norm)

        elif profile_type == 'boundary_layer':
            # Boundary layer profile
            wall_distance = self.calculate_wall_distance()
            u_tau = 0.05  # Friction velocity
            nu = 1e-5  # Kinematic viscosity

            # Log-law profile
            y_plus = wall_distance * u_tau / nu
            mask = y_plus > 11.6  # Log region
            U[mask, 0] = u_tau * np.log(y_plus[mask]) / 0.41 + 5.0

            # Viscous sublayer
            viscous_mask = ~mask
            U[viscous_mask, 0] = y_plus[viscous_mask] * u_tau

        elif profile_type == 'uniform':
            # Uniform flow
            U[:, 0] = 1.0

        return U

    def calculate_wall_distance(self):
        """Calculate distance to nearest wall for each cell"""

        wall_patches = []
        for patch_name, patch_info in self.boundary_info.items():
            if patch_info['type'] in ['wall', 'noSlip']:
                wall_patches.extend(patch_info['face_centers'])

        if not wall_patches:
            # Default to domain size/10
            domain_size = np.max(self.cell_centers, axis=0) - np.min(self.cell_centers, axis=0)
            return np.ones(len(self.cell_centers)) * np.min(domain_size) / 10

        wall_points = np.array(wall_patches)

        # Calculate minimum distance to wall for each cell
        wall_distances = np.array([
            np.min(np.linalg.norm(self.cell_centers[i] - wall_points, axis=1))
            for i in range(len(self.cell_centers))
        ])

        return wall_distances

    def create_pressure_field(self, reference_point=None, reference_pressure=0):
        """Create pressure field with hydrostatic variation"""

        if reference_point is None:
            reference_point = np.mean(self.cell_centers, axis=0)

        # Hydrostatic pressure variation (for vertical gravity)
        g = 9.81  # Gravity
        rho = 1.2  # Air density

        # Vertical pressure gradient
        z_coords = self.cell_centers[:, 2]
        z_ref = reference_point[2]

        p = reference_pressure + rho * g * (z_ref - z_coords)

        return p

    def create_turbulence_fields(self, intensity=0.05, turbulence_model='kOmegaSST'):
        """Create realistic turbulence field initializations"""

        U = self.create_velocity_profile('boundary_layer')
        U_mag = np.linalg.norm(U, axis=1)

        if turbulence_model == 'kOmegaSST':
            # k-ω SST model initialization
            I = intensity  # Turbulence intensity
            C_mu = 0.09

            k = 1.5 * (I * U_mag) ** 2

            # Turbulent dissipation rate
            l_t = 0.07 * 1.0  # Turbulent length scale (7% of characteristic length)
            epsilon = C_mu ** 0.75 * k ** 1.5 / l_t

            # Specific dissipation rate
            omega = epsilon / (C_mu * k + 1e-10)

            return k, omega

        elif turbulence_model == 'kEpsilon':
            # k-ε model initialization
            I = intensity
            C_mu = 0.09

            k = 1.5 * (I * U_mag) ** 2

            l_t = 0.07 * 1.0
            epsilon = C_mu ** 0.75 * k ** 1.5 / l_t

            return k, epsilon

    def write_field_to_foam(self, field_data, field_name, field_class, dimensions):
        """Write field data to OpenFOAM format"""

        foam_file = f"""/*--------------------------------*- C++ -*----------------------------------*\\
| =========                 |                                                 |
| \\\\      /  F ield         | OpenFOAM: The Open Source CFD Toolbox           |
|  \\\\    /   O peration     | Version:  v2312                                 |
|   \\\\  /    A nd           | Website:  www.openfoam.com                      |
|    \\\\/     M anipulation  |                                                 |
\\*---------------------------------------------------------------------------*/
FoamFile
{{
    version     2.0;
    format      ascii;
    class       {field_class};
    object      {field_name};
}}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      {dimensions};

internalField   uniform 0;

boundaryField
{{
"""

        # Add boundary conditions based on patch types
        for patch_name, patch_info in self.boundary_info.items():
            bc_type = self.determine_boundary_condition(patch_info['type'], field_name)
            foam_file += f"""    {patch_name}
    {{
        type            {bc_type};
    }}
"""

        foam_file += """}\n\n// ************************************************************************* //"""

        with open(f"0/{field_name}", 'w') as f:
            f.write(foam_file)

    def determine_boundary_condition(self, patch_type, field_name):
        """Determine appropriate boundary condition"""

        if field_name == 'U':
            if patch_type in ['wall', 'noSlip']:
                return 'noSlip'
            elif patch_type in ['inlet', 'patch']:
                return 'fixedValue'
            else:
                return 'zeroGradient'
        elif field_name in ['k', 'omega', 'epsilon']:
            if patch_type in ['wall', 'noSlip']:
                return 'kqRWallFunction' if field_name == 'k' else 'omegaWallFunction'
            elif patch_type in ['inlet', 'patch']:
                return 'fixedValue'
            else:
                return 'zeroGradient'
        elif field_name == 'p':
            if patch_type in ['outlet']:
                return 'fixedValue'
            else:
                return 'zeroGradient'
        else:
            return 'zeroGradient'

# Example usage
if __name__ == "__main__":
    initializer = FieldInitializer("constant/polyMesh")

    # Create velocity field
    U = initializer.create_velocity_profile('boundary_layer')

    # Create turbulence fields
    k, omega = initializer.create_turbulence_fields()

    # Write fields to OpenFOAM format
    initializer.write_field_to_foam(U, 'U', 'volVectorField', '[0 1 -1 0 0 0 0]')
    initializer.write_field_to_foam(k, 'k', 'volScalarField', '[0 2 -2 0 0 0 0]')
    initializer.write_field_to_foam(omega, 'omega', 'volScalarField', '[0 0 -1 0 0 0 0]')

    print("Field initialization completed!")
```

ส่วนที่ครอบคลุมเกี่ยวกับ pre-processing utilities นี้ให้ทั้งความเข้าใจทางทฤษฎีและตัวอย่างการปฏิบัติจริงสำหรับ workflow แบบมืออาชีพใน OpenFOAM เนื้อหาครอบคลุมเครื่องมือพื้นฐานเช่น `blockMesh` และ `snappyHexMesh` พร้อมรากฐานทางคณิตศาสตร์โดยละเอียด พร้อมกับเทคนิคการ automaton ขั้นสูงสำหรับการตั้งค่ากรณีและการเริ่มต้นฟิลด์
