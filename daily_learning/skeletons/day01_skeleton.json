    "part_1": {
      "title": "Core Theory - Conservation Laws",
      "ratio": 0.30,
      "readability": "beginner",
      "sections": [
        {
          "title": "Mass Conservation (Continuity Equation)",
          "topics": [
            "Integral form: d/dt ∫_V ρ dV + ∮_S ρ(𝐔·𝐧) dS = S_m ⭐",
            "Differential form: ∂ρ/∂t + ∇·(ρ𝐔) = S_m ⭐",
            "Incompressible case: ∇·𝐔 = 0 ⭐",
            "Phase change modification: ∇·𝐔 = ṁ(1/ρ_v - 1/ρ_l) ⭐ CRITICAL for R410A"
          ]
        },
        {
          "title": "Momentum Conservation (Navier-Stokes)",
          "topics": [
            "Newton's Second Law applied to fluids",
            "Integral form: d/dt ∫_V ρ𝐔 dV + ∮_S ρ𝐔(𝐔·𝐧) dS = ∮_S 𝐓·𝐧 dS + ∫_V 𝐟_b dV ⭐",
            "Differential form: ∂(ρ𝐔)/∂t + ∇·(ρ𝐔𝐔) = ∇·𝐓 + 𝐟_b ⭐",
            "Stress tensor 𝐓 for Newtonian fluids",
            "Complete expansion for incompressible flow: ∂𝐔/∂t + ∇·(𝐔𝐔) = -∇p/ρ + ∇·(ν∇𝐔) + 𝐠"
          ]
        },
        {
          "title": "Energy Conservation",
          "topics": [
            "First Law of Thermodynamics",
            "Integral form: d/dt ∫_V ρh dV + ∮_S ρh(𝐔·𝐧) dS = ∮_S k∇T·𝐧 dS + ∫_V Q̇ dV ⭐",
            "Differential form: ∂(ρh)/∂t + ∇·(ρh𝐔) = ∇·(k∇T) + Q̇ ⭐",
            "Enthalpy form: ∂(ρh)/∂t + ∇·(ρh𝐔) = ∇·(α∇h) + S_h",
            "Boundary condition formulations"
          ]
        },
        {
          "title": "Vector Notation and Tensor Basics",
          "topics": [
            "Bold vector notation: 𝐔, 𝐧, 𝐓 (using \\mathbf{} in LaTeX)",
            "Divergence operator: ∇·𝐔",
            "Gradient operator: ∇p",
            "Laplacian operator: ∇²φ",
            "Tensor operations: ∇·𝐓 (divergence of stress tensor)"
          ]
        }
      ]
    },
