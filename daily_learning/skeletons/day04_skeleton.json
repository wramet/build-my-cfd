  "formulas": {
    "euler_explicit": {
      "formula": "\\frac{\\partial \\phi}{\\partial t} = \\frac{\\phi^{n+1} - \\phi^n}{\\Delta t}",
      "order": "First-order (O(\\Delta t))",
      "verified": true,
      "source": "EulerDdtScheme.C:126"
    },
    "euler_implicit_diagonal": {
      "formula": "a_P = \\frac{1}{\\Delta t} \\cdot V_P",
      "verified": true,
      "source": "EulerDdtScheme.C:307"
    },
    "euler_implicit_source": {
      "formula": "b_P = \\frac{1}{\\Delta t} \\cdot \\phi_P^n \\cdot V_P",
      "verified": true,
      "source": "EulerDdtScheme.C:315"
    },
    "backward_coefficients": {
      "coefft": "coeff_t = 1 + \\frac{\\Delta t}{\\Delta t + \\Delta t_0}",
      "coefft0": "coeff_{t0} = coeff_t + coeff_{t00}",
      "coefft00": "coeff_{t00} = \\frac{\\Delta t \\cdot \\Delta t}{\\Delta t_0 \\cdot (\\Delta t + \\Delta t_0)}",
      "verified": true,
      "source": "backwardDdtScheme.C:151-153"
    },
    "backward_explicit": {
      "formula": "\\frac{\\partial \\phi}{\\partial t} = \\frac{1}{\\Delta t} \\left(coeff_t \\phi - coeff_{t0} \\phi_{old} + coeff_{t00} \\phi_{oldold}\\right)",
      "order": "Second-order (O(\\Delta t^2))",
      "verified": true,
      "source": "backwardDdtScheme.C:190-194"
    },
    "cfl_number": {
      "formula": "C = \\frac{|\\mathbf{U}| \\Delta t}{\\Delta x} \\leq 1",
      "description": "Courant-Friedrichs-Lewy condition for stability",
      "vof_requirement": "VOF typically requires C \\leq 0.3 for accurate interface tracking",
      "verified": true
    },
    "crank_nicolson_coeff": {
      "formula": "cnCoeff = \\frac{1}{1 + ocCoeff}",
      "description": "Crank-Nicolson coefficient for implicit part, ocCoeff in range [0, 1]",
      "verified": true,
      "source": "CrankNicolsonDdtScheme.H:78"
    }
  },
