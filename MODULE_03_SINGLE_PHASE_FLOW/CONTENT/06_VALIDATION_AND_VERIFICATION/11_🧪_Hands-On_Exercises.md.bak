#### ขั้นตอนที่ 6: การเปรียบเทียบข้อมูลการทดลอง
```python
def calculate_error_metrics(cfd_values, exp_values):
    """Calculate comprehensive error metrics"""
    errors = cfd_values - exp_values
    
    # L2 norm (RMS error)
    L2 = np.sqrt(np.mean(errors**2))
    
    # L_infinity norm (maximum absolute error)
    L_inf = np.max(np.abs(errors))
    
    # Coefficient of determination
    ss_res = np.sum(errors**2)
    ss_tot = np.sum((exp_values - np.mean(exp_values))**2)
    R2 = 1 - (ss_res / ss_tot)
    
    # Root Mean Square Error
    RMSE = np.sqrt(np.mean(errors**2))
    
    # Mean Absolute Percentage Error
    MAPE = np.mean(np.abs(errors/exp_values)) * 100
    
    return {
        'L2': L2,
        'L_inf': L_inf, 
        'R2': R2,
        'RMSE': RMSE,
        'MAPE': MAPE
    }

# Example: Compare velocity profiles
x_positions = np.linspace(0, 5*D, 50)  # Downstream positions
U_cfd = []  # Extract from CFD results
U_exp = exp_data['velocity'].values  # From experimental data

# Calculate error metrics
error_metrics = calculate_error_metrics(np.array(U_cfd), U_exp)

print("Validation Error Metrics:")
for metric, value in error_metrics.items():
    print(f"  {metric:8s}: {value:.6f}")

# Validation criteria
print("\nValidation Assessment:")
if error_metrics['R2'] > 0.95:
    print("✓ R² > 0.95: Excellent correlation")
elif error_metrics['R2'] > 0.90:
    print("⚠ 0.90 < R² < 0.95: Good correlation")  
else:
    print("✗ R² < 0.90: Poor correlation")

if error_metrics['MAPE'] < 5.0:
    print("✓ MAPE < 5%: Excellent accuracy")
elif error_metrics['MAPE'] < 10.0:
    print("⚠ 5% < MAPE < 10%: Good accuracy")
else:
    print("✗ MAPE > 10%: Poor accuracy")
```

### ผลลัพธ์ที่คาดหวัง

| พารามิเตอร์ | ค่าอ้างอิง | ค่าที่ยอมรับได้ | การประเมิน |
|--------------|-------------|-----------------|-------------|
| Drag Coefficient ($C_D$) | 1.000 ± 0.05 | ความคลาดเคลื่อน < 10% | ✓ ถูกต้อง |
| Strouhal Number ($St$) | 0.210 ± 0.01 | ความคลาดเคลื่อน < 10% | ✓ ถูกต้อง |
| $R^2$ Correlation | > 0.95 | > 0.90 | ดีเยี่ยม |
| RMSE | < 0.05 | < 0.10 | ยอดเยี่ยม |
| MAPE | < 5% | < 10% | ดีเยี่ยม |

### OpenFOAM Code Implementation: Validation Functions

```cpp
// Example: Custom validation function object for cylinder flow
class cylinderValidation
{
    // Calculate drag coefficient from forces
    scalar calculateDragCoefficient(const vectorField& forces)
    {
        const scalar rho = rhoInf_;
        const scalar U = UInf_;
        const scalar D = cylinderDiameter_;
        const scalar L = 1.0; // 2D assumption
        
        return 2.0*mag(forces[0].x())/(rho*U*U*D*L);
    }
    
    // Calculate Strouhal number from FFT analysis
    scalar calculateStrouhalNumber(const scalarField& liftForce, scalar dt)
    {
        // Perform FFT to find dominant frequency
        List<complex> fftResult = fft(liftForce);
        
        // Find peak frequency (excluding DC component)
        scalar maxAmplitude = 0;
        scalar dominantFreq = 0;
        
        for (int i = 1; i < fftResult.size()/2; i++)
        {
            scalar amplitude = mag(fftResult[i]);
            if (amplitude > maxAmplitude)
            {
                maxAmplitude = amplitude;
                dominantFreq = i/(dt*fftResult.size());
            }
        }
        
        return dominantFreq * cylinderDiameter_ / UInf_;
    }
};
```

