### Step 3: Create Fields File

**File:** `createFields.H`

```cpp
Info<< "Reading transport properties\n" << endl;
IOdictionary transportProperties
(
    IOobject
    (
        "transportProperties",
        runTime.constant(),
        mesh,
        IOobject::MUST_READ_IF_MODIFIED,
        IOobject::NO_WRITE
    )
);

Info<< "Reading field rho\n" << endl;
volScalarField rho
(
    IOobject
    (
        "rho",
        runTime.timeName(),
        mesh,
        IOobject::MUST_READ,
        IOobject::AUTO_WRITE
    ),
    mesh
);

Info<< "Reading field U\n" << endl;
volVectorField U
(
    IOobject
    (
        "U",
        runTime.timeName(),
        mesh,
        IOobject::MUST_READ,
        IOobject::AUTO_WRITE
    ),
    mesh
);

Info<< "Reading/calculating face flux field phi\n" << endl;
surfaceScalarField phi
(
    IOobject
    (
        "phi",
        runTime.timeName(),
        mesh,
        IOobject::READ_IF_PRESENT,
        IOobject::AUTO_WRITE
    ),
    linearInterpolate(rho*U) & mesh.Sf()
);

Info<< "Creating fvModels and fvConstraints\n" << endl;
Foam::fvModels& fvModels = Foam::fvModels::New(mesh);
Foam::fvConstraints& fvConstraints = Foam::fvConstraints::New(mesh);
```

**C++ Concept:** Const references (`const VolField<Type>&`)
- **What happens:** Parameters passed as `const &` prevent modification and avoid copying
- **Why:** Efficient for large objects like fields (no copy overhead)
- **CFD Connection:** Ensures explicit operators (`fvc`) don't modify input fields

