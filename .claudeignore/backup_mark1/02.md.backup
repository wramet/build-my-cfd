### Exercise 5: Analyze fvMesh Structure in OpenFOAM

**Problem:** Write an OpenFOAM application to print geometric information about the mesh.

**Solution:**

```cpp
#include "fvCFD.H"

int main(int argc, char *argv[])
{
    #include "setRootCaseLists.H"
    #include "createTime.H"
    #include "createMesh.H"

    // Print mesh information
    Info << "=== fvMesh Geometric Information ===" << endl;

    // Cell volumes
    const volScalarField::Internal& V = mesh.V();
    Info << "Number of cells: " << mesh.nCells() << endl;
    Info << "Min cell volume: " << min(V).value() << endl;
    Info << "Max cell volume: " << max(V).value() << endl;
    Info << "Total volume: " << sum(V).value() << endl;

    // Face area vectors
    const surfaceVectorField& Sf = mesh.Sf();
    Info << "\nNumber of internal faces: " << mesh.nInternalFaces() << endl;

    // Check geometric conservation for a sample cell
    label sampleCell = mesh.nCells() / 2;
    vector sumSf(Zero, Zero, Zero);

    const cell& cFaces = mesh.cells()[sampleCell];
    forAll(cFaces, fi)
    {
        label facei = cFaces[fi];
        if (mesh.isInternalFace(facei))
        {
            if (mesh.owner()[facei] == sampleCell)
                sumSf += Sf[facei];
            else
                sumSf -= Sf[facei];
        }
        else
        {
            // Boundary faces
            forAll(mesh.boundary(), patchi)
            {
                const labelUList& pFaceCells = mesh.boundary()[patchi].faceCells();
                const vectorField& pSf = Sf.boundaryField()[patchi];

                forAll(p, pfi)
                {
                    if (pFaceCells[pfi] == sampleCell)
                        sumSf += pSf[pfi];
                }
            }
        }
    }

    Info << "\nGeometric conservation check for cell " << sampleCell << ":" << endl;
    Info << "  Sum of Sf: " << sumSf << " (should be ~0)" << endl;

    // Owner-neighbor analysis
    const labelUList& owner = mesh.owner();
    const labelUList& neighbour = mesh.neighbour();

    Info << "\nOwner-neighbor statistics:" << endl;
    Info << "  Min owner index: " << min(owner) << endl;
    Info << "  Max owner index: " << max(owner) << endl;
    Info << "  Min neighbour index: " << min(neighbour) << endl;
    Info << "  Max neighbour index: " << max(neighbour) << endl;

    // Verify: owner < neighbour for all internal faces
    bool allValid = true;
    forAll(owner, facei)
    {
        if (owner[facei] >= neighbour[facei])
        {
            allValid = false;
            WarningIn("main()")
                << "Face " << facei << ": owner (" << owner[facei]
                << ") >= neighbour (" << neighbour[facei] << ")" << endl;
        }
    }

    if (allValid)
    {
        Info << "  ✓ All faces satisfy owner < neighbour" << endl;
    }

    Info << "\nEnd" << endl;

    return 0;
}
```

**Compilation and usage:**
```bash
# Copy to applications/test/meshInfo/
wmake
meshInfo
```

