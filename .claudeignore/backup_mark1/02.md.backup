### A.1 Gauss Gradient Header (`gaussGrad.H`)

```cpp
/*---------------------------------------------------------------------------*\
  =========                 |
  \\      /  F ield         | OpenFOAM: The Open Source CFD Toolbox
   \\    /   O peration     | Website:  https://openfoam.org
    \\  /    A nd           | Copyright (C) 2011-2023 OpenFOAM Foundation
     \\/     M anipulation  |
-------------------------------------------------------------------------------
License
    This file is part of OpenFOAM.

    OpenFOAM is free software: you can redistribute it and/or modify it
    under the terms of the GNU General Public License as published by
    the Free Software Foundation, either version 3 of the License, or
    (at your option) any later version.

    OpenFOAM is distributed in the hope that it will be useful, but WITHOUT
    ANY WARRANTY; without even the implied warranty of MERCHANTABILITY or
    FITNESS FOR A PARTICULAR PURPOSE.  See the GNU General Public License
    for more details.

    You should have received a copy of the GNU General Public License
    along with OpenFOAM.  If not, see <http://www.gnu.org/licenses/>.

Class
    Foam::fv::gaussGrad

Group
    grpFvGradSchemes

Description
    Basic second-order gradient scheme using face-interpolation and Gauss'
    theorem.

    The gradient is calculated as:
    \f[
        \nabla \phi = \frac{1}{V_P} \sum_f \mathbf{S}_f \phi_f
    \f]

SourceFiles
    gaussGrad.C

\*---------------------------------------------------------------------------*/

#ifndef gaussGrad_H
#define gaussGrad_H

#include "gradScheme.H"

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

namespace Foam
{
namespace fv
{

/*---------------------------------------------------------------------------*\
                       Class gaussGrad Declaration
\*---------------------------------------------------------------------------*/

template<class Type>
class gaussGrad
:
    public gradScheme<Type>
{
    // Private Data

        tmp<surfaceInterpolationScheme<Type>> tinterpScheme_;


public:

    //- Runtime type information
    TypeName("Gauss");


    // Constructors

        //- Construct from mesh
        gaussGrad(const fvMesh& mesh)
        :
            gradScheme<Type>(mesh),
            tinterpScheme_(nullptr)
        {}

        //- Construct from mesh and interpolation scheme
        gaussGrad
        (
            const fvMesh& mesh,
            Istream& is
        )
        :
            gradScheme<Type>(mesh),
            tinterpScheme_(surfaceInterpolationScheme<Type>::New(mesh, is))
        {}


    //- Destructor
    virtual ~gaussGrad()
    {}


    // Member Functions

        //- Return the gradient of the given field calculated from the
        //  face-interpolation scheme and Gauss' theorem
        tmp
        <
            VolField<typename outerProduct<vector, Type>::type>
        > grad
        (
            const VolField<Type>& vsf,
            const word& name
        ) const
        {
            return calcGrad(vsf, name);
        }


        //- Return the gradient of the given field calculated from the
        //  face-interpolation scheme and Gauss' theorem
        tmp
        <
            VolField<typename outerProduct<vector, Type>::type>
        > grad
        (
            const tmp<VolField<Type>>& tvsf,
            const word& name
        ) const
        {
            tmp
            <
                VolField<typename outerProduct<vector, Type>::type>
            > tgrad = calcGrad(tvsf(), name);
            tvsf.clear();
            return tgrad;
        }


        //- Return the gradient of the given field calculated from the
        //  face-interpolation scheme and Gauss' theorem
        tmp
        <
            VolField<typename outerProduct<vector, Type>::type>
        > grad
        (
            const VolField<Type>& vsf
        ) const
        {
            return grad(vsf, "grad(" + vsf.name() + ')');
        }


        //- Return the gradient of the given field calculated from the
        //  face-interpolation scheme and Gauss' theorem
        tmp
        <
            VolField<typename outerProduct<vector, Type>::type>
        > grad
        (
            const tmp<VolField<Type>>& tvsf
        ) const
        {
            tmp
            <
                VolField<typename outerProduct<vector, Type>::type>
            > tgrad = grad(tvsf());
            tvsf.clear();
            return tgrad;
        }


    // Member Operators

        //- Disallow default bitwise assignment
        void operator=(const gaussGrad&) = delete;
};


// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

} // End namespace fv

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

} // End namespace Foam

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

#endif

// ************************************************************************* //
```

