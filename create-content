#!/bin/bash
# Simple wrapper for content creation
# Usage: ./create-content 03

DAY=$1

if [ -z "$DAY" ]; then
    echo "Usage: ./create-content <day_number>"
    echo "Example: ./create-content 03"
    exit 1
fi

# Remove leading zeros for display
DAY_NUM=$((10#$DAY))

echo "🚀 Creating content for Day $DAY..."
echo ""

# Run orchestrator
python3 .claude/skills/create-day/orchestrator.py --day="$DAY"

echo ""
echo "✅ Done! Check daily_learning/ for output."
