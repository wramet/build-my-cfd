        +gradientInternalCoeffs() Field~Type~
        +gradientBoundaryCoeffs() Field~Type~
    }
    
    class mixedFvPatchField {
        +updateCoeffs()
        +evaluate()
        +valueInternalCoeffs() Field~Type~
        +valueBoundaryCoeffs() Field~Type~
