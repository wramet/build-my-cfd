        +initMesh()
        +updateMesh(mapPolyMesh)
        +C() volVectorField
        +Cf() surfaceVectorField
        +Sf() surfaceVectorField
        +V() volScalarField
    }

    class MeshGeometryCalculator {
        -const fvMesh& mesh_
        -surfaceVectorField Cf_
        -surfaceVectorField Sf_
