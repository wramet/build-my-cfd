        +const surfaceVectorField& faceAreaVectors() const
        +const volScalarField& cellVolumes() const
    }

    class NonOrthogonalCorrector {
        -const MeshGeometryCalculator& geometry_
        -const word correctionScheme_
        -scalar maxCorrection_
