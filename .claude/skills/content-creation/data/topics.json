        "keywords": ["finiteVolume", "fvMesh", "flux", "discretization"]
      },
      "03": {
        "topic": "Spatial Discretization Schemes",
        "target_path": "openfoam_temp/src/finiteVolume/interpolation/surfaceInterpolation",
        "description": "upwind, linear, vanLeer schemes with divergence/gradient operators",
        "keywords": ["upwind", "linear", "vanLeer", "divergence", "gradient", "interpolation"]
      },
      "04": {
        "topic": "Temporal Discretization",
        "target_path": "openfoam_temp/src/finiteVolume",
        "description": "Euler, Crank-Nicolson, backward schemes",
        "keywords": ["ddtScheme", "Euler", "backward", "time", "integration"]
      },
      "05": {
        "topic": "Pressure-Velocity Coupling",
        "target_path": "openfoam_temp/src/finiteVolume",
        "description": "SIMPLE, PISO, PIMPLE algorithms",
        "keywords": ["SIMPLE", "PISO", "PIMPLE", "pressure", "velocity"]
      },
      "06": {
        "topic": "Boundary Conditions",
        "target_path": "openfoam_temp/src/finiteVolume/fields/fvBoundaryFields",
        "description": "Dirichlet, Neumann, mixed BCs in OpenFOAM",
