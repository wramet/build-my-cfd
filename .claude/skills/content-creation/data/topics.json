      },
      "07": {
        "topic": "Linear Solvers and Preconditioners",
        "target_path": "openfoam_temp/src/OpenFOAM/matrices",
        "description": "GAMG, ICCG, BiCGStab solvers",
        "keywords": ["solver", "GAMG", "ICCG", "preconditioner"]
      },
      "08": {
        "topic": "Turbulence Modeling Fundamentals",
        "target_path": "openfoam_temp/src/turbulenceModels",
        "description": "RANS, k-epsilon, k-omega models",
        "keywords": ["RANS", "kEpsilon", "kOmega", "turbulence"]
      },
      "09": {
        "topic": "Advanced Turbulence Models",
        "target_path": "openfoam_temp/src/turbulenceModels",
        "description": "LES, DES, SAS approaches",
        "keywords": ["LES", "DES", "SAS", "wallFunctions"]
      },
      "10": {
        "topic": "Mesh Generation Fundamentals",
        "target_path": "openfoam_temp/src/meshTools",
        "description": "blockMesh, snappyHexMesh basics",
        "keywords": ["blockMesh", "snappyHexMesh", "mesh"]
      },
      "11": {
        "topic": "Parallel Processing with HPC",
        "target_path": "openfoam_temp/src/OpenFOAM/mpi",
        "description": "Domain decomposition, MPI communication",
        "keywords": ["decomposePar", "mpi", "parallel", "scotch"]
      },
      "12": {
        "topic": "Verification and Validation",
        "target_path": "openfoam_temp/src",
        "description": "Mesh independence, experimental validation",
        "keywords": ["verification", "validation", "uncertainty"]
      }
    }
  },
