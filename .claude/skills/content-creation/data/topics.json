{
  "Phase_01_Foundation_Theory": {
    "phase": "Phase 01: Foundation Theory",
    "days": {
      "01": {
        "topic": "Governing Equations of Fluid Flow",
        "target_path": "openfoam_temp/src/finiteVolume",
        "description": "Continuity, momentum, energy equations with OpenFOAM implementation",
        "keywords": ["navier-stokes", "continuity", "momentum", "transport"]
      },
      "02": {
        "topic": "Finite Volume Method Basics",
        "target_path": "openfoam_temp/src/finiteVolume",
