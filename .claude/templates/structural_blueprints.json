        "natural_only": {
          "description": "Only include C++/DSA topics that naturally appear in OpenFOAM",
          "include": [
            "Templates (tmp<>, Field<Type>, fvMatrix<Type>)",
            "Smart pointers (tmp<>, autoPtr, refPtr)",
            "Containers (List, HashTable, Map, Dictionary)",
            "Sparse matrices (LduMatrix, lduAddressing)",
            "Graph structures (mesh connectivity)",
            "Trees (octree for spatial search)",
            "Sorting (stableSort)",
            "Iterators (forAll, iterator patterns)",
