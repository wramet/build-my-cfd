  "equation_modifications": {
    "continuity": {
      "standard": "\\frac{\\partial \\rho}{\\partial t} + \\nabla \\cdot (\\rho \\mathbf{U}) = 0",
      "r410a": "\\frac{\\partial \\rho}{\\partial t} + \\nabla \\cdot (\\rho \\mathbf{U}) = \\dot{m}",
      "added_term": "\\dot{m} (mass transfer rate)",
      "significance": "Accounts for evaporation/condensation"
    },
    "momentum": {
      "standard": "\\frac{\\partial (\\rho \\mathbf{U})}{\\partial t} + \\nabla \\cdot (\\rho \\mathbf{U} \\otimes \\mathbf{U}) = -\\nabla p + \\nabla \\cdot \\boldsymbol{\\tau}",
      "r410a": "\\frac{\\partial (\\rho \\mathbf{U})}{\\partial t} + \\cdots = \\cdots + \\mathbf{F}_\\sigma + \\dot{m}\\mathbf{U}_i",
      "added_terms": [
        "\\mathbf{F}_\\sigma = \\sigma \\kappa \\nabla \\alpha (surface tension)",
        "\\dot{m}\\mathbf{U}_i (momentum transfer)"
      ],
      "significance": "Surface tension dominates at small scales"
    },
    "energy": {
      "standard": "\\frac{\\partial (\\rho h)}{\\partial t} + \\nabla \\cdot (\\rho \\mathbf{U} h) = \\nabla \\cdot (k \\nabla T)",
      "r410a": "\\frac{\\partial (\\rho h)}{\\partial t} + \\nabla \\cdot (\\rho \\mathbf{U} h) = \\nabla \\cdot (k \\nabla T) + \\dot{m} h_{lv}",
      "added_term": "\\dot{m} h_{lv} (latent heat)",
      "significance": "Dominant term in energy balance"
    },
    "vof": {
      "standard": "\\frac{\\partial \\alpha}{\\partial t} + \\nabla \\cdot (\\alpha \\mathbf{U}) = 0",
      "r410a": "\\frac{\\partial \\alpha}{\\partial t} + \\nabla \\cdot (\\alpha \\mathbf{U}) + \\nabla \\cdot [\\alpha(1-\\alpha)\\mathbf{U}_r] = \\dot{m}(\\frac{1}{\\rho_l} - \\frac{1}{\\rho_v})",
      "added_terms": [
        "\\nabla \\cdot [\\alpha(1-\\alpha)\\mathbf{U}_r] (interface compression)",
        "\\dot{m}(\\frac{1}{\\rho_l} - \\frac{1}{\\rho_v}) (phase change source)"
      ],
      "significance": "Sharp interface tracking with phase change"
    }
  },
