  "structure": {
    "parts": [
      {
        "id": "p1",
        "title": "Foundation Theory",
        "ratio": 0.25,
        "readability": "beginner",
        "approach": "derivations",
        "content_type": "theory",
        "guideline": "Standard governing equations (continuity, momentum, energy)",
        "topics": [
          "Control volume analysis",
          "Reynolds Transport Theorem",
          "Continuity equation",
          "Navier-Stokes equations",
          "Energy equation (enthalpy form)"
        ],
        "estimated_lines": 500
      },
      {
        "id": "p2",
        "title": "R410A Properties & Physics",
        "ratio": 0.20,
        "readability": "intermediate",
        "approach": "data-driven",
        "content_type": "application",
        "guideline": "Concrete property data with physical interpretation",
        "mandatory_content": [
          "Property table (ρ, μ, k, c_p, σ, h_lv)",
          "Density ratio significance",
          "Phase change physics",
          "Surface tension effects",
          "Temperature/pressure ranges"
        ],
        "estimated_lines": 400
      },
      {
        "id": "p3",
        "title": "Equation Modifications for R410A",
        "ratio": 0.25,
        "readability": "advanced",
        "approach": "comparison",
        "content_type": "analysis",
        "guideline": "Side-by-side comparison: standard vs. R410A equations",
        "mandatory_comparisons": [
          "Continuity: add mass source ṁ",
          "Momentum: add F_σ + ṁU_i",
          "Energy: add ṁh_lv",
          "VOF: add interface compression"
        ],
        "estimated_lines": 500
      },
      {
        "id": "p4",
        "title": "OpenFOAM Implementation",
        "ratio": 0.30,
        "readability": "professional",
        "approach": "code-first",
        "content_type": "code",
        "guideline": "Complete R410A solver with phase change",
        "mandatory_implementations": [
          "Lee model for mass transfer",
          "CSF model for surface tension",
          "MULES for VOF transport",
          "Energy equation with latent heat",
          "Complete solver structure"
        ],
        "estimated_lines": 600
      }
    ]
  },
