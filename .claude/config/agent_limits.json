{
  "max_file_lines": 1000,
  "max_context_tokens": 100000,
  "chunk_size": 500,
  "skip_large_files": true,
  "prefer_smart_reader": true,
  "tokens_per_line_estimate": 15,
  "max_parallel_agents": 3,
  "context_cleanup_interval": 5,
  "agent_timeouts": {
    "explore": 120,
    "research": 180,
    "walkthrough": 300
  },
  "file_type_limits": {
    ".md": {
      "max_lines": 1000,
      "use_smart_reader": true
    },
    ".cpp": {
      "max_lines": 500,
      "use_smart_reader": true
    },
    ".H": {
      "max_lines": 500,
      "use_smart_reader": true
    },
    ".py": {
      "max_lines": 500,
      "use_smart_reader": true
    }
  }
}
