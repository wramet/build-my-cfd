# **หัวข้อ 2: polyMesh - "ฐานข้อมูลโทโพโลยีรูปหลายหน้า"**

คลาส `polyMesh` แสดงถึงแนวทางขั้นสูงของ OpenFOAM ในการจัดการโทโพโลยี mesh รูปหลายหน้า แตกต่างจากรูปแบบ mesh แบบดั้งเดิมที่จำกัดอยู่กับประเภทเซลล์เฉพาะ (hexahedra, tetrahedra, ฯลฯ) polyMesh ให้เฟรมเวิร์กที่เป็นเอกภาพสำหรับ mesh รูปหลายหน้าโดยพลการ

## **สถาปัตยกรรมหลัก: การเชื่อมต่อที่ขึ้นอยู่กับผิว**

```cpp
class polyMesh
{
private:
    // การจัดเก็บโทโพโลยีดั้งเดิม (ไม่เปลี่ยนแปลงหลังการสร้าง mesh)
    const pointField& points_;           // พิกัด 3D ของจุด mesh ทั้งหมด
    const faceList& faces_;              // รายการดัชนีจุดที่กำหนดแต่ละผิว
    const cellList& cells_;              // รายการดัชนีผิวที่กำหนดแต่ละเซลล์
    const labelList& owner_;             // ดัชนีเซลล์เจ้าของสำหรับแต่ละผิว
    const labelList& neighbour_;         // ดัชนีเซลล์ข้างเคียงสำหรับแต่ละผิว (ผิวขอบเขต = -1)
    
    // การเชื่อมต่อที่ได้จากการคำนวณ (คำนวณเมื่อจำเป็น)
    mutable autoPtr<labelListList> cellPoints_;   // จุดที่เป็นของแต่ละเซลล์
    mutable autoPtr<labelListList> pointCells_;   // เซลล์ที่มีแต่ละจุด
    mutable autoPtr<labelListList> cellEdges_;    // ขอบของแต่ละเซลล์
    mutable autoPtr<labelListList> edgeCells_;    // เซลล์ที่ใช้ร่วมกันแต่ละขอบ

public:
    // วิธีการเข้าถึงโดยตรง
    const pointField& points() const { return points_; }
    const faceList& faces() const { return faces_; }
    const cellList& cells() const { return cells_; }
    
    // การเชื่อมต่อที่คำนวณได้กับ lazy evaluation
    const labelListList& cellPoints() const
    {
        if (!cellPoints_.valid())
        {
            cellPoints_.reset(new labelListList(cells_.size()));
            forAll(cells_, cellI)
            {
                // สร้างรายการจุดสำหรับเซลล์นี้โดยเดินผ่านผิวของมัน
                DynamicList<label> cellPointList;
                const labelList& cellFaces = cells_[cellI];
                
                forAll(cellFaces, faceI)
                {
                    const face& f = faces_[cellFaces[faceI]];
                    forAll(f, pointI)
                    {
                        // เพิ่มจุดที่ไม่ซ้ำกันไปยังรายการจุดเซลล์
                        if (findIndex(cellPointList, f[pointI]) == -1)
                        {
                            cellPointList.append(f[pointI]);
                        }
                    }
                }
                cellPoints_()[cellI].transfer(cellPointList);
            }
        }
        return cellPoints_();
    }
};
```

[Diagram: โครงสร้างข้อมูลโทโพโลยีใน polyMesh แสดงการเชื่อมต่อระหว่าง points, faces, และ cells]

## **กลยุทธ์การจัดการขอบเขต**

```cpp
class polyMesh
{
private:
    // การกำหนดขอบเขต
    const polyBoundaryMesh& boundary_;   // คอลเลกชันของ patch ขอบเขต
    
    // การจำแนกการเชื่อมต่อผิว
    const labelListList& faceNeighbour_; // เซลล์ข้างเคียงสำหรับผิวภายใน
    const labelList& faceOwner_;         // เซลล์เจ้าของสำหรับผิวทั้งหมด
    
public:
    // อินเทอร์เฟซขอบเขต
    const polyBoundaryMesh& boundary() const { return boundary_; }
    
    // วิธีการจำแนกผิว
    bool isInternalFace(label faceI) const
    {
        return faceNeighbour_[faceI] != -1;
    }
    
    bool isBoundaryFace(label faceI) const
    {
        return faceNeighbour_[faceI] == -1;
    }
    
    // การเข้าถึง patch ขอบเขต
    const polyPatch& boundaryPatch(label faceI) const
    {
        if (isBoundaryFace(faceI))
        {
            label patchID = whichPatch(faceI);
            return boundary_[patchID];
        }
        FatalErrorIn("polyMesh::boundaryPatch(label)")
            << "Face " << faceI << " is not a boundary face"
            << abort(FatalError);
    }
    
    // การค้นหาการเชื่อมต่อขั้นสูง
    void findCellsAroundPoint(const point& p, List<label>& cellIndices) const
    {
        cellIndices.clear();
        
        // ค้นหาเซลล์ mesh ที่บรรจุโดยใช้การค้นหาเชิงพื้นที่
        label containingCell = findCell(p);
        if (containingCell != -1)
        {
            cellIndices.append(containingCell);
            
            // ค้นหาเซลล์ข้างเคียงที่อาจมีจุดนี้ด้วย
            const labelList& cellFaces = cells()[containingCell];
            forAll(cellFaces, faceI)
            {
                label neighborCell = faceNeighbour_[cellFaces[faceI]];
                if (neighborCell != -1 && pointInCell(p, neighborCell))
                {
                    cellIndices.append(neighborCell);
                }
            }
        }
    }
};
```

[Diagram: การจัดการขอบเขตใน polyMesh แสดงความสัมพันธ์ระหว่าง internal faces และ boundary patches]

## **การดำเนินการโทโพโลยีขั้นสูง**

```cpp
class polyMesh
{
public:
    // การค้นหาโทโพโลยีที่ซับซ้อนซึ่งจำเป็นสำหรับอัลกอริทึม CFD
    void getCellBoundingPoints(label cellI, List<point>& cellBoundingPoints) const
    {
        // รับจุดที่ไม่ซ้ำกันทั้งหมดที่กำหนดขอบเขตเซลล์
        const labelList& cellPoints = this->cellPoints();
        const labelList& pointList = cellPoints[cellI];
        
        cellBoundingPoints.setSize(pointList.size());
        forAll(pointList, pointI)
        {
            cellBoundingPoints[pointI] = points_[pointList[pointI]];
        }
        
        // จัดเรียงจุดตามต้องการเพื่อการจัดลำดับที่สม่ำเสมอ
        sortPoints(cellBoundingPoints);
    }
    
    void getFaceNormal(label faceI, vector& normal, scalar& area) const
    {
        const face& f = faces_[faceI];
        
        if (f.size() < 3)
        {
            normal = vector::zero;
            area = 0.0;
            return;
        }
        
        // คำนวณ normal ของผิวโดยใช้วิธี cross product
        normal = vector::zero;
        const point& p0 = points_[f[0]];
        
        for (label i = 1; i < f.size() - 1; i++)
        {
            const point& p1 = points_[f[i]];
            const point& p2 = points_[f[i + 1]];
            
            vector edge1 = p1 - p0;
            vector edge2 = p2 - p0;
            normal += edge1 ^ edge2;  // Cross product
        }
        
        area = mag(normal);
        if (area > SMALL)
        {
            normal /= area;  // Normalize
        }
        else
        {
            normal = vector::zero;
        }
        
        // รับรองว่า normal ชี้จากเจ้าของไปยังข้างเคียง
        if (!isInternalFace(faceI) || dot(normal, points_[f[0]] - cellCentres()[faceOwner_[faceI]]) < 0)
        {
            normal = -normal;
        }
    }
    
    // วิธีการประเมินคุณภาพ mesh
    void calculateMeshQuality(scalar& maxNonOrthogonality, 
                             scalar& maxSkewness,
                             scalar& maxAspectRatio) const
    {
        maxNonOrthogonality = 0.0;
        maxSkewness = 0.0;
        maxAspectRatio = 0.0;
        
        // ตรวจสอบผิวภายในทั้งหมดสำหรับ non-orthogonality
        forAll(faceNeighbour_, faceI)
        {
            if (isInternalFace(faceI))
            {
                scalar nonOrth = calculateNonOrthogonality(faceI);
                maxNonOrthogonality = max(maxNonOrthogonality, nonOrth);
            }
        }
        
        // ตรวจสอบเซลล์ทั้งหมดสำหรับ skewness และ aspect ratio
        forAll(cells_, cellI)
        {
            scalar skew = calculateSkewness(cellI);
            scalar aspect = calculateAspectRatio(cellI);
            
            maxSkewness = max(maxSkewness, skew);
            maxAspectRatio = max(maxAspectRatio, aspect);
        }
    }
    
private:
    scalar calculateNonOrthogonality(label faceI) const
    {
        vector faceNormal;
        scalar faceArea;
        getFaceNormal(faceI, faceNormal, faceArea);
        
        vector d = cellCentres()[faceNeighbour_[faceI]] - 
                   cellCentres()[faceOwner_[faceI]];
        
        return acos(mag(dot(d, faceNormal))/(mag(d)*mag(faceArea))) * 180.0/M_PI;
    }
    
    scalar calculateSkewness(label cellI) const
    {
        // ใช้การคำนวณ skewness โดยยึดตามการแทรกสอดผิวต่อผิว
        const labelList& cellFaces = cells_[cellI];
        scalar totalSkewness = 0.0;
        
        forAll(cellFaces, faceI)
        {
            label faceID = cellFaces[faceI];
            if (isInternalFace(faceID))
            {
                // คำนวณระยะห่างระหว่างจุดศูนย์กลางผิวและเส้น
                // เชื่อมต่อจุดศูนย์กลางเซลล์
                point faceCentre = faceCentres()[faceID];
                vector d = cellCentres()[faceNeighbour_[faceID]] - 
                          cellCentres()[faceOwner_[faceID]];
                
                point dCentre = cellCentres()[faceOwner_[faceID]] + 
                               0.5 * d;
                
                scalar distance = mag(faceCentre - dCentre);
                scalar dMag = mag(d);
                
                if (dMag > SMALL)
                {
                    totalSkewness += distance/dMag;
                }
            }
        }
        
        return totalSkewness / cellFaces.size();
    }
};
```

### **การวัดคุณภาพ Mesh**

| เมตริก | คำนวณโดย | ค่าที่ยอมรับได้ | ผลกระทบ |
|---------|-----------|----------------|----------|
| **Non-orthogonality** | `calculateNonOrthogonality()` | < 70° | ความแม่นยำของการกระจาย |
| **Skewness** | `calculateSkewness()` | < 0.5 | เสถียรภาพการคำนวณ |
| **Aspect Ratio** | `calculateAspectRatio()` | < 1000 | ความเร็วในการลู่เข้า |
| **Expansion Ratio** | `expansionRatio()` | < 20 | ความเรียบร้อยของเซลล์ |

[Diagram: การแสดงเมตริกคุณภาพ mesh แบบ visual - non-orthogonality, skewness, และ aspect ratio]

**การออกแบบที่มุ่งเน้นโทโพโลยีนี้ช่วยให้ polyMesh สามารถจัดการเรขาคณิตรูปหลายหน้าโดยพลการในขณะที่ให้การเข้าถึงข้อมูลการเชื่อมต่อที่มีประสิทธิภาพซึ่งจำเป็นสำหรับการคำนวณ CFD Lazy evaluation ของการเชื่อมต่อที่ได้จากการคำนวณรับประกันประสิทธิภาพหน่วยความจำในขณะที่รักษาความยืดหยุ่นที่จำเป็นสำหรับวิธีการเชิงตัวเลขขั้นสูง**
