# 🔧 แบบฝึกปฏิบัติ: การดำเนินการฟิลด์ขั้นสูงใน OpenFOAM

## แบบฝึกปฏิบัติที่ 1: การดำเนินการพื้นฐานของฟิลด์

### วัตถุประสงค์
เรียนรู้การดำเนินการพื้นฐานของฟิลด์และเข้าใจพื้นฐานคณิตศาสตร์ของการดำเนินการฟิลด์ใน OpenFOAM

### พื้นฐานทฤษฎี

ฟิลด์ใน OpenFOAM ใช้แนวคิดทางคณิตศาสตร์ของการดำเนินการฟิลด์ซึ่งดำเนินการแบบ element-wise ทั่วทั้งโดเมนการคำนวณ สำหรับฟิลด์สเกลาร์สองฟิลด์ $p_1(\mathbf{x})$ และ $p_2(\mathbf{x})$ การดำเนินการทางคณิตศาสตร์พื้นฐานถูกกำหนดดังนี้:

$$ (p_1 + p_2)(\mathbf{x}) = p_1(\mathbf{x}) + p_2(\mathbf{x}) $$
$$ (p_1 - p_2)(\mathbf{x}) = p_1(\mathbf{x}) - p_2(\mathbf{x}) $$
$$ \left(\frac{p_1 + p_2}{2}\right)(\mathbf{x}) = \frac{p_1(\mathbf{x}) + p_2(\mathbf{x})}{2} $$

### การนำไปใช้งาน

```cpp
// สร้างฟิลด์สเกลาร์สองฟิลด์ด้วยการกระจายเริ่มต้นที่แตกต่างกัน
volScalarField p1
(
    IOobject
    (
        "p1",
        runTime.timeName(),
        mesh,
        IOobject::NO_READ,
        IOobject::AUTO_WRITE
    ),
    mesh,
    dimensionedScalar("p1", dimPressure, 101325.0) // Pa
);

volScalarField p2
(
    IOobject
    (
        "p2",
        runTime.timeName(),
        mesh,
        IOobject::NO_READ,
        IOobject::AUTO_WRITE
    ),
    mesh,
    dimensionedScalar("p2", dimPressure, 95000.0) // Pa
);

// ตั้งค่าการกระจายเริ่มต้นที่แตกต่างกัน (ตัวอย่าง: การเปลี่ยนแปลงแบบ sinusoidal)
forAll(p1, i)
{
    const vector& C = mesh.C()[i];
    p1[i] = 101325.0 + 1000.0 * sin(C.x() * 2.0 * M_PI / 0.1);
    p2[i] = 95000.0 + 500.0 * cos(C.y() * 2.0 * M_PI / 0.1);
}

// คำนวณการดำเนินการฟิลด์โดยใช้ operator overloading
volScalarField p_sum = p1 + p2;
volScalarField p_diff = p1 - p2;
volScalarField p_avg = (p1 + p2) / 2.0;

// เพิ่มค่าชดเชยความดันคงที่
volScalarField p_offset = p1 + dimensionedScalar("offset", dimPressure, 1000.0);

// เขียนผลลัพธ์เพื่อการ visualisation
p_sum.write();
p_diff.write();
p_avg.write();
p_offset.write();
```

### การตรวจสอบความสอดคล้องของมิติ

ระบบประเภทของ OpenFOAM ป้องกันการดำเนินการที่ผิดกฎหมายในเวลาคอมไพล์:

```cpp
// นี่จะทำให้เกิดคอมไพล์ error:
volScalarField p_wrong = p1 + dimensionedScalar("velocity", dimVelocity, 1.0);
// Error: ไม่สามารถบวกความดัน (M L^-1 T^-2) และความเร็ว (L T^-1) ได้

// แนวทางที่ถูกต้อง: ตรวจสอบให้แน่ใจว่ามีความสอดคล้องของมิติ
dimensionedScalar pressureOffset("offset", dimPressure, 1000.0);
volScalarField p_correct = p1 + pressureOffset;
```

### เคล็ดลับการ Visualisation

ใช้ `paraFoam` สำหรับการ visualisation:
1. โหลด case ใน paraFoam
2. ใช้ filters เพื่อ visualise การกระจายฟิลด์
3. ใช้ contour plots สำหรับฟิลด์ความดัน
4. สร้าง vector plots สำหรับฟิลด์ gradient

## แบบฝึกปฏิบัติที่ 2: การสำรวจ Operator Overloading

### วัตถุประสงค์
เข้าใจว่า OpenFOAM ใช้การดำเนินการฟิลด์อย่างมีประสิทธิภาพผ่าน expression templates และ operator overloading อย่างไร

### การวิเคราะห์ Macro

มาโคร `PRODUCT_OPERATOR` ใน `FieldFunctions.H` สร้างการดำเนินการแบบ binary:

```cpp
// ตัวอย่างการขยาย macro สำหรับการคูณ:
#define PRODUCT_OPERATOR(Type, op) \
template<class Type1, class Type2> \
inline tmp<##Field<typename product<Type1, Type2>::type>> \
operator op(const UList<Type1>& f1, const UList<Type2>& f2) \
{ \
    typedef typename product<Type1, Type2>::type productType; \
    tmp<Field<productType>> tRes(new Field<productType>(f1.size())); \
    Field<productType>& res = tRes.ref(); \
    forAll(f1, i) { res[i] = f1[i] op f2[i]; } \
    return tRes; \
}

PRODUCT_OPERATOR(Type, *)  // สร้าง multiplication operator
```

### การนำ Operator ที่กำหนดเองไปใช้งาน

สร้างการดำเนินการฟิสิกส์เฉพาะทาง:

```cpp
// การดำเนินการฟิลด์แบบกำหนดเองสำหรับ turbulence production
template<class Type>
class turbulenceProductionOp
{
public:
    typedef typename outerProduct<Type, Type>::type result_type;
    
    template<class Field1, class Field2>
    static inline result_type apply(const Field1& gradU, const Field2& S)
    {
        // คำนวณ turbulence production: P = 2*nu_t*S_ij*S_ij
        return 2.0 * gradU * S;
    }
};

// การใช้งานใน solver:
volTensorField gradU = fvc::grad(U);
volSymmTensorField S = symm(gradU);  // ค่าความเครียด rate tensor
volScalarField P_k = turbulenceProductionOp<volTensorField>::apply(gradU, S);
```

### การทดสอบการตรวจสอบมิติ

```cpp
// ทดสอบความสอดคล้องของมิติ
void testDimensionalChecking()
{
    // สร้างฟิลด์ที่มีมิติที่ไม่เข้ากัน
    volScalarField pressure("p", mesh, dimensionedScalar("p", dimPressure, 101325.0));
    volScalarField velocity("U_mag", mesh, dimensionedScalar("U", dimVelocity, 1.0));
    
    // นี่ควรคอมไพล์พร้อม error:
    // volScalarField wrong = pressure + velocity;  // Compile-time error
    
    // การรวมมิติที่ถูกต้อง:
    dimensionedScalar timeScale("dt", dimTime, 1.0);
    volScalarField dpdt = pressure / timeScale;  // Pa/s = kg m^-1 s^-3
}
```

### การวัดประสิทธิภาพ

```cpp
// เปรียบเทียบประสิทธิภาพระหว่าง loops และ operators
void benchmarkOperations(const volScalarField& field1, const volScalarField& field2)
{
    const int nIter = 1000;
    const label nCells = field1.size();
    
    // วิธีที่ 1: Manual loop
    auto start1 = std::chrono::high_resolution_clock::now();
    for (int i = 0; i < nIter; i++)
    {
        volScalarField result("result_manual", field1.mesh(), dimensionedScalar("zero", field1.dimensions(), 0.0));
        forAll(result, cellI)
        {
            result[cellI] = field1[cellI] + field2[cellI];
        }
    }
    auto end1 = std::chrono::high_resolution_clock::now();
    
    // วิธีที่ 2: Operator overloading พร้อม expression templates
    auto start2 = std::chrono::high_resolution_clock::now();
    for (int i = 0; i < nIter; i++)
    {
        volScalarField result = field1 + field2;
    }
    auto end2 = std::chrono::high_resolution_clock::now();
    
    // คำนวณและรายงาน performance metrics
    auto time1 = std::chrono::duration_cast<std::chrono::microseconds>(end1 - start1);
    auto time2 = std::chrono::duration_cast<std::chrono::microseconds>(end2 - start2);
    
    Info << "Manual loop time: " << time1.count() << " μs" << endl;
    Info << "Operator time: " << time2.count() << " μs" << endl;
    Info << "Speedup: " << static_cast<double>(time1.count()) / time2.count() << "x" << endl;
}
```

## แบบฝึกปฏิบัติที่ 3: การวิเคราะห์มิติ

### วัตถุประสงค์
เรียนรู้ระบบการวิเคราะห์มิติของ OpenFOAM และนำการตรวจสอบมิติแบบกำหนดเองไปใช้งาน

### ชุดมิติแบบกำหนดเอง

```cpp
// กำหนดปริมาณทางฟิสิกส์แบบกำหนดเอง: enthalpy flux
// มิติ: [M L^2 T^-3] (พลังงานต่อหน่วยเวลา)
dimensionSet enthalpyFluxDimensions(1, 2, -3, 0, 0, 0, 0);

// คลาสคุณสมบัติทางอุณหพลศาสตร์แบบกำหนดเอง
class enthalpyFlux
{
    dimensionedScalar h_;
    
public:
    enthalpyFlux(const word& name, const scalar value)
        : h_(name, enthalpyFluxDimensions, value)
    {}
    
    // เปิดใช้งาน arithmetic ของมิติ
    const dimensionedScalar& operator()() const { return h_; }
    
    // การบวกกับมิติเดียวกัน
    enthalpyFlux operator+(const enthalpyFlux& other) const
    {
        return enthalpyFlux(h_.name() + "_sum", h_.value() + other.h_.value());
    }
    
    // การคูณกับ scalar
    enthalpyFlux operator*(const dimensionedScalar& factor) const
    {
        return enthalpyFlux(h_.name() + "_scaled", 
                          h_.value() * factor.value());
    }
};
```

### การนำการตรวจสอบมิติไปใช้งาน

```cpp
// สมการแบบกำหนดเอง: Nusselt number correlation
// Nu = h*L/k (ไร้มิติ)
dimensionSet lengthDimensions(0, 1, 0, 0, 0, 0, 0);
dimensionSet thermalCondDimensions(1, 1, -3, -1, 0, 0, 0);  // W/(m·K)

bool checkNusseltCorrelation()
{
    dimensionedScalar h("h", enthalpyFluxDimensions, 1000.0);  // W/m²
    dimensionedScalar L("L", lengthDimensions, 0.1);           // m
    dimensionedScalar k("k", thermalCondDimensions, 50.0);     // W/(m·K)
    
    // คำนวณมิติ
    dimensionSet numerator = h.dimensions() * L.dimensions();
    dimensionSet denominator = k.dimensions();
    dimensionSet result = numerator / denominator;
    
    // ตรวจสอบว่าผลลัพธ์ไร้มิติหรือไม่
    return result == dimensionSet(0, 0, 0, 0, 0, 0, 0);
}
```

### การ Debug ความไม่สอดคล้องของมิติ

```cpp
// Debug function สำหรับการวิเคราะห์มิติ
void debugDimensionalEquation()
{
    // ตัวอย่าง: สมการการอนุรักษ์พลังงาน
    // ρ*cp*∂T/∂t = k*∇²T + Q
    
    dimensionSet rho_cp_T = dimDensity * dimSpecificHeatCapacity * dimTemperature;
    dimensionSet time_derivative = rho_cp_T / dimTime;          // kg/(m³·s³)
    
    dimensionSet k_grad2_T = dimThermalConductivity * dimTemperature / pow(dimLength, 2);
    dimensionSet Q = dimPower / dimVolume;                       // kg/(m·s³)
    
    Info << "Energy equation consistency:" << endl;
    Info << "  LHS dimensions: " << time_derivative << endl;
    Info << "  RHS k∇²T: " << k_grad2_T << endl;
    Info << "  RHS Q: " << Q << endl;
    
    if (time_derivative == k_grad2_T && time_derivative == Q)
    {
        Info << "  ✓ มีความสอดคล้องทางมิติ" << endl;
    }
    else
    {
        Info << "  ✗ ตรวจพบความไม่สอดคล้องทางมิติ!" << endl;
    }
}
```

### เครื่องมือแปลงหน่วย

```cpp
class unitConverter
{
    static constexpr double Pa_to_psi = 0.000145038;
    static constexpr double K_to_R = 1.8;
    static constexpr double m_to_ft = 3.28084;
    
public:
    // การแปลงความดัน
    static dimensionedScalar convertPressure(const dimensionedScalar& pressure, 
                                           const word& targetUnit)
    {
        if (targetUnit == "psi")
        {
            return dimensionedScalar(pressure.name() + "_psi", 
                                   dimPressure, 
                                   pressure.value() * Pa_to_psi);
        }
        return pressure; // ส่งคืนค่าเดิมหากไม่ต้องการแปลง
    }
    
    // การแปลงอุณหภูมิ
    static dimensionedScalar convertTemperature(const dimensionedScalar& temp, 
                                              const word& targetUnit)
    {
        if (targetUnit == "R")
        {
            return dimensionedScalar(temp.name() + "_R", 
                                   dimTemperature, 
                                   temp.value() * K_to_R);
        }
        return temp;
    }
    
    // การแปลงความยาว
    static dimensionedScalar convertLength(const dimensionedScalar& length, 
                                         const word& targetUnit)
    {
        if (targetUnit == "ft")
        {
            return dimensionedScalar(length.name() + "_ft", 
                                   dimLength, 
                                   length.value() * m_to_ft);
        }
        return length;
    }
};
```

## แบบฝึกปฏิบัติที่ 4: การเพิ่มประสิทธิภาพ Expression Template

### วัตถุประสงค์
เข้าใจและนำรูปแบบ expression template ไปใช้สำหรับการดำเนินการฟิลด์ที่เพิ่มประสิทธิภาพ

### การ Profiling นิพจน์ฟิลด์

```cpp
#include "profiling.H"

// ทดสอบประสิทธิภาพของนิพจน์ที่ซับซ้อน
void profileFieldExpressions(const volScalarField& T, const volScalarField& p, 
                           const volVectorField& U)
{
    // นิพจน์ 1: แนวทางแบบ naive พร้อมฟิลด์ชั่วคราว
    auto start1 = std::chrono::high_resolution_clock::now();
    for (int i = 0; i < 100; i++)
    {
        volScalarField temp1 = T + p;  // สร้างค่าชั่วคราว
        volScalarField temp2 = temp1 * mag(U);  // ค่าชั่วคราวอีก
        volScalarField result = temp2 / 2.0;  // ผลลัพธ์สุดท้าย
    }
    auto end1 = std::chrono::high_resolution_clock::now();
    
    // นิพจน์ 2: แนวทางแบบ expression template
    auto start2 = std::chrono::high_resolution_clock::now();
    for (int i = 0; i < 100; i++)
    {
        volScalarField result = (T + p) * mag(U) / 2.0;  // การประเมินครั้งเดียว
    }
    auto end2 = std::chrono::high_resolution_clock::now();
    
    // รายงานผลลัพธ์
    auto time1 = std::chrono::duration_cast<std::chrono::milliseconds>(end1 - start1);
    auto time2 = std::chrono::duration_cast<std::chrono::milliseconds>(end2 - start2);
    
    Info << "Naive approach: " << time1.count() << " ms" << nl
         << "Expression template: " << time2.count() << " ms" << nl
         << "Speedup: " << static_cast<double>(time1.count()) / time2.count() << "x" << endl;
}
```

### ระบบ Expression Template แบบกำหนดเอง

```cpp
// การนำ expression template ไปใช้งานแบบง่าย
template<class LHS, class RHS, class Op>
class BinaryExpression
{
    const LHS& lhs_;
    const RHS& rhs_;
    
public:
    using value_type = typename Op::result_type;
    
    BinaryExpression(const LHS& lhs, const RHS& rhs) 
        : lhs_(lhs), rhs_(rhs) {}
    
    value_type operator[](const label i) const
    {
        return Op::apply(lhs_[i], rhs_[i]);
    }
    
    label size() const { return lhs_.size(); }
};

// การดำเนินการบวก
struct AddOp
{
    template<class T1, class T2>
    static auto apply(const T1& a, const T2& b) -> decltype(a + b)
    {
        return a + b;
    }
};

// Template deduction guide สำหรับการบวก
template<class LHS, class RHS>
auto operator+(const LHS& lhs, const RHS& rhs) 
    -> BinaryExpression<LHS, RHS, AddOp>
{
    return BinaryExpression<LHS, RHS, AddOp>(lhs, rhs);
}

// ตัวสร้างฟิลด์เฉพาะสำหรับนิพจน์
template<class Expr>
class ExpressionField
{
    const Expr& expr_;
    
public:
    ExpressionField(const Expr& expr) : expr_(expr) {}
    
    scalar operator[](const label i) const
    {
        return expr_[i];
    }
    
    label size() const { return expr_.size(); }
};
```

### การวิเคราะห์การใช้งานหน่วยความจำ

```cpp
// Memory profiling สำหรับการสร้างสูตรนิพจน์ที่แตกต่างกัน
void analyzeMemoryUsage(const fvMesh& mesh)
{
    const label nCells = mesh.nCells();
    const scalar bytesPerScalar = sizeof(scalar);
    
    Info << "การวิเคราะห์หน่วยความจำสำหรับ " << nCells << " cells:" << endl;
    
    // วิธีที่ 1: ฟิลด์ชั่วคราวหลายฟิลด์
    Info << "วิธีที่ 1 - ค่าชั่วคราวหลายค่า:" << endl;
    Info << "  Field1: " << nCells * bytesPerScalar << " bytes" << endl;
    Info << "  Field2: " << nCells * bytesPerScalar << " bytes" << endl;
    Info << "  Field3: " << nCells * bytesPerScalar << " bytes" << endl;
    Info << "  รวม: " << 3 * nCells * bytesPerScalar << " bytes" << endl;
    
    // วิธีที่ 2: Expression template (การประเมินครั้งเดียว)
    Info << "วิธีที่ 2 - Expression template:" << endl;
    Info << "  ผลลัพธ์: " << nCells * bytesPerScalar << " bytes" << endl;
    Info << "  รวม: " << nCells * bytesPerScalar << " bytes" << endl;
    
    scalar memorySaving = (3.0 * nCells * bytesPerScalar) / (nCells * bytesPerScalar);
    Info << "ปัจจัยการลดหน่วยความจำ: " << memorySaving << "x" << endl;
}
```

### ตัวอย่างการเพิ่มประสิทธิภาพ Solver

```cpp
// Optimized momentum equation solver โดยใช้ expression templates
void solveMomentumOptimized(fvVectorMatrix& UEqn, volVectorField& U)
{
    // แนวทางเดิม (ค่าชั่วคราวหลายค่า):
    // volVectorField gradP = fvc::grad(p);
    // volScalarField divTau = fvc::div(tau);
    // UEqn -= (gradP + divTau);
    
    // แนวทางที่เพิ่มประสิทธิภาพ (การประเมินครั้งเดียว):
    UEqn -= (fvc::grad(p) + fvc::div(tau));  // Expression template
    
    // แก้ไขด้วยการประเมินเงื่อนไขขอบเขตที่เพิ่มประสิทธิภาพ
    UEqn.relax();
    
    // ใช้การเลือก solver ที่มีประสิทธิภาพตามคุณสมบัติของเมทริกซ์
    solverPerformance solverPerf = UEqn.solve();
    
    // รายงานการ converging
    const scalar residual = solverPerf.initialResidual();
    const label nIterations = solverPerf.nIterations();
    
    Info << "Momentum solver converged ใน " << nIterations 
         << " iterations, residual สุดท้าย = " << residual << endl;
}
```

### การเก็บรวบรวม Performance Metrics

```cpp
class PerformanceProfiler
{
    std::map<word, scalar> timings_;
    std::map<word, scalar> memoryUsage_;
    
public:
    void startTiming(const word& operation)
    {
        startTimes_[operation] = std::chrono::high_resolution_clock::now();
    }
    
    void endTiming(const word& operation)
    {
        auto end = std::chrono::high_resolution_clock::now();
        auto start = startTimes_[operation];
        auto duration = std::chrono::duration_cast<std::chrono::microseconds>(end - start);
        
        timings_[operation] += duration.count();
        startTimes_.erase(operation);
    }
    
    void report()
    {
        Info << "Performance Report:" << endl;
        for (const auto& timing : timings_)
        {
            Info << "  " << timing.first << ": " << timing.second << " μs" << endl;
        }
    }
    
private:
    std::map<word, std::chrono::high_resolution_clock::time_point> startTimes_;
};
```

## เคล็ดลับขั้นสูงและแนวทางปฏิบัติที่ดีที่สุด

### แนวทางปฏิบัติ Expression Template
1. **หลีกเลี่ยงค่าชั่วคราวที่ไม่จำเป็น**: รวมการดำเนินการในนิพจน์เดียว
2. **Profile ก่อนการเพิ่มประสิทธิภาพ**: วัดประสิทธิภาพอย่างเป็นระบบ
3. **พิจารณา memory hierarchy**: การดำเนินการที่เป็นมิตรกับ cache ช่วยเพิ่มประสิทธิภาพ
4. **ใช้ type deduction ที่เหมาะสม**: ให้ templates จัดการ type promotion อัตโนมัติ

### แนวทางปฏิบัติการวิเคราะห์มิติ
1. **ใช้ประเภทมิติเสมอ**: `dimensionedScalar` แทน `scalar` แบบดิบ
2. **ตรวจสอบความสอดคล้องของมิติ**: โดยเฉพาะในสมการแบบกำหนดเอง
3. **จัดทำเอกสารมิติ**: ความคิดเห็นที่ชัดเจนเกี่ยวกับความหมายทางกายภาพ
4. **ทดสอบกรณีขอบ**: ตรวจสอบว่าการตรวจสอบมิติจับความผิดพลาดจริงได้

### กลยุทธ์การเพิ่มประสิทธิภาพโค้ด
1. **เป็นมิตรกับ vectorization**: จัดโครงสร้างข้อมูลสำหรับการดำเนินการ SIMD
2. **การจัดตำแหน่งหน่วยความจำ**: ลด cache misses ในการดำเนินการฟิลด์
3. **ประสิทธิภาพแบบขนาน**: ตรวจสอบให้แน่ใจว่า expression templates ทำงานกับการ decompose domain ได้
4. **การเพิ่มประสิทธิภาพของ compiler**: ใช้ค่าสถานะ compiler ที่เหมาะสมสำหรับโค้ดตัวเลข

แบบฝึกปฏิบัติเหล่านี้ให้ประสบการณ์จริงกับการดำเนินการฟิลด์ขั้นสูงใน OpenFOAM ซึ่งช่วยให้คุณเข้าใจทั้งพื้นฐานทางคณิตศาสตร์และรายละเอียดการนำไปใช้งานที่ทำให้ OpenFOAM มีประสิทธิภาพสำหรับการจำลอง CFD
