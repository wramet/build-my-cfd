# 📦 คอนเทนเนอร์ `List` ของ OpenFOAM: คู่มือครอบคลุมสำหรับการพัฒนา CFD

## 🔍 แนวคิดระดับสูง: ระบบจัดเก็บข้อมูลแบบยืดหยุ่น

ในพลศาสตร์ของไหลเชิงคำนวณ คอนเทนเนอร์ `List` ทำหน้าที่เป็นอาร์เรย์ขนาดไดนามิกพื้นฐานของ OpenFOAM—จินตนาการถึงระบบจัดเก็บข้อมูลแบบปรับตัวได้ที่มีช่องว่างสามารถขยายหรือหดตัวในขณะที่ยังคงรักษารูปแบบการเข้าถึงที่มีประสิทธิภาพสูง คอนเทนเนอร์นี้ให้โครงสร้างหลักสำหรับจัดเก็บข้อมูลฟิลด์, เวกเตอร์การแก้ปัญหา, และผลลัพธ์กลางคันตลอดการจำลอง CFD

คลาส `List` ใช้กลยุทธ์การจัดสรรหน่วยความจำต่อเนื่อง โดยที่องค์ประกอบทั้งหมดถูกจัดเก็บตามลำดับ ทำให้การดำเนินการที่เป็นมิตรกับแคชมีประสิทธิภาพสูงซึ่งเป็นสิ่งจำเป็นสำหรับการคำนวณเชิงตัวเลข ต่างจากอาร์เรย์ C++ มาตรฐาน, `List` จัดการการจัดสรรหน่วยความจำ, การปรับขนาด, และการตรวจสอบขอบเขตโดยอัตโนมัติในขณะที่ยังคงคุณสมบัติด้านประสิทธิภาพที่จำเป็นสำหรับแอปพลิเคชัน CFD ขนาดใหญ่

[Diagram: ภาพแสดงโครงสร้างหน่วยความจำแบบต่อเนื่องของ List กับองค์ประกอบ v_, size_, และ capacity_]

### สถาปัตยกรรมการจัดเก็บข้อมูลหลัก

`List` ทำงานบนหลักการของ **อาร์เรย์ไดนามิกที่ปลอดภัยต่อชนิดข้อมูล** พร้อมการจัดการหน่วยความจำอัตโนมัติ การออกแบบที่ใช้เทมเพลตทำให้มั่นใจได้ว่ามีการตรวจสอบชนิดข้อมูลในเวลาคอมไพล์ในขณะที่ให้ความยืดหยุ่นในการแก้ไขขนาดในรันไทม์ อินสแตนซ์ `List` แต่ละรายการรักษาองค์ประกอบสำคัญสามรายการ: พอยเตอร์ไปยังหน่วยความจำที่จัดสรร (`v_`), จำนวนองค์ประกอบปัจจุบัน (`size_`), และความจุทั้งหมดที่จัดสรร (`capacity_`)

กลยุทธ์การจัดเก็บทำตาม **รูปแบบการจัดสรรที่เน้นการเติบโต** โดยที่คอนเทนเนอร์จะขยายในชิ้นส่วนที่แยกจากกันเพื่อลดการจัดสรรหน่วยความจำซ้ำๆ เมื่อความจุปัจจุบันเกินขีดจำกัด ตัวจัดสรรโดยทั่วไปจะเพิ่มพื้นที่ที่จัดสรรเป็นสองเท่า, คัดลอกองค์ประกอบที่มีอยู่ไปยังตำแหน่งหน่วยความจำใหม่ และปล่อยการจัดสรรเก่า แนวทางนี้สมดุลระหว่างประสิทธิภาพหน่วยความจำกับการปรับให้เหมาะสมด้านประสิทธิภาพ

### ความสัมพันธ์กับระบบฟิลด์ของ OpenFOAM

`List` เป็นพื้นฐานสำหรับลำดับชั้นฟิลด์ทั้งหมดของ OpenFOAM คลาสฟิลด์ (`volScalarField`, `volVectorField`, ฯลฯ) สืบทอดจาก `List` และขยายความสามารถด้วยการรับรู้เมช, การจัดการเงื่อนไขขอบเขต, และการดำเนินการทางคณิตศาสตร์ การสืบทอดนี้ช่วยให้สามารถแปลงระหว่างการจัดเก็บข้อมูลดิบและการแสดงผลฟิลด์ที่มีความหมายทางฟิสิกส์ได้อย่างราบรื่น

เมื่อทำงานกับการจำลอง CFD, คุณจะพบกับอินสแตนซ์ `List` ทั่วทั้งโค้ดเบส—จากการกระจายความดันและความเร็วไปจนถึงพารามิเตอร์โมเดลความปั่นป่วนและความเข้มข้นของสารเคมี การออกแบบคอนเทนเนอร์มุ่งเน้นเฉพาะที่ความต้องการด้านประสิทธิภาพของวิธีการเชิงตัวเลข เช่น การวิธีปริมาตรจำกัด ซึ่งการเข้าถึงและการแก้ไของค์ประกอบอย่างรวดเร็วเป็นสิ่งจำเป็นสำหรับประสิทธิภาพของ solver

[Diagram: แผนภาพแสดงลำดับชั้นการสืบทอดจาก List ไปยัง GeometricField ไปยังฟิลด์เฉพาะเช่น volScalarField]

## ⚙️ การใช้งานทางเทคนิค

### สถาปัตยกรรมเทมเพลตและระบบชนิดข้อมูล

คลาสเทมเพลต `List` ใน OpenFOAM ให้รากฐานที่แข็งแกร่งสำหรับการดำเนินการคอนเทนเนอร์ที่ปลอดภัยต่อชนิดข้อมูล:

```cpp
template<class T>
class List : public UList<T>
{
private:
    T* __restrict__ v_;      // พอยเตอร์ไปยังหน่วยความจำที่จัดสรร
    label size_;             // จำนวนองค์ประกอบปัจจุบัน
    label capacity_;         // ความจุทั้งหมดที่จัดสรร

public:
    // Constructor กับรูปแบบการกำหนดค่าเริ่มต้นต่างๆ
    List();
    explicit List(const label n);
    List(const label n, const T& val);
    List(const List<T>& lst);
    
    // การดำเนินการจัดการหน่วยความจำ
    void resize(const label n);
    void reserve(const label n);
    void clear();
    void shrink();
    
    // การเข้าถึงองค์ประกอบพร้อมการตรวจสอบขอบเขต
    T& operator[](const label i);
    const T& operator[](const label i) const;
    
    // ตัวดำเนินการกำหนดค่าและการเปรียบเทียบ
    List<T>& operator=(const List<T>& lst);
    bool operator==(const List<T>& lst) const;
    bool operator!=(const List<T>& lst) const;
};
```

โครงสร้างเทมเพลตนี้ช่วยให้สามารถสร้างอินสแตนซ์ในเวลาคอมไพล์สำหรับชนิดข้อมูลต่างๆ ที่ใช้กันทั่วไปใน CFD:

```cpp
// ชนิดข้อมูล CFD ทั่วไปที่จัดเก็บใน Lists
List<scalar> pressureValues;           // ฟิลด์ความดัน
List<vector> velocityVectors;          // ส่วนประกอบความเร็ว
List<tensor> stressTensors;            // ฟิลด์เทนเซอร์ความเค้น
List<label> connectivityIndices;       // การเชื่อมต่อเมช
List<symmTensor> reynoldsStress;       // ปริมาณความปั่นป่วน
List<sphericalTensor> vorticity;       // ฟิลด์การหมุน
```

### กลยุทธ์การจัดการหน่วยความจำ

กลยุทธ์การจัดสรรใช้การเติบโตแบบเอกซ์โพเนนเชียลพร้อมการจัดการความจุ:

```cpp
template<class T>
void List<T>::reserve(const label nAlloc)
{
    if (nAlloc > capacity_)
    {
        T* newV = new T[nAlloc];           // จัดสรรหน่วยความจำใหม่
        
        // คัดลอกหน่วยความจำอย่างมีประสิทธิภาพโดยใช้ std::copy สำหรับ pod types
        if (std::is_trivially_copyable<T>::value)
        {
            std::memcpy(newV, v_, size_ * sizeof(T));
        }
        else
        {
            // คัดลอกแบบองค์ประกอบต่อองค์ประกอบสำหรับชนิดข้อมูลที่ซับซ้อนที่มี destructor
            for (label i = 0; i < size_; i++)
            {
                newV[i] = std::move(v_[i]);
            }
        }
        
        delete[] v_;                        // ปล่อยหน่วยความจำเก่า
        v_ = newV;                          // อัปเดตพอยเตอร์
        capacity_ = nAlloc;                 // อัปเดตความจุ
    }
}

template<class T>
void List<T>::resize(const label n)
{
    if (n != size_)
    {
        if (n > capacity_)
        {
            reserve(max(n, 2 * capacity_));  // การเติบโตแบบเอกซ์โพเนนเชียล
        }
        
        // สร้างองค์ประกอบใหม่ถ้าขยาย
        for (label i = size_; i < n; i++)
        {
            new (&v_[i]) T();                // Placement new สำหรับการสร้าง
        }
        
        // ทำลายองค์ประกอบที่ถูกลบถ้าหด
        for (label i = n; i < size_; i++)
        {
            v_[i].~T();                      // เรียก destructor อย่างชัดเจน
        }
        
        size_ = n;
    }
}
```

### การดำเนินการขั้นสูงและการสนับสนุนอัลกอริทึม

`List` ทำงานร่วมกับระบบอัลกอริทึมของ OpenFOAM ได้อย่างราบรื่น:

```cpp
// การดำเนินการแบบขนานโดยใช้เฟรมเวิร์กแบบขนานของ OpenFOAM
List<scalar> parallelReduce(const List<scalar>& field)
{
    scalar sumField = 0.0;
    forAll(field, i)
    {
        sumField += field[i];
    }
    reduce(sumField, sumOp<scalar>());      // MPI reduction ข้ามโปรเซสเซอร์
    return List<scalar>(1, sumField);
}

// การดำเนินการทางคณิตศาสตร์กับพีชคณิตฟิลด์
List<vector> computeGradients(const List<scalar>& phi, const fvMesh& mesh)
{
    List<vector> gradPhi(phi.size());
    
    forAll(gradPhi, cellI)
    {
        const labelList& cellFaces = mesh.cells()[cellI];
        vector grad = vector::zero;
        
        forAll(cellFaces, faceI)
        {
            label faceID = cellFaces[faceI];
            vector dSf = mesh.Sf()[faceID];  // เวกเตอร์พื้นที่ผิว
            scalar deltaPhi = phi[faceID] - phi[cellI];
            grad += deltaPhi * dSf / mesh.V()[cellI];
        }
        
        gradPhi[cellI] = grad;
    }
    
    return gradPhi;
}
```

### เทคนิคการปรับให้เหมาะสมด้านประสิทธิภาพ

การใช้งาน `List` ประกอบด้วยคุณสมบัติที่เพิ่มประสิทธิภาพหลายอย่าง:

```cpp
// รูปแบบการวนซ้ำที่เป็นมิตรกับแคช
template<class T>
class optimizedListOperations
{
public:
    // การวนซ้ำที่ตระหนักถึงการ prefetch สำหรับลิสต์ขนาดใหญ่
    static void elementwiseOperation(List<T>& result, const List<T>& op1, const List<T>& op2)
    {
        const label n = result.size();
        
        // ประมวลผลเป็นชิ้นที่เป็นมิตรกับแคช
        constexpr label chunkSize = 64;      // ปรับให้เหมาะสมสำหรับขนาด cache line
        
        for (label chunk = 0; chunk < n; chunk += chunkSize)
        {
            label end = min(chunk + chunkSize, n);
            
            // Prefetch ชิ้นถัดไปลงในแคช
            if (end + chunkSize <= n)
            {
                __builtin_prefetch(&op1[end + chunkSize], 0, 3);
                __builtin_prefetch(&op2[end + chunkSize], 0, 3);
                __builtin_prefetch(&result[end + chunkSize], 1, 3);
            }
            
            // ประมวลผลชิ้นปัจจุบัน
            for (label i = chunk; i < end; i++)
            {
                result[i] = op1[i] * op2[i];   // ตัวอย่าง: การคูณแบบองค์ประกอบต่อองค์ประกอบ
            }
        }
    }
};
```

## 🧠 สถาปัตยกรรมหน่วยความจำและการสืบทอด

### การออกแบบลำดับชั้นคอนเทนเนอร์

ระบบคอนเทนเนอร์ของ OpenFOAM ทำตามลำดับชั้นการสืบทอดที่มีโครงสร้างอย่างระมัดรััว:

```cpp
// อินเทอร์เฟซฐานโดยไม่มีความเป็นเจ้าของหน่วยความจำ
template<class T>
class UList
{
protected:
    T* __restrict__ v_;
    label size_;

public:
    // การดำเนินการอินเทอร์เฟซบริสุทธิ์
    virtual T& operator[](const label i) = 0;
    virtual const T& operator[](const label i) const = 0;
    virtual label size() const = 0;
    
    // Constructor แบบไม่มีความเป็นเจ้าของ
    UList(T* data, label size) : v_(data), size_(size) {}
    
    // Virtual destructor สำหรับพฤติกรรม polymorphic
    virtual ~UList() = default;
};

// คอนเทนเนอร์ที่เป็นเจ้าของพร้อมการจัดการหน่วยความจำ
template<class T>
class List : public UList<T>
{
private:
    label capacity_;     // การติดตามความจุเพิ่มเติม

public:
    // Constructor ที่เป็นเจ้าของหน่วยความจำ
    explicit List(label n = 0) : UList<T>(nullptr, n), capacity_(n)
    {
        if (n > 0)
        {
            this->v_ = new T[n];
        }
    }
    
    // การใช้งานกฎห้าม (Rule of five)
    List(const List<T>& other) : List(other.size())
    {
        for (label i = 0; i < this->size_; i++)
        {
            this->v_[i] = other.v_[i];
        }
    }
    
    List(List<T>&& other) noexcept
    {
        this->v_ = other.v_;
        this->size_ = other.size_;
        capacity_ = other.capacity_;
        
        other.v_ = nullptr;
        other.size_ = 0;
        other.capacity_ = 0;
    }
    
    List& operator=(const List<T>& other)
    {
        if (this != &other)
        {
            resize(other.size_);
            for (label i = 0; i < this->size_; i++)
            {
                this->v_[i] = other.v_[i];
            }
        }
        return *this;
    }
    
    List& operator=(List<T>&& other) noexcept
    {
        if (this != &other)
        {
            delete[] this->v_;
            
            this->v_ = other.v_;
            this->size_ = other.size_;
            capacity_ = other.capacity_;
            
            other.v_ = nullptr;
            other.size_ = 0;
            other.capacity_ = 0;
        }
        return *this;
    }
    
    ~List()
    {
        delete[] this->v_;
    }
};
```

### การผสานรวมระบบฟิลด์

คลาสฟิลด์สร้างขึ้นบน `List` เพื่อให้ฟังก์ชันการทำงานที่รับรู้เมช:

```cpp
// คลาสฟิลด์ฐาน
template<class Type, class GeoMesh>
class GeometricField : public List<Type>
{
protected:
    const GeoMesh& mesh_;           // การอ้างอิงเมช
    word name_;                     // ตัวระบุฟิลด์
    Dimensioned<Type> dimensions_;  // มิติทางฟิสิกส์

public:
    // Constructor ที่รับรู้เมช
    GeometricField(const word& name, const GeoMesh& mesh, const dimensionSet& dims)
        : List<Type>(mesh.size()), mesh_(mesh), name_(name), dimensions_(dims)
    {}
    
    // วิธีการผสานรวมเมช
    const GeoMesh& mesh() const { return mesh_; }
    const word& name() const { return name_; }
    const dimensionSet& dimensions() const { return dimensions_.dimensions(); }
    
    // การจัดการเงื่อนไขขอบเขต
    template<class PatchField>
    void setBoundaryCondition(const word& patchName, const PatchField& condition)
    {
        label patchID = mesh_.boundaryMesh().findPatchID(patchName);
        if (patchID != -1)
        {
            // ใช้เงื่อนไขขอบเขตกับ patch ที่ระบุ
            applyPatchCondition(patchID, condition);
        }
    }
};

// ชนิดฟิลด์เฉพาะ
using volScalarField = GeometricField<scalar, fvMesh>;
using volVectorField = GeometricField<vector, fvMesh>;
using surfaceScalarField = GeometricField<scalar, surfaceMesh>;
```

### การปรับให้เหมาะสมของโครงสร้างหน่วยความจำ

โครงสร้างหน่วยความจำต่อเนื่องให้ประโยชน์ด้านประสิทธิภาพที่สำคัญ:

```cpp
// การจัดเก็บข้อมูลที่ประหยัดหน่วยความจำสำหรับการดำเนินการ CFD
template<class T>
class memoryOptimizedList
{
private:
    static constexpr size_t CACHE_LINE_SIZE = 64;
    static constexpr size_t ALIGNMENT = 64;  // การจัดแนว SIMD
    
    T* __restrict__ data_;
    label size_;
    label capacity_;
    
    // การจัดสรรที่จัดแนวสำหรับการดำเนินการ SIMD
    T* allocateAligned(size_t n)
    {
        if (n == 0) return nullptr;
        
        void* ptr = nullptr;
        int result = posix_memalign(&ptr, ALIGNMENT, n * sizeof(T));
        
        if (result != 0)
        {
            FatalErrorInFunction << "Aligned allocation failed" << abort(FatalError);
        }
        
        return static_cast<T*>(ptr);
    }

public:
    // การดำเนินการที่เข้ากันได้กับ SIMD
    void vectorizedOperation(const List<T>& operand)
    {
        const label n = min(size_, operand.size());
        const label vectorizedEnd = n - (n % 8);  // ประมวลผล 8 องค์ประกอบต่อครั้ง
        
        // การประมวลผลแบบเวกเตอร์โดยใช้คำสั่ง SIMD
        for (label i = 0; i < vectorizedEnd; i += 8)
        {
            // โหลด 8 องค์ประกอบลงในรีจิสเตอร์ SIMD
            __m256 vecA = _mm256_load_ps(&data_[i]);
            __m256 vecB = _mm256_load_ps(&operand[i]);
            
            // ดำเนินการ (เช่น การบวก)
            __m256 result = _mm256_add_ps(vecA, vecB);
            
            // เก็บผลลัพธ์
            _mm256_store_ps(&data_[i], result);
        }
        
        // จัดการกับองค์ประกอบที่เหลือ
        for (label i = vectorizedEnd; i < n; i++)
        {
            data_[i] += operand[i];
        }
    }
};
```

## ⚠️ ข้อควรพิจารณาด้านประสิทธิภาพและข้อผิดพลาดทั่วไป

### ข้อผิดพลาดในการจัดการหน่วยความจำ

#### 1. การใช้ Iterator ไม่ได้ระหว่างการปรับขนาด

```cpp
// ปัญหาประสิทธิภาพร้ายแรง: การอ้างอิงที่ใช้ไม่ได้
void problematicResizing(List<scalar>& values)
{
    // รับพอยเตอร์ไปยังองค์ประกอบก่อนการจัดสรรหน่วยความจำใหม่ที่อาจเกิดขึ้น
    scalar& firstValue = values[0];  // การอ้างอิงถึงองค์ประกอบแรก
    
    // การจัดสรรหน่วยความจำใหม่อาจเกิดขึ้น, ย้ายตำแหน่งหน่วยความจำ
    values.resize(values.size() + 1000);  // หน่วยความจำอาจย้าย!
    
    // อันตราย: firstValue ตอนนี้ชี้ไปยังหน่วยความจำที่ถูกปล่อยแล้ว
    firstValue = 123.45;  // พฤติกรรมที่ไม่กำหนด - น่าจะขัดข้อง
}

// ทางเลือกที่ปลอดภัย
void safeResizing(List<scalar>& values)
{
    label originalSize = values.size();
    values.resize(originalSize + 1000);  // ปรับขนาดก่อน
    
    // รับการอ้างอิงใหม่หลังจากปรับขนาด
    scalar& firstValue = values[0];  // การอ้างอิงที่ถูกต้อง
    firstValue = 123.45;  // การดำเนินการที่ปลอดภัย
}
```

#### 2. ผลกระทบด้านประสิทธิภาพจากการจัดสรรหน่วยความจำซ้ำๆ

| แนวทาง | ความซับซ้อน | การจัดสรรหน่วยความจำ | ประสิทธิภาพ | คำอธิบาย |
|---------|-------------|------------------|---------|----------|
| `inefficientConstruction` | O(n²) | หลายครั้ง | ต่ำ | การใช้ `append()` ซ้ำๆ |
| `efficientConstruction` | O(n) | 1 ครั้ง | สูง | การจัดสรรครั้งเดียว |
| `dynamicGrowthWithReserve` | O(n) | 1-2 ครั้ง | สูง | การจองความจุล่วงหน้า |

```cpp
// รูปแบบตรงข้าม: ความซับซ้อน O(n²) จากการปรับขนาดซ้ำๆ
List<scalar> inefficientConstruction()
{
    List<scalar> data;
    
    // แต่ละการต่อท้ายอาจทำให้เกิดการจัดสรรและคัดลอกใหม่
    for (label i = 0; i < 100000; i++)
    {
        data.append(i * 0.001);  // การดำเนินการ O(n) ต่อการต่อท้ายที่เป็นไปได้
    }
    
    return data;  // ความซับซ้อนโดยรวม O(n²)
}

// แนวทางที่เหมาะสม: ความซับซ้อน O(n) พร้อมการจัดสรรล่วงหน้า
List<scalar> efficientConstruction()
{
    List<scalar> data(100000);  // จัดสรรครั้งเดียว
    
    // การกำหนดค่าโดยตรงโดยไม่มีการจัดสรรใหม่
    for (label i = 0; i < data.size(); i++)
    {
        data[i] = i * 0.001;  // การดำเนินการ O(1) ต่อองค์ประกอบ
    }
    
    return data;  // ความซับซ้อนโดยรวม O(n)
}

// ทางเลือก: การเติบโตแบบไดนามิกพร้อมการจองความจุ
List<scalar> dynamicGrowthWithReserve()
{
    List<scalar> data;
    data.reserve(100000);  // จองความจุล่วงหน้า
    
    // การดำเนินการต่อท้ายโดยไม่มีการจัดสรรใหม่
    for (label i = 0; i < 100000; i++)
    {
        data.append(i * 0.001);  // O(1) เฉลี่ยต่อการต่อท้าย
    }
    
    return data;
}
```

#### 3. ความสับสนระหว่างการคัดลอกลึกและตื้น

```cpp
// โครงสร้างที่ซ้อนกันซับซ้อนพร้อมความหมายของการคัดลอก
class CFDData
{
private:
    List<List<scalar>> pressureHistory_;  // ข้อมูลความดัน 2D
    
public:
    // Constructor พร้อมลิสต์ที่ซ้อนกัน
    CFDData(label nTimeSteps, label nCells)
        : pressureHistory_(nTimeSteps)
    {
        for (label t = 0; t < nTimeSteps; t++)
        {
            pressureHistory_[t] = List<scalar>(nCells, 101325.0);  // กำหนดค่าเริ่มต้น
        }
    }
    
    // พฤติกรรมการคัดลอกตื้น (ค่าเริ่มต้น)
    void problematicAssignment()
    {
        List<List<scalar>> copy = pressureHistory_;  // การคัดลอกตื้นของลิสต์ภายนอก
        
        // การแก้ไขลิสต์ภายในมีผลกับข้อมูลต้นฉบับ
        copy[0][0] = 999999.0;  // ยังเปลี่ยน pressureHistory_[0][0] ด้วย
        
        // เกิดเพราะลิสต์ภายนอกถูกคัดลอก แต่ลิสต์ภายในแชร์การอ้างอิง
        // อันตรายต่อความสมบูรณ์ของข้อมูล
    }
    
    // การใช้งานการคัดลอกลึกที่ถูกต้อง
    void safeCopy()
    {
        List<List<scalar>> deepCopy;
        deepCopy.setSize(pressureHistory_.size());
        
        forAll(pressureHistory_, i)
        {
            deepCopy[i] = pressureHistory_[i];  // คัดลอกแต่ละลิสต์ภายใน
        }
        
        // การแก้ไขที่ปลอดภัย
        deepCopy[0][0] = 999999.0;  // มีผลกับสำเนาเท่านั้น
    }
};
```

### การปรับให้เหมาะสมด้านประสิทธิภาพแคช

#### 1. รูปแบบการเข้าถึงหน่วยความจำ

| รูปแบบการเข้าถึง | ประสิทธิภาพแคช | การใช้งาน | คำแนะนำ |
|---------------|--------------|----------|----------|
| `sequential` | สูง | การวนซ้ำปกติ | **แนะนำ** สำหรับลูปหลัก |
| `strided` | ปานกลาง | การเข้าถึงทุก n องค์ประกอบ | ใช้เมื่อจำเป็น |
| `random` | ต่ำ | การจัดทำดัชนี | หลีกเลี่ยงหากเป็นไปได้ |

```cpp
// รูปแบบการเข้าถึงที่ไม่เป็นมิตรกับแคช
void cacheUnfriendlyIteration(List<scalar>& field, const List<label>& indices)
{
    // รูปแบบการเข้าถึงแบบสุ่มทำให้การ prefetch ของแคชล้มเหลว
    forAll(indices, i)
    {
        label idx = indices[i];
        field[idx] *= 1.001;  // การเข้าถึงหน่วยความจำแบบสุ่ม
    }
}

// การเข้าถึงตามลำดับที่เป็นมิตรกับแคช
void cacheFriendlyIteration(List<scalar>& field)
{
    // การเข้าถึงตามลำดับเพิ่มประสิทธิภาพการใช้แคช
    forAll(field, i)
    {
        field[i] *= 1.001;  // รูปแบบการเข้าถึงหน่วยความจำที่ทำนายได้
    }
}

// การประมวลผลแบบบล็อกสำหรับชุดข้อมูลขนาดใหญ่
void blockWiseProcessing(List<scalar>& field)
{
    constexpr label BLOCK_SIZE = 1024;  // ปรับให้เหมาะสมสำหรับขนาดแคช
    const label n = field.size();
    
    for (label block = 0; block < n; block += BLOCK_SIZE)
    {
        label blockEnd = min(block + BLOCK_SIZE, n);
        
        // ประมวลผลบล็อกเพื่อให้อยู่ภายในแคช
        for (label i = block; i < blockEnd; i++)
        {
            field[i] = sqrt(abs(field[i]));  // การดำเนินการที่ซับซ้อน
        }
    }
}
```

#### 2. ข้อควรพิจารณาด้านการเวกเตอร์ไซเซชัน SIMD

```cpp
// การดำเนินการที่ปรับให้เหมาะสมด้วย SIMD สำหรับส่วนที่สำคัญต่อประสิทธิภาพ
class vectorizedListOperations
{
public:
    // การบวกแบบเวกเตอร์โดยใช้คำสั่ง AVX
    static void vectorizedAdd(List<scalar>& result, const List<scalar>& a, const List<scalar>& b)
    {
        const label n = min(result.size(), min(a.size(), b.size()));
        const label vectorizedSize = n - (n % 8);  // ประมวลผลเป็นกลุ่มของ 8
        
        // ลูปแบบเวกเตอร์
        for (label i = 0; i < vectorizedSize; i += 8)
        {
            __m256 vecA = _mm256_loadu_ps(&a[i]);
            __m256 vecB = _mm256_loadu_ps(&b[i]);
            __m256 vecResult = _mm256_add_ps(vecA, vecB);
            _mm256_storeu_ps(&result[i], vecResult);
        }
        
        // จัดการกับองค์ประกอบที่เหลือ
        for (label i = vectorizedSize; i < n; i++)
        {
            result[i] = a[i] + b[i];
        }
    }
};
```

## 🎯 การประยุกต์ใช้ทางวิศวกรรมใน CFD

### การจัดเก็บและรูปแบบการเข้าถึงฟิลด์

ในการจำลอง CFD แบบปริมาตรจำกัด, คอนเทนเนอร์ `List` ทำหน้าที่เป็นกลไกการจัดเก็บข้อมูลหลักสำหรับค่าฟิลด์ที่แบ่งค่า:

```cpp
class CFDFieldStorage
{
private:
    const fvMesh& mesh_;
    
    // ตัวแปรฟิลด์หลัก
    List<scalar> pressure_;          // ฟิลด์ความดัน [Pa]
    List<vector> velocity_;          // ฟิลด์ความเร็ว [m/s]
    List<scalar> temperature_;       // ฟิลด์อุณหภูมิ [K]
    
    // ปริมาณที่ได้จากการคำนวณ
    List<scalar> turbulenceKE_;      // พลังงานจลน์ความปั่นป่วน [m²/s²]
    List<scalar> turbulenceEpsilon_; // การสลายตัวของความปั่นป่วน [m²/s³]
    
    // การเข้าถึงเรขาคณิตเมช
    List<vector> cellCenters_;       // พิกัดจุดศูนย์กลางเซลล์
    List<scalar> cellVolumes_;       // ปริมาตรเซลล์ [m³]
    List<tensor> cellGradients_;     // เทนเซอร์ไลเกรเดียนของเซลล์

public:
    CFDFieldStorage(const fvMesh& mesh) : mesh_(mesh)
    {
        // กำหนดค่าเริ่มต้นการจัดเก็บฟิลด์ด้วยมิติของเมช
        pressure_.setSize(mesh.nCells());
        velocity_.setSize(mesh.nCells());
        temperature_.setSize(mesh.nCells());
        turbulenceKE_.setSize(mesh.nCells());
        turbulenceEpsilon_.setSize(mesh.nCells());
        
        // คำนวณปริมาณทางเรขาคณิตล่วงหน้า
        computeGeometry();
    }
    
private:
    void computeGeometry()
    {
        const label nCells = mesh_.nCells();
        cellCenters_.setSize(nCells);
        cellVolumes_.setSize(nCells);
        cellGradients_.setSize(nCells);
        
        forAll(cellCenters_, cellI)
        {
            cellCenters_[cellI] = mesh_.C()[cellI];  // จุดศูนย์กลางเซลล์
            cellVolumes_[cellI] = mesh_.V()[cellI];  // ปริมาตรเซลล์
            cellGradients_[cellI] = mesh_.gradCellVol()[cellI];  // ไลเกรเดียนปริมาตร
        }
    }
    
public:
    // กำหนดค่าเริ่มต้นการกระจายความดันไฮโดรสแตติก
    void initializeHydrostaticPressure(scalar pRef, scalar rhoRef, scalar g)
    {
        forAll(pressure_, cellI)
        {
            scalar z = cellCenters_[cellI].z();  // ความสูงเหนือจุดอ้างอิง
            pressure_[cellI] = pRef - rhoRef * g * z;
        }
    }
    
    // คำนวณขนาดของความเร็ว
    List<scalar> computeVelocityMagnitude() const
    {
        List<scalar> velocityMag(velocity_.size());
        
        forAll(velocityMag, cellI)
        {
            velocityMag[cellI] = mag(velocity_[cellI]);
        }
        
        return velocityMag;
    }
    
    // ใช้เงื่อนไขขอบเขตโดยใช้การเชื่อมต่อผิวหน้าของเมช
    void applyBoundaryConditions()
    {
        const fvPatchList& patches = mesh_.boundary();
        
        forAll(patches, patchI)
        {
            const fvPatch& patch = patches[patchI];
            
            if (isA<wallFvPatchScalarField>(patch))
            {
                // ใช้เงื่อนไขขอบเขต no-slip
                forAll(patch, faceI)
                {
                    label cellI = patch.faceCells()[faceI];
                    velocity_[cellI] = vector::zero;  // เงื่อนไข no-slip
                }
            }
        }
    }
};
```

### การผสานรวม Linear Solver

คอนเทนเนอร์ `List` เป็นพื้นฐานสำหรับการแก้ปัญหาระบบเชิงเส้นที่เกิดจากการวิธีปริมาตรจำกัด CFD:

```cpp
class CFDLinearSolver
{
private:
    const fvMesh& mesh_;
    List<scalar> solutionVector_;    // เวกเตอร์การแก้ปัญหา x
    List<scalar> rightHandSide_;     // เวกเตอร์ด้านขวา b
    List<scalar> residual_;          // เวกเตอร์ส่วนตกคง r = b - Ax
    
    // พารามิเตอร์ solver
    scalar tolerance_;
    label maxIterations_;
    scalar relaxationFactor_;

public:
    CFDLinearSolver(const fvMesh& mesh, scalar tol = 1e-6, label maxIter = 1000)
        : mesh_(mesh), tolerance_(tol), maxIterations_(maxIter), relaxationFactor_(0.8)
    {
        label nCells = mesh.nCells();
        solutionVector_.setSize(nCells, 0.0);      // การเดาค่าเริ่มต้น
        rightHandSide_.setSize(nCells, 0.0);
        residual_.setSize(nCells, 0.0);
    }
    
    // แก้ปัญหา Ax = b โดยใช้วิธี Conjugate Gradient
    bool solveConjugateGradient()
    {
        label nCells = solutionVector_.size();
        
        // จองเวกเตอร์ทำงานล่วงหน้า
        List<scalar> directionVector(nCells);
        List<scalar> matrixDirectionProduct(nCells);
        
        // คำนวณส่วนตกคงเริ่มต้น: r = b - Ax
        computeMatrixVectorProduct(solutionVector_, matrixDirectionProduct);
        forAll(residual_, i)
        {
            residual_[i] = rightHandSide_[i] - matrixDirectionProduct[i];
        }
        
        // กำหนดทิศทางการค้นหาเริ่มต้น
        directionVector = residual_;
        
        scalar residualNorm = sqrt(sumSqr(residual_));
        
        if (residualNorm < tolerance_)
        {
            Info << "Converged with initial guess" << endl;
            return true;
        }
        
        // ลูปการวนซ้ำหลัก
        for (label iter = 0; iter < maxIterations_; iter++)
        {
            // คำนวณ Ap = A*p
            computeMatrixVectorProduct(directionVector, matrixDirectionProduct);
            
            // คำนวณ alpha = (r·r)/(p·Ap)
            scalar numerator = sumSqr(residual_);
            scalar denominator = dotProduct(directionVector, matrixDirectionProduct);
            scalar alpha = numerator / denominator;
            
            // อัปเดตการแก้ปัญหา: x = x + α*p
            forAll(solutionVector_, i)
            {
                solutionVector_[i] += alpha * directionVector_[i];
            }
            
            // อัปเดตส่วนตกคง: r = r - α*Ap
            forAll(residual_, i)
            {
                residual_[i] -= alpha * matrixDirectionProduct[i];
            }
            
            // ตรวจสอบการลู่เข้า
            residualNorm = sqrt(sumSqr(residual_));
            
            if (residualNorm < tolerance_)
            {
                Info << "Converged after " << iter + 1 << " iterations" << endl;
                return true;
            }
            
            // คำนวณ beta = (r_new·r_new)/(r_old·r_old)
            scalar newResidualNorm = sumSqr(residual_);
            scalar beta = newResidualNorm / numerator;
            
            // อัปเดตทิศทางการค้นหา: p = r + β*p
            forAll(directionVector_, i)
            {
                directionVector_[i] = residual_[i] + beta * directionVector_[i];
            }
            
            Info << "Iteration " << iter + 1 << ": residual = " << residualNorm << endl;
        }
        
        Warning << "Failed to converge after " << maxIterations_ << " iterations" << endl;
        return false;
    }

private:
    // การคูณเมทริกซ์-เวกเตอร์แบบกระจายสำหรับการวิธีปริมาตรจำกัด
    void computeMatrixVectorProduct(const List<scalar>& x, List<scalar>& result) const
    {
        result.setSize(x.size(), 0.0);
        
        // ส่วนส่วนของเส้นแทยง
        forAll(result, cellI)
        {
            result[cellI] = mesh_.lduAddr().upperAddr()[cellI] * x[cellI];  // ทำให้ง่าย
        }
        
        // ส่วนส่วนนอกเส้นแทยง (การเชื่อมต่อเมทริกซ์)
        const labelList& upperAddr = mesh_.lduAddr().upperAddr();
        const labelList& lowerAddr = mesh_.lduAddr().lowerAddr();
        const scalarField& upperCoeffs = mesh_.lduMatrix().upper();
        const scalarField& lowerCoeffs = mesh_.lduMatrix().lower();
        
        forAll(upperAddr, faceI)
        {
            label row = upperAddr[faceI];
            label col = lowerAddr[faceI];
            
            result[row] += upperCoeffs[faceI] * x[col];
            result[col] += lowerCoeffs[faceI] * x[row];
        }
    }
    
    scalar sumSqr(const List<scalar>& vec) const
    {
        scalar sum = 0.0;
        forAll(vec, i)
        {
            sum += vec[i] * vec[i];
        }
        return sum;
    }
    
    scalar dotProduct(const List<scalar>& a, const List<scalar>& b) const
    {
        scalar sum = 0.0;
        forAll(a, i)
        {
            sum += a[i] * b[i];
        }
        return sum;
    }
};
```

### การผสานรวมเวลาและการจำลองแบบข้าวเวลา

สำหรับการจำลองแบบ CFD แบบข้าวเวลา, คอนเทนเนอร์ `List` จัดเก็บประวัติฟิลด์และเปิดใช้งานอัลกอริทึมการขยับเวลา:

```cpp
class TransientCFDSolver
{
private:
    const fvMesh& mesh_;
    scalar timeStep_;
    scalar currentTime_;
    
    // ฟิลด์ระดับเวลาปัจจุบัน
    List<scalar> pressure_;
    List<vector> velocity_;
    List<scalar> temperature_;
    
    // ฟิลด์ระดับเวลาก่อนหน้า (สำหรับโครงร่างหลายขั้นตอน)
    List<List<scalar>> pressureHistory_;
    List<List<vector>> velocityHistory_;
    
    // พารามิเตอร์การผสานรวมเวลา
    label maxTimeSteps_;
    scalar finalTime_;
    scalar convergenceTolerance_;

public:
    TransientCFDSolver(const fvMesh& mesh, scalar dt, scalar tFinal)
        : mesh_(mesh), timeStep_(dt), finalTime_(tFinal), currentTime_(0.0),
          maxTimeSteps_(static_cast<label>(tFinal / dt) + 1)
    {
        label nCells = mesh.nCells();
        
        // กำหนดค่าเริ่มต้นฟิลด์ปัจจุบัน
        pressure_.setSize(nCells);
        velocity_.setSize(nCells);
        temperature_.setSize(nCells);
        
        // กำหนดค่าเริ่มต้นการจัดเก็บประวัติสำหรับโครงร่างหลายขั้นตอน
        pressureHistory_.setSize(3, List<scalar>(nCells));  // สามระดับเวลา
        velocityHistory_.setSize(3, List<vector>(nCells));
        
        convergenceTolerance_ = 1e-6;
    }
    
    // รันการจำลองแบบข้าวเวลาโดยใช้อัลกอริทึม PISO
    void runTransientSimulation()
    {
        Info << "Starting transient simulation" << endl;
        Info << "Time step: " << timeStep_ << " s" << endl;
        Info << "Final time: " << finalTime_ << " s" << endl;
        Info << "Max time steps: " << maxTimeSteps_ << endl;
        
        // กำหนดค่าเริ่มต้นฟิลด์
        initializeFields();
        
        // ลูปการขยับเวลาหลัก
        for (label timeStep = 0; timeStep < maxTimeSteps_; timeStep++)
        {
            currentTime_ += timeStep_;
            
            Info << "\nTime step: " << timeStep << ", Current time: " << currentTime_ << " s" << endl;
            
            // อัลกอริทึม PISO สำหรับการผสานรวมความดัน-ความเร็ว
            bool converged = performPISOIteration();
            
            if (!converged)
            {
                Warning << "PISO failed to converge at time " << currentTime_ << " s" << endl;
                break;
            }
            
            // อัปเดตประวัติฟิลด์สำหรับขั้นตอนเวลาถัดไป
            updateFieldHistory();
            
            // ตรวจสอบความคืบหน้าของการแก้ปัญหา
            monitorProgress();
            
            // ตรวจสอบว่าการจำลองเสร็จสิ้นหรือไม่
            if (currentTime_ >= finalTime_)
            {
                Info << "Simulation completed successfully" << endl;
                break;
            }
        }
    }

private:
    // กำหนดค่าเริ่มต้นฟิลด์ทั้งหมดด้วยค่าที่มีความหมายทางฟิสิกส์
    void initializeFields()
    {
        // กำหนดค่าเริ่มต้นความดันด้วยการกระจายไฮโดรสแตติก
        forAll(pressure_, cellI)
        {
            scalar z = mesh_.C()[cellI].z();
            pressure_[cellI] = 101325.0 - 1.2 * 9.81 * z;  // ความดันไฮโดรสแตติก
        }
        
        // กำหนดค่าเริ่มต้นความเร็วด้วยการรบกวนเล็กน้อย
        forAll(velocity_, cellI)
        {
            velocity_[cellI] = vector(0.1, 0.0, 0.0);  // ความเร็วทิศทาง x เล็กน้อย
        }
        
        // กำหนดค่าเริ่มต้นอุณหภูมิด้วยโปรไฟล์เชิงเส้น
        forAll(temperature_, cellI)
        {
            scalar y = mesh_.C()[cellI].y();
            temperature_[cellI] = 300.0 + 10.0 * y;  // ไลเกรเดียนอุณหภูมิเชิงเส้น
        }
        
        // กำหนดค่าเริ่มต้นประวัติด้วยเงื่อนไขเริ่มต้น
        pressureHistory_[0] = pressure_;
        pressureHistory_[1] = pressure_;
        pressureHistory_[2] = pressure_;
        
        velocityHistory_[0] = velocity_;
        velocityHistory_[1] = velocity_;
        velocityHistory_[2] = velocity_;
    }
    
    // ดำเนินการการผสานรวมความดัน-ความเร็วแบบ PISO
    bool performPISOIteration()
    {
        const label maxPISOIterations = 5;
        const scalar convergenceTolerance = 1e-5;
        
        List<vector> velocityPredictor(velocity_.size());
        List<scalar> pressureCorrection(pressure_.size());
        
        // ลูปการวนซ้ำ PISO
        for (label pisoIter = 0; pisoIter < maxPISOIterations; pisoIter++)
        {
            // ทำนายฟิลด์ความเร็ว
            predictVelocityField(velocityPredictor);
            
            // แก้สมการการแก้ไขความดัน
            bool pressureConverged = solvePressureCorrection(pressureCorrection);
            
            // แก้ไขฟิลด์ความเร็ว
            correctVelocityField(velocityPredictor, pressureCorrection);
            
            // ตรวจสอบการลู่เข้า
            scalar velocityResidual = computeVelocityResidual();
            scalar pressureResidual = computePressureResidual();
            
            Info << "  PISO iteration " << pisoIter + 1 
                 << ": velocity residual = " << velocityResidual
                 << ", pressure residual = " << pressureResidual << endl;
            
            if (velocityResidual < convergenceTolerance && 
                pressureResidual < convergenceTolerance)
            {
                Info << "  PISO converged after " << pisoIter + 1 << " iterations" << endl;
                return true;
            }
        }
        
        Warning << "  PISO failed to converge after " << maxPISOIterations << " iterations" << endl;
        return false;
    }
    
    // อัปเดตประวัติฟิลด์สำหรับการผสานรวมเวลาแบบหลายขั้นตอน
    void updateFieldHistory()
    {
        // เลื่อนประวัติไปข้างหน้าในเวลา
        pressureHistory_[2] = pressureHistory_[1];
        pressureHistory_[1] = pressureHistory_[0];
        pressureHistory_[0] = pressure_;  // ปัจจุบันกลายเป็นใหม่
        
        velocityHistory_[2] = velocityHistory_[1];
        velocityHistory_[1] = velocityHistory_[0];
        velocityHistory_[0] = velocity_;  // ปัจจุบันกลายเป็นใหม่
    }
    
    // ตรวจสอบความคืบหน้าของการจำลองแบบ
    void monitorProgress() const
    {
        scalar maxVelocity = 0.0;
        scalar avgPressure = 0.0;
        scalar maxTemperature = 0.0;
        
        forAll(velocity_, cellI)
        {
            maxVelocity = max(maxVelocity, mag(velocity_[cellI]));
            avgPressure += pressure_[cellI];
            maxTemperature = max(maxTemperature, temperature_[cellI]);
        }
        
        avgPressure /= velocity_.size();
        
        Info << "  Progress: time = " << currentTime_ << " s (" 
             << 100.0 * currentTime_ / finalTime_ << "%)" << endl;
        Info << "  Max velocity: " << maxVelocity << " m/s" << endl;
        Info << "  Avg pressure: " << avgPressure << " Pa" << endl;
        Info << "  Max temperature: " << maxTemperature << " K" << endl;
    }
    
    // การใช้งานตัวยึดสำหรับขั้นตอนอัลกอริทึม PISO
    void predictVelocityField(List<vector>& velocityPredictor)
    {
        // การทำนายโมเมนตัมที่ทำให้ง่าย
        forAll(velocityPredictor, cellI)
        {
            velocityPredictor[cellI] = velocity_[cellI] + 
                timeStep_ * vector(0.01, 0.0, 0.0);  // แรงภายนอกที่ทำให้ง่าย
        }
    }
    
    bool solvePressureCorrection(List<scalar>& pressureCorrection)
    {
        // การแก้การแก้ไขความดันที่ทำให้ง่าย
        pressureCorrection.setSize(pressure_.size(), 0.0);
        
        forAll(pressureCorrection, cellI)
        {
            pressureCorrection[cellI] = 0.1 * sin(currentTime_ + cellI * 0.1);
        }
        
        return true;
    }
    
    void correctVelocityField(List<vector>& velocityPredictor, const List<scalar>& pressureCorrection)
    {
        forAll(velocity_, cellI)
        {
            velocity_[cellI] = velocityPredictor[cellI] - 
                timeStep_ * vector(pressureCorrection[cellI], 0.0, 0.0);
        }
    }
    
    scalar computeVelocityResidual() const
    {
        scalar residual = 0.0;
        forAll(velocity_, cellI)
        {
            residual += magSqr(velocity_[cellI] - velocityHistory_[1][cellI]);
        }
        return sqrt(residual / velocity_.size());
    }
    
    scalar computePressureResidual() const
    {
        scalar residual = 0.0;
        forAll(pressure_, cellI)
        {
            residual += magSqr(pressure_[cellI] - pressureHistory_[1][cellI]);
        }
        return sqrt(residual / pressure_.size());
    }
};
```

## 🧮 พื้นฐานทางคณิตศาสตร์

คอนเทนเนอร์ `List` เป็นพื้นฐานสำหรับการดำเนินการทางคณิตศาสตร์ที่จำเป็นสำหรับพลศาสตร์ของไหลเชิงคำนวณ ในวิธีปริมาตรจำกัด, รูปแบบที่แบ่งค่าของสมการกำกับต้องการการจัดเก็บและการจัดการค่าฟิลด์อย่างมีประสิทธิภาพข้ามเซลล์เมช, ผิวหน้า, และขอบเขต

### การวิธีปริมาตรจำกัด

วิธีปริมาตรจำกัดแบ่งสมการกำกับเป็นรูปแบบพีชคณิตที่สามารถแก้ปัญหาได้โดยใช้คอนเทนเนอร์ `List`:

$$\int_V \frac{\partial \phi}{\partial t} \, \mathrm{d}V + \oint_S \phi \mathbf{u} \cdot \mathbf{n} \, \mathrm{d}S = \int_V \nabla \cdot (\Gamma \nabla \phi) \, \mathrm{d}V + \int_V S_\phi \, \mathrm{d}V$$

รูปแบบอินทิกรัลนี้กลายเป็นระบบสมการพีชคณิต:

$$\sum_{f=1}^{n_f} \phi_f \mathbf{u}_f \cdot \mathbf{S}_f = \sum_{f=1}^{n_f} \Gamma_f \frac{\phi_{P} - \phi_{N}}{d_{PN}} |\mathbf{S}_f| + S_P V_P$$

โดยที่แต่ละเทอมถูกจัดเก็บและคำนวณโดยใช้คอนเทนเนอร์ `List`:

- $\phi$ ตัวแปรขนส่ง (เช่น ความเร็ว, อุณหภูมิ, ความเข้มข้นสาร)
- $\mathbf{u}$ เวกเตอร์ความเร็วของไหล
- $\mathbf{S}_f$ เวกเตอร์พื้นที่ผิวหน้า
- $\Gamma_f$ สัมประสิทธิ์การแพร่ตัวที่ผิวหน้า
- $d_{PN}$ ระยะห่างระหว่างเซลล์ข้างเคียง
- $S_P$ เทอมต้นทางต่อปริมาตร
- $V_P$ ปริมาตรเซลล์

[Diagram: แผนภาพแสดงการแบ่งค่าบนเซลล์ควบคุม P พร้อมค่าที่ใจกลางเซลล์และผิวหน้า]

```cpp
// การวิธีปริมาตรจำกัดโดยใช้คอนเทนเนอร์ List
class FiniteVolumeDiscretization
{
private:
    const fvMesh& mesh_;
    List<scalar> phi_;           // ฟิลด์ตัวแปรหลัก
    List<scalar> sourceTerm_;    // เทอมต้นทาง S_φ
    List<vector> velocity_;      // ฟิลด์ความเร็ว u
    List<scalar> diffusivity_;   // สัมประสิทธิ์การแพร่ Γ
    
    // สัมประสิทธิ์เมทริกซ์สำหรับระบบเชิงเส้น
    List<scalar> diagonal_;      // สัมประสิทธิ์ A_P
    List<scalar> lower_;         // สัมประสิทธิ์ A_N (สามเหลี่ยมล่าง)
    List<scalar> upper_;         // สัมประสิทธิ์ A_P (สามเหลี่ยมบน)
    List<label> lowerAddr_;      // การจัดที่อยู่เมทริกซ์ล่าง
    List<label> upperAddr_;      // การจัดที่อยู่เมทริกซ์บน

public:
    // สร้างเมทริกซ์การแบ่งค่าสำหรับสมการ convection-diffusion
    void buildConvectionDiffusionMatrix()
    {
        label nCells = mesh_.nCells();
        diagonal_.setSize(nCells, 0.0);
        sourceTerm_.setSize(nCells, 0.0);
        
        // ประมวลผลผิวหน้าทั้งหมดเพื่อสร้างเมทริกซ์
        forAll(mesh_.faces(), faceI)
        {
            if (!mesh_.isInternalFace(faceI)) continue;
            
            // รับข้อมูลคู่เซลล์
            label own = mesh_.owner()[faceI];
            label nei = mesh_.neighbour()[faceI];
            
            // เรขาคณิตผิวหน้า
            vector Sf = mesh_.Sf()[faceI];        // เวกเตอร์พื้นที่ผิวหน้า
            scalar d = mag(mesh_.C()[nei] - mesh_.C()[own]);  // ระยะห่างระหว่างเซลล์
            vector dVec = mesh_.C()[nei] - mesh_.C()[own];     // เวกเตอร์ระยะห่าง
            
            // แทรกค่าไปยังผิวหน้า
            scalar gamma_f = 0.5 * (diffusivity_[own] + diffusivity_[nei]);
            vector U_f = 0.5 * (velocity_[own] + velocity_[nei]);
            
            // เทอม convection
            scalar F = U_f & Sf;  // ปริมาณค่ามวลผ่านผิวหน้า
            
            // เทอม diffusion
            scalar D_f = gamma_f * mag(Sf) / d;  // คอนดักแตนซ์การแพร่
            
            // การแทรกค่า upwind สำหรับ convection
            scalar phi_face = (F > 0) ? phi_[own] : phi_[nei];
            
            // สัมประสิทธิ์เมทริกซ์
            scalar a_own = D_f - max(F, 0.0);
            scalar a_nei = D_f + max(F, 0.0);
            
            // อัปเดตสัมประสิทธิ์เมทริกซ์
            diagonal_[own] += D_f + max(F, 0.0);
            diagonal_[nei] += D_f - min(F, 0.0);
            
            // เพิ่มส่วนส่วนนอกเส้นแทยง
            addMatrixCoefficient(own, nei, -a_nei);
            addMatrixCoefficient(nei, own, -a_own);
        }
        
        // เพิ่มเทอมต้นทาง
        forAll(sourceTerm_, cellI)
        {
            sourceTerm_[cellI] *= mesh_.V()[cellI];  // คูณด้วยปริมาตรเซลล์
        }
    }
    
private:
    void addMatrixCoefficient(label row, label col, scalar value)
    {
        // หาสัมประสิทธิ์ที่มีอยู่หรือเพิ่มใหม่
        for (label i = 0; i < lowerAddr_.size(); i++)
        {
            if ((lowerAddr_[i] == row && upperAddr_[i] == col) ||
                (lowerAddr_[i] == col && upperAddr_[i] == row))
            {
                if (lowerAddr_[i] == row)
                {
                    lower_[i] += value;
                }
                else
                {
                    upper_[i] += value;
                }
                return;
            }
        }
        
        // เพิ่มสัมประสิทธิ์ใหม่
        if (row < col)
        {
            lowerAddr_.append(row);
            upperAddr_.append(col);
            lower_.append(value);
            upper_.append(0.0);
        }
        else
        {
            lowerAddr_.append(col);
            upperAddr_.append(row);
            lower_.append(0.0);
            upper_.append(value);
        }
    }
};
```

### อัลกอริทึมการผสานรวมความดัน-ความเร็ว

การผสานรวมความดัน-ความเร็วในการไหลแบบอัดไม่ได้ต้องการอัลกอริทึมที่ซับซ้อนซึ่งพึ่งพาการดำเนินการ `List` อย่างมาก:

#### ขั้นตอนอัลกอริทึม PISO

1. **ทำนายความเร็ว**: $\mathbf{u}^* = \mathbf{u}^n + \Delta t \cdot \mathbf{H}(\mathbf{u}^n) - \Delta t \cdot \nabla p^n/\rho$
2. **แก้สมการการแก้ไขความดัน**: $\nabla^2 p' = \rho/\Delta t \cdot \nabla \cdot \mathbf{u}^*$
3. **แก้ไขความดัน**: $p^{n+1} = p^n + p'$
4. **แก้ไขความเร็ว**: $\mathbf{u}^{n+1} = \mathbf{u}^* - \Delta t \cdot \nabla p'/\rho$

[Diagram: แผนภูมิการไหลของอัลกอริทึม PISO แสดง 4 ขั้นตอนหลัก]

```cpp
// การใช้งานอัลกอริทึม PISO โดยใช้คอนเทนเนอร์ List
class PISOAlgorithm
{
private:
    const fvMesh& mesh_;
    List<vector> velocity_;
    List<scalar> pressure_;
    List<scalar> pressureCorrection_;
    
    // ฟิลด์ชั่วคราวสำหรับการวนซ้ำ PISO
    List<vector> U_star_;         // ความเร็วที่ทำนาย
    List<vector> HbyA_;           // เทอม H/A
    List<scalar> rAU_;            // เทอมเส้นแทยง 1/A
    
    // สัมประสิทธิ์เมทริกซ์
    List<scalar> a_P_, a_N_;
    List<label> cellFaces_;
    List<vector> faceFluxes_;

public:
    // ดำเนินการลูปการแก้ไข PISO
    void performPICorrection(label nCorrectors)
    {
        Info << "Performing PISO pressure correction" << endl;
        
        for (label corr = 0; corr < nCorrectors; corr++)
        {
            Info << "  PISO corrector " << corr + 1 << endl;
            
            // ขั้นตอนที่ 1: คำนวณ U* = H/A - ∇p/A
            predictVelocity();
            
            // ขั้นตอนที่ 2: แก้สมการการแก้ไขความดัน
            solvePressureCorrection();
            
            // ขั้นตอนที่ 3: แก้ไขความดัน
            correctPressure();
            
            // ขั้นตอนที่ 4: แก้ไขความเร็ว
            correctVelocity();
            
            // ขั้นตอนที่ 5: แก้ไขปริมาณค่าผิวหน้า
            correctFaceFluxes();
            
            // ตรวจสอบการลู่เข้า
            if (checkConvergence())
            {
                Info << "  PISO converged after " << corr + 1 << " correctors" << endl;
                break;
            }
        }
    }

private:
    void predictVelocity()
    {
        // U* = H/A - ∇p/A (ทำให้ง่าย)
        U_star_.setSize(velocity_.size());
        HbyA_.setSize(velocity_.size());
        rAU_.setSize(pressure_.size());
        
        forAll(U_star_, cellI)
        {
            // การทำนายโมเมนตัมที่ทำให้ง่าย
            scalar volume = mesh_.V()[cellI];
            rAU_[cellI] = volume / a_P_[cellI];  // 1/A_P
            
            // คำนวณเทอม H/A (ทำให้ง่าย)
            vector H_A = vector::zero;
            const labelList& faces = mesh_.cells()[cellI];
            
            forAll(faces, faceI)
            {
                label faceID = faces[faceI];
                if (mesh_.isInternalFace(faceID))
                {
                    label neighbor = mesh_.neighbour()[faceID];
                    if (neighbor != cellI)
                    {
                        H_A += a_N_[faceI] * velocity_[neighbor];
                    }
                }
            }
            
            HbyA_[cellI] = rAU_[cellI] * H_A;
            
            // ทำนายความเร็ว
            U_star_[cellI] = HbyA_[cellI] - rAU_[cellI] * fvc::grad(pressure_)[cellI];
        }
    }
    
    void solvePressureCorrection()
    {
        // สร้างและแก้สมการการแก้ไขความดัน:
        // ∇·(rAU∇p') = ∇·U*
        
        pressureCorrection_.setSize(pressure_.size(), 0.0);
        
        // การแก้การแก้ไขความดันที่ทำให้ง่าย
        for (label iter = 0; iter < 50; iter++)
        {
            scalar residual = 0.0;
            
            forAll(pressureCorrection_, cellI)
            {
                // คำนวณการไหลเวียนของความเร็วที่ทำนาย
                scalar divU_star = computeDivergence(U_star_, cellI);
                
                // ตัวดำเนินการ Laplacian ที่ทำให้ง่าย
                scalar laplacian_p_prime = 0.0;
                const labelList& faces = mesh_.cells()[cellI];
                
                forAll(faces, faceI)
                {
                    label faceID = faces[faceI];
                    if (mesh_.isInternalFace(faceID))
                    {
                        label neighbor = mesh_.neighbour()[faceID];
                        if (neighbor != cellI)
                        {
                            scalar distance = mag(mesh_.C()[neighbor] - mesh_.C()[cellI]);
                            laplacian_p_prime += (pressureCorrection_[neighbor] - pressureCorrection_[cellI]) / (distance * distance);
                        }
                    }
                }
                
                // อัปเดตการแก้ไขความดัน (การวนซ้ำ Jacobi)
                scalar old_value = pressureCorrection_[cellI];
                pressureCorrection_[cellI] = divU_star / (laplacian_p_prime + 1e-10);
                
                residual += mag(pressureCorrection_[cellI] - old_value);
            }
            
            if (residual < 1e-6)
            {
                Info << "    Pressure correction converged in " << iter + 1 << " iterations" << endl;
                break;
            }
        }
    }
    
    void correctPressure()
    {
        // p = p + p'
        forAll(pressure_, cellI)
        {
            pressure_[cellI] += pressureCorrection_[cellI];
        }
    }
    
    void correctVelocity()
    {
        // U = U* - rAU∇p'
        forAll(velocity_, cellI)
        {
            vector grad_p_prime = fvc::grad(pressureCorrection_)[cellI];
            velocity_[cellI] = U_star_[cellI] - rAU_[cellI] * grad_p_prime;
        }
    }
    
    void correctFaceFluxes()
    {
        // φ = φ - rAU(∇p'·S_f)
        forAll(faceFluxes_, faceI)
        {
            if (mesh_.isInternalFace(faceI))
            {
                label own = mesh_.owner()[faceI];
                label nei = mesh_.neighbour()[faceI];
                
                vector Sf = mesh_.Sf()[faceI];
                vector grad_p_prime = (pressureCorrection_[nei] - pressureCorrection_[own]) * 
                                      (mesh_.C()[nei] - mesh_.C()[own]) / 
                                      magSqr(mesh_.C()[nei] - mesh_.C()[own]);
                
                scalar rAU_face = 0.5 * (rAU_[own] + rAU_[nei]);
                faceFluxes_[faceI] -= rAU_face * (grad_p_prime & Sf);
            }
        }
    }
    
    bool checkConvergence()
    {
        scalar velocityResidual = 0.0;
        scalar pressureResidual = 0.0;
        
        forAll(velocity_, cellI)
        {
            velocityResidual += magSqr(velocity_[cellI] - U_star_[cellI]);
        }
        
        forAll(pressureCorrection_, cellI)
        {
            pressureResidual += magSqr(pressureCorrection_[cellI]);
        }
        
        velocityResidual = sqrt(velocityResidual / velocity_.size());
        pressureResidual = sqrt(pressureResidual / pressureCorrection_.size());
        
        Info << "    Velocity residual: " << velocityResidual 
             << ", Pressure residual: " << pressureResidual << endl;
        
        return (velocityResidual < 1e-5 && pressureResidual < 1e-5);
    }
    
    scalar computeDivergence(const List<vector>& field, label cellI) const
    {
        scalar div = 0.0;
        const labelList& faces = mesh_.cells()[cellI];
        
        forAll(faces, faceI)
        {
            label faceID = faces[faceI];
            vector Sf = mesh_.Sf()[faceID];
            vector field_face = interpolateToFace(field, faceID);
            
            div += field_face & Sf;
        }
        
        return div / mesh_.V()[cellI];
    }
    
    vector interpolateToFace(const List<vector>& field, label faceID) const
    {
        if (mesh_.isInternalFace(faceID))
        {
            label own = mesh_.owner()[faceID];
            label nei = mesh_.neighbour()[faceID];
            return 0.5 * (field[own] + field[nei]);
        }
        else
        {
            label own = mesh_.boundaryMesh()[mesh_.boundary()[faceID].patchIndex()].faceCells()[0];
            return field[own];
        }
    }
};
```

### การผสานรวมหลายฟิสิกส์

คอนเทนเนอร์ `List` ช่วยให้การผสานรวมโมเดลฟิสิกส์หลายอย่างในการจำลองแบบ CFD ที่ซับซ้อนได้อย่างมีประสิทธิภาพ:

```cpp
// การผสานรวมหลายฟิสิกส์โดยใช้การดำเนินการ List ที่ซิงโครไนซ์
class MultiPhysicsCoupling
{
private:
    const fvMesh& mesh_;
    
    // ฟิลด์หลัก
    List<vector> velocity_;         // ฟิลด์ความเร็ว
    List<scalar> pressure_;         // ฟิลด์ความดัน
    List<scalar> temperature_;      // ฟิลด์อุณหภูมิ
    List<scalar> turbulenceKE_;     // พลังงานจลน์ความปั่นป่วน
    List<scalar> turbulenceEps_;    // การสลายตัวความปั่นป่วน
    
    // การขนส่งสาร
    List<List<scalar>> species_;    // ความเข้มข้นของสารหลายชนิด
    List<scalar> reactionRates_;    // อัตราปฏิกิริยาเคมี
    
    // การถ่ายเทความร้อน
    List<scalar> heatSource_;       // การผลิตความร้อนต่อปริมาตร
    List<vector> heatFlux_;         // เวกเตอร์ปริมาณค่าความร้อน
    
    // ส่วนผสมเฟสสำหรับการไหลหลายเฟส
    List<scalar> phaseFraction_;    // ส่วนผสมต่อปริมาตรของเฟสกระจาย

public:
    // แก้ระบบหลายฟิสิกส์ที่เชื่อมโยงกัน
    void solveCoupledSystem()
    {
        Info << "Solving coupled multi-physics system" << endl;
        
        // ลูปการผสานรวมแบบวนซ้ำ
        const label maxCouplingIterations = 10;
        scalar couplingTolerance = 1e-4;
        
        for (label couplingIter = 0; couplingIter < maxCouplingIterations; couplingIter++)
        {
            Info << "\nCoupling iteration " << couplingIter + 1 << endl;
            
            // เก็บค่าการวนซ้ำก่อนหน้าสำหรับการตรวจสอบการลู่เข้า
            List<vector> velocityOld = velocity_;
            List<scalar> temperatureOld = temperature_;
            List<scalar> turbulenceKEOld = turbulenceKE_;
            
            // ขั้นตอนที่ 1: แก้สมการโมเมนตัมพร้อมผลกระทบการลอยตัว
            solveMomentumWithBuoyancy();
            
            // ขั้นตอนที่ 2: แก้การผสานรวมความดัน-ความเร็ว
            solvePressureVelocityCoupling();
            
            // ขั้นตอนที่ 3: แก้สมการพลังงานพร้อมแหล่งความร้อน
            solveEnergyEquation();
            
            // ขั้นตอนที่ 4: อัปเดตโมเดลความปั่นป่วน
            updateTurbulenceModel();
            
            // ขั้นตอนที่ 5: แก้สมการการขนส่งสาร
            solveSpeciesTransport();
            
            // ขั้นตอนที่ 6: อัปเดตอัตราปฏิกิริยา (ขึ้นกับอุณหภูมิ)
            updateReactionRates();
            
            // ขั้นตอนที่ 7: อัปเดตส่วนผสมเฟสสำหรับผลกระทบหลายเฟส
            updatePhaseFractions();
            
            // ตรวจสอบการลู่เข้าของการผสานรวม
            scalar velocityResidual = computeFieldResidual(velocity_, velocityOld);
            scalar temperatureResidual = computeFieldResidual(temperature_, temperatureOld);
            scalar turbulenceResidual = computeFieldResidual(turbulenceKE_, turbulenceKEOld);
            
            Info << "  Velocity residual: " << velocityResidual << endl;
            Info << "  Temperature residual: " << temperatureResidual << endl;
            Info << "  Turbulence residual: " << turbulenceResidual << endl;
            
            if (max(velocityResidual, max(temperatureResidual, turbulenceResidual)) < couplingTolerance)
            {
                Info << "Multi-physics coupling converged after " << couplingIter + 1 << " iterations" << endl;
                break;
            }
            
            if (couplingIter == maxCouplingIterations - 1)
            {
                Warning << "Multi-physics coupling failed to converge" << endl;
            }
        }
    }

private:
    void solveMomentumWithBuoyancy()
    {
        // สมการโมเมนตัมพร้อมเทอมต้นทางการลอยตัว:
        // ρ(∂u/∂t + u·∇u) = -∇p + μ∇²u + ρg + F_buoyancy
        
        List<vector> momentumResidual(velocity_.size());
        
        forAll(velocity_, cellI)
        {
            scalar rho = computeDensity(cellI);
            scalar mu = computeViscosity(cellI);
            vector g = computeGravityVector(cellI);
            
            // แรงลอยตัว: F_b = (ρ_ref - ρ)g
            vector buoyancyForce = (1.2 - rho) * g;  // ρ_ref = 1.2 kg/m³ สำหรับอากาศ
            
            // การอัปเดตสมการโมเมนตัมที่ทำให้ง่าย
            vector convectionTerm = computeConvectionTerm(cellI);
            vector diffusionTerm = computeDiffusionTerm(cellI);
            vector pressureGradient = computePressureGradient(cellI);
            
            // อัปเดตความเร็วโดยใช้การขยับเวลาแบบชัดเจน
            velocity_[cellI] = velocity_[cellI] + 
                0.001 * (buoyancyForce - convectionTerm - pressureGradient + diffusionTerm) / rho;
        }
    }
    
    void solveEnergyEquation()
    {
        // สมการพลังงานพร้อมคุณสมบัติแปรผัน:
        // ρc_p(∂T/∂t + u·∇T) = ∇·(k∇T) + Q_reaction + Q_viscous
        
        forAll(temperature_, cellI)
        {
            scalar rho = computeDensity(cellI);
            scalar cp = computeSpecificHeat(cellI);
            scalar k = computeThermalConductivity(cellI);
            
            // แหล่งความร้อนจากปฏิกิริยาเคมี
            scalar reactionHeat = computeReactionHeatSource(cellI);
            
            // การสลายตัวแบบหนืด
            scalar viscousHeat = computeViscousDissipation(cellI);
            
            // แหล่งความร้อนทั้งหมด
            scalar Q_total = reactionHeat + viscousHeat;
            
            // การอัปเดตสมการพลังงานที่ทำให้ง่าย
            scalar convectionTerm = computeTemperatureConvection(cellI);
            scalar diffusionTerm = computeTemperatureDiffusion(cellI);
            
            temperature_[cellI] = temperature_[cellI] + 
                0.001 * (Q_total - convectionTerm + diffusionTerm) / (rho * cp);
        }
    }
    
    void updateTurbulenceModel()
    {
        // สมการโมเดลความปั่นป่วน k-ε มาตรฐาน
        
        forAll(turbulenceKE_, cellI)
        {
            scalar rho = computeDensity(cellI);
            vector U = velocity_[cellI];
            scalar k = turbulenceKE_[cellI];
            scalar epsilon = turbulenceEps_[cellI];
            
            // ความหนืดความปั่นป่วน
            scalar mu_t = 0.09 * rho * k * k / max(epsilon, 1e-10);
            
            // การผลิตของพลังงานจลน์ความปั่นป่วน
            scalar P_k = computeTurbulentProduction(cellI, mu_t);
            
            // การสลายตัวของพลังงานจลน์ความปั่นป่วน
            scalar D_k = epsilon;
            
            // สมการ k: ∂k/∂t + u·∇k = P_k - D_k + ∇·[(μ + μ_t/σ_k)∇k]
            turbulenceKE_[cellI] = k + 0.001 * (P_k - D_k) / rho;
            
            // สมการ ε: ∂ε/∂t + u·∇ε = C_ε1(P_k)ε/k - C_ε2ε²/k + ∇·[(μ + μ_t/σ_ε)∇ε]
            turbulenceEps_[cellI] = epsilon + 0.001 * (1.44 * P_k * epsilon / max(k, 1e-10) - 1.92 * epsilon * epsilon / max(k, 1e-10)) / rho;
            
            // ทำให้แน่ใจว่าเป็นค่าบวก
            turbulenceKE_[cellI] = max(turbulenceKE_[cellI], 1e-10);
            turbulenceEps_[cellI] = max(turbulenceEps_[cellI], 1e-10);
        }
    }
    
    void solveSpeciesTransport()
    {
        // สมการการขนส่งสาร:
        // ∂Y_i/∂t + u·∇Y_i = ∇·(D_i∇Y_i) + ω_i
        
        for (label species = 0; species < species_.size(); species++)
        {
            forAll(species_[species], cellI)
            {
                scalar D_i = computeSpeciesDiffusivity(species, cellI);
                scalar omega_i = reactionRates_[cellI];  // อัตราการผลิต
                
                scalar convectionTerm = computeSpeciesConvection(species, cellI);
                scalar diffusionTerm = computeSpeciesDiffusion(species, cellI, D_i);
                
                species_[species][cellI] = species_[species][cellI] + 
                    0.001 * (omega_i - convectionTerm + diffusionTerm);
                
                // ทำให้แน่ใจว่าขอบเขตทางกายภาพ
                species_[species][cellI] = max(0.0, min(1.0, species_[species][cellI]));
            }
        }
    }
    
    void updateReactionRates()
    {
        // อัตราปฏิกิริยา Arrhenius: ω = A * T^β * exp(-E_a/RT) * ∏Y_i^ν_i
        
        forAll(reactionRates_, cellI)
        {
            scalar T = temperature_[cellI];
            scalar A = 1e10;      // ปัจจัยก่อนเลขชี้กำลัง
            scalar beta = 0.5;     // เลขชี้กำลังอุณหภูมิ
            scalar E_a = 50000;    // พลังงานกระตุ้น [J/mol]
            scalar R = 8.314;      // ค่าคงที่ก๊าซสากล [J/(mol·K)]
            
            // อัตราที่ขึ้นกับอุณหภูมิ
            scalar rate_constant = A * pow(T, beta) * exp(-E_a / (R * T));
            
            // เทอมที่ขึ้นกับความเข้มข้น
            scalar concentration_term = 1.0;
            for (label i = 0; i < species_.size(); i++)
            {
                concentration_term *= pow(species_[i][cellI], 1.0);  // ปฏิกิริยาอันดับหนึ่ง
            }
            
            reactionRates_[cellI] = rate_constant * concentration_term;
        }
    }
    
    void updatePhaseFractions()
    {
        // วิธีปริมาตรของของไหล (VOF) สำหรับการขนส่งส่วนผสมเฟส:
        // ∂α/∂t + ∇·(αu) = 0
        
        forAll(phaseFraction_, cellI)
        {
            scalar convectionTerm = computePhaseFractionConvection(cellI);
            scalar diffusionTerm = computePhaseFractionDiffusion(cellI);
            
            phaseFraction_[cellI] = phaseFraction_[cellI] + 
                0.001 * (-convectionTerm + diffusionTerm);
            
            // ทำให้แน่ใจว่าขอบเขตทางกายภาพ
            phaseFraction_[cellI] = max(0.0, min(1.0, phaseFraction_[cellI]));
        }
    }
    
    // วิธีการช่วยสำหรับการคำนวณเทอมต่างๆ
    scalar computeDensity(label cellI) const
    {
        // กฎของก๊าซอุดมคติ: ρ = pM/(RT)
        scalar p = pressure_[cellI];
        scalar T = temperature_[cellI];
        scalar M = 0.029;      // มวลโมลของอากาศ [kg/mol]
        scalar R = 8.314;      // ค่าคงที่ก๊าซสากล
        
        return p * M / (R * T);
    }
    
    scalar computeViscosity(label cellI) const
    {
        // กฎของ Sutherland สำหรับความหนืดที่ขึ้นกับอุณหภูมิ
        scalar T = temperature_[cellI];
        scalar mu_ref = 1.716e-5;    // ความหนืดอ้างอิง [Pa·s]
        scalar T_ref = 273.15;       // อุณหภูมิอ้างอิง [K]
        scalar S = 110.4;            // ค่าคงที่ Sutherland [K]
        
        return mu_ref * pow(T / T_ref, 1.5) * (T_ref + S) / (T + S);
    }
    
    scalar computeSpecificHeat(label cellI) const
    {
        // ความจุความร้อนที่ขึ้นกับอุณหภูมิสำหรับอากาศ
        scalar T = temperature_[cellI];
        return 1005.0 + 0.1 * T;  // สหสัมพันธ์ที่ทำให้ง่าย [J/(kg·K)]
    }
    
    scalar computeThermalConductivity(label cellI) const
    {
        // สัมประสิทธิ์การนำความร้อนที่ขึ้นกับอุณหภูมิ
        scalar T = temperature_[cellI];
        return 0.024 + 0.0001 * T;  // สหสัมพันธ์ที่ทำให้ง่าย [W/(m·K)]
    }
    
    vector computeGravityVector(label cellI) const
    {
        // เวกเตอร์ความโน้มถ่วง (อาจแตกต่างกับความสูง)
        scalar z = mesh_.C()[cellI].z();
        return vector(0, 0, -9.81);  // ความโน้มถ่วงมาตรฐาน [m/s²]
    }
    
    vector computeConvectionTerm(label cellI) const
    {
        // คำนวณเทอมพาพา u·∇u
        return vector::zero;  // การใช้งานที่ทำให้ง่าย
    }
    
    vector computeDiffusionTerm(label cellI) const
    {
        // คำนวณเทอมการแพร่ตัวหนืด μ∇²u
        return vector::zero;  // การใช้งานที่ทำให้ง่าย
    }
    
    vector computePressureGradient(label cellI) const
    {
        // คำนวณไลเกรเดียนความดัน ∇p
        return vector::zero;  // การใช้งานที่ทำให้ง่าย
    }
    
    scalar computeReactionHeatSource(label cellI) const
    {
        // ความร้อนที่ปลดปล่อย/ดูดซับโดยปฏิกิริยาเคมี
        return -1000.0 * reactionRates_[cellI];  // ปฏิกิริยา exothermic ที่ทำให้ง่าย
    }
    
    scalar computeViscousDissipation(label cellI) const
    {
        // ความร้อนที่เกิดจากการสลายตัวแบบหนืด: Φ = μ(∇u + ∇u^T):∇u
        return 1e-6 * magSqr(computeConvectionTerm(cellI));  // ทำให้ง่าย
    }
    
    scalar computeTemperatureConvection(label cellI) const
    {
        // คำนวณเทอมพาพาในสมการพลังงาน: u·∇T
        return 0.0;  // การใช้งานที่ทำให้ง่าย
    }
    
    scalar computeTemperatureDiffusion(label cellI) const
    {
        // คำนวณเทอมการแพร่ตัวในสมการพลังงาน: ∇·(k∇T)
        return 0.0;  // การใช้งานที่ทำให้ง่าย
    }
    
    scalar computeTurbulentProduction(label cellI, scalar mu_t) const
    {
        // การผลิตของพลังงานจลน์ความปั่นป่วน: P_k = μ_t(∇u + ∇u^T):∇u
        return 0.1 * mu_t * magSqr(computeConvectionTerm(cellI));  // ทำให้ง่าย
    }
    
    scalar computeSpeciesConvection(label species, label cellI) const
    {
        // คำนวณเทอมพาพาสำหรับการขนส่งสาร
        return 0.0;  // การใช้งานที่ทำให้ง่าย
    }
    
    scalar computeSpeciesDiffusion(label species, label cellI, scalar D_i) const
    {
        // คำนวณเทอมการแพร่ตัวสำหรับการขนส่งสาร
        return 0.0;  // การใช้งานที่ทำให้ง่าย
    }
    
    scalar computeSpeciesDiffusivity(label species, label cellI) const
    {
        // สัมประสิทธิ์การแพร่ตัวที่ขึ้นกับอุณหภูมิและความดัน
        scalar T = temperature_[cellI];
        scalar p = pressure_[cellI];
        return 1e-5 * pow(T / 273.15, 1.5) * (101325.0 / p);  // ทำให้ง่าย
    }
    
    scalar computePhaseFractionConvection(label cellI) const
    {
        // คำนวณเทอมพาพาสำหรับสมการ VOF
        return 0.0;  // การใช้งานที่ทำให้ง่าย
    }
    
    scalar computePhaseFractionDiffusion(label cellI) const
    {
        // คำนวณเทอมการบีบอัดสำหรับสมการ VOF
        return 0.0;  // การใช้งานที่ทำให้ง่าย
    }
    
    template<class Type>
    scalar computeFieldResidual(const List<Type>& field1, const List<Type>& field2) const
    {
        scalar residual = 0.0;
        forAll(field1, i)
        {
            residual += magSqr(field1[i] - field2[i]);
        }
        return sqrt(residual / field1.size());
    }
};
```

## 📊 การวิเคราะห์และการปรับให้เหมาะสมด้านประสิทธิภาพ

### การวิเคราะห์ประสิทธิภาพแคช

ประสิทธิภาพของการดำเนินการ `List` ในการจำลองแบบ CFD ได้รับอิทธิพลอย่างมากจากการใช้แคช การใช้งาน `List` ของ OpenFOAM ได้รับการออกแบบมาเพื่อเพิ่มประสิทธิภาพแคชสูงสุดผ่านการจัดสรรหน่วยความจำต่อเนื่องและรูปแบบการเข้าถึงที่ปรับให้เหมาะสมสำหรับอัลกอริทึมเชิงตัวเลข:

#### ความสัมพันธ์ขนาดบล็อกแคช

| ขนาดบล็อค | ความเหมาะสมสำหรับ | ประสิทธิภาพแคช | การใช้งาน |
|-------------|-------------------|----------------|----------|
| 16-32 องค์ประกอบ | เมชเล็ก | สูงมาก | การประมวลผลคู่ |
| 64-128 องค์ประกอบ | เมชขนาดกลาง | สูง | การใช้งานทั่วไป |
| 256+ องค์ประกอบ | เมชใหญ่ | ปานกลาง | การคำนวณเชิงซ้อน |

```cpp
// การวิเคราะห์และการปรับให้เหมาะสมด้านประสิทธิภาพแคช
class CacheOptimizedOperations
{
private:
    static constexpr size_t L1_CACHE_SIZE = 32 * 1024;     // แคช L1 32 KB
    static constexpr size_t L2_CACHE_SIZE = 256 * 1024;    // แคช L2 256 KB
    static constexpr size_t L3_CACHE_SIZE = 8 * 1024 * 1024; // แคช L3 8 MB
    
    static constexpr size_t CACHE_LINE_SIZE = 64;          // แคชไลน์ 64 ไบต์

public:
    // การประมวลผลบล็อกที่ตระหนักถึงแคช
    template<class Type>
    static void cacheAwareProcessing(List<Type>& result, const List<Type>& input1, const List<Type>& input2)
    {
        const label n = result.size();
        
        // คำนวณขนาดบล็อกที่เหมาะสมที่สุดตามลำดับชั้นแคช
        const size_t elementSize = sizeof(Type);
        const size_t cacheLineElements = CACHE_LINE_SIZE / elementSize;
        
        // ประมวลผลบล็อกที่พอดีกับแคช L1
        const label blockSize = min(n, static_cast<label>(L1_CACHE_SIZE / (3 * elementSize)));
        
        for (label blockStart = 0; blockStart < n; blockStart += blockSize)
        {
            label blockEnd = min(blockStart + blockSize, n);
            
            // Prefetch บล็อกถัดไปลงในแคช
            if (blockEnd + blockSize <= n)
            {
                __builtin_prefetch(&input1[blockEnd], 0, 3);
                __builtin_prefetch(&input2[blockEnd], 0, 3);
                __builtin_prefetch(&result[blockEnd], 1, 3);
            }
            
            // ประมวลผลบล็อกปัจจุบัน
            for (label i = blockStart; i < blockEnd; i++)
            {
                result[i] = input1[i] + input2[i];  // ตัวอย่างการดำเนินการ
            }
        }
    }
    
    // การดำเนินการแบบเวกเตอร์พร้อมการจัดแนวหน่วยความจำ
    template<class Type>
    static void vectorizedOperation(List<Type>& result, const List<Type>& operand, Type scalar)
    {
        // ทำให้มั่นใจว่าการจัดแนวหน่วยความจำสำหรับการดำเนินการ SIMD
        static_assert(std::is_trivially_copyable<Type>::value, "Type must be SIMD-compatible");
        
        const label n = result.size();
        const label vectorizedEnd = n - (n % 8);  // ประมวลผลเป็นกลุ่มของ 8
        
        // ลูปแบบเวกเตอร์โดยใช้ AVX
        for (label i = 0; i < vectorizedEnd; i += 8)
        {
            __m256 vecOperand = _mm256_load_ps(&operand[i]);
            __m256 vecScalar = _mm256_set1_ps(scalar);
            __m256 vecResult = _mm256_mul_ps(vecOperand, vecScalar);
            _mm256_store_ps(&result[i], vecResult);
        }
        
        // จัดการกับองค์ประกอบที่เหลือ
        for (label i = vectorizedEnd; i < n; i++)
        {
            result[i] = operand[i] * scalar;
        }
    }
    
    // การปรับให้เหมาะสมของแบนด์วิดท์หน่วยความจำ
    static void optimizeMemoryBandwidth()
    {
        // ทดสอบแบนด์วิดท์หน่วยความจำกับรูปแบบการเข้าถึงต่างๆ
        const label n = 1000000;
        List<scalar> data(n);
        List<scalar> result(n);
        
        // การเข้าถึงตามลำดับ (เป็นมิตรกับแคช)
        auto start = std::chrono::high_resolution_clock::now();
        
        for (label i = 0; i < n; i++)
        {
            result[i] = data[i] * 2.0;
        }
        
        auto sequentialTime = std::chrono::high_resolution_clock::now() - start;
        
        // การเข้าถึงแบบสุ่ม (ไม่เป็นมิตรกับแคช)
        List<label> indices(n);
        for (label i = 0; i < n; i++)
        {
            indices[i] = (i * 7919) % n;  // การสับเปลี่ยนเทียมสุ่ม
        }
        
        start = std::chrono::high_resolution_clock::now();
        
        for (label i = 0; i < n; i++)
        {
            label idx = indices[i];
            result[idx] = data[idx] * 2.0;
        }
        
        auto randomTime = std::chrono::high_resolution_clock::now() - start;
        
        Info << "Sequential access time: " 
             << std::chrono::duration<double>(sequentialTime).count() << " seconds" << endl;
        Info << "Random access time: " 
             << std::chrono::duration<double>(randomTime).count() << " seconds" << endl;
        Info << "Performance ratio: " 
             << std::chrono::duration<double>(randomTime).count() / 
                std::chrono::duration<double>(sequentialTime).count() << "x" << endl;
    }
};
```

### การปรับให้เหมาะสมด้านการประมวลผลขนาน

คอนเทนเนอร์ `List` ของ OpenFOAM ผสานรวมกับเฟรมเวิร์กการประมวลผลขนานสำหรับระบบหน่วยความจำแบบกระจายได้อย่างราบรื่น:

#### ประสิทธิภาพการประมวลผลขนาน

| จำนวนโปรเซสเซอร์ | ประสิทธิภาพ | Overhead | การใช้งานที่เหมาะสม |
|-------------------|-----------|----------|----------------|
| 2-4 | 80-90% | ต่ำ | การจำลองขนาดเล็ก-กลาง |
| 8-16 | 70-85% | ปานกลาง | การจำลองขนาดกลาง |
| 32+ | 50-70% | สูง | การจำลองขนาดใหญ่ |

```cpp
// การปรับให้เหมาะสมด้านการประมวลผลขนานสำหรับการดำเนินการ List
class ParallelListOperations
{
private:
    const fvMesh& mesh_;
    const Pstream::commsTypes communicationType_;

public:
    // การดำเนินการลดค่าฟิลด์แบบขนาน
    template<class Type>
    Type parallelFieldReduction(const List<Type>& field, const std::function<Type(const Type&, const Type&)>& operation, Type identity) const
    {
        // การลดค่าในเครื่อง
        Type localResult = identity;
        forAll(field, i)
        {
            localResult = operation(localResult, field[i]);
        }
        
        // การลดค่าทั่วโลกข้ามโปรเซสเซอร์ทั้งหมด
        Type globalResult = localResult;
        reduce(globalResult, operationOp<Operation>());  // MPI reduction ของ OpenFOAM
        
        return globalResult;
    }
    
    // การทำให้ฟิลด์เป็นบรรทัดฐานแบบขนาน
    List<scalar> parallelFieldNormalization(const List<scalar>& field) const
    {
        // คำนวณค่าน้อยที่สุดและมากที่สุดทั่วโลก
        scalar localMin = min(field);
        scalar localMax = max(field);
        
        scalar globalMin = localMin;
        scalar globalMax = localMax;
        
        reduce(globalMin, minOp<scalar>());
        reduce(globalMax, maxOp<scalar>());
        
        // ทำให้ฟิลด์เป็นบรรทัดฐาน
        List<scalar> normalized(field.size());
        scalar range = globalMax - globalMin;
        
        if (range > 1e-10)
        {
            forAll(normalized, i)
            {
                normalized[i] = (field[i] - globalMin) / range;
            }
        }
        else
        {
            normalized = field;  // ไม่ทำการทำให้เป็นบรรทัดฐานถ้าช่วงเล็กเกินไป
        }
        
        return normalized;
    }
    
    // การซิงโครไนซ์เงื่อนไขขอบเขตแบบขนาน
    void synchronizeBoundaryConditions(List<scalar>& field) const
    {
        // ซิงโครไนซ์ขอบเขตโปรเซสเซอร์
        const fvPatchList& patches = mesh_.boundary();
        
        forAll(patches, patchI)
        {
            if (isA<processorFvPatch>(patches[patchI]))
            {
                const processorFvPatch& procPatch = 
                    refCast<const processorFvPatch>(patches[patchI]);
                
                if (procPatch.neighbour())
                {
                    // ส่งข้อมูลไปยังโปรเซสเซอร์ข้างเคียง
                    const labelList& faceCells = procPatch.faceCells();
                    List<scalar> sendData(faceCells.size());
                    
                    forAll(faceCells, i)
                    {
                        sendData[i] = field[faceCells[i]];
                    }
                    
                    // การสื่อสารแบบ non-blocking
                    OPstream toNeighbour(Pstream::commsTypes::nonBlocking, 
                                        procPatch.neighbProcNo());
                    toNeighbour << sendData;
                    
                    // รับข้อมูลจากโปรเซสเซอร์ข้างเคียง
                    IPstream fromNeighbour(Pstream::commsTypes::nonBlocking, 
                                          procPatch.neighbProcNo());
                    List<scalar> recvData;
                    fromNeighbour >> recvData;
                    
                    // ใช้ค่าขอบเขตที่ได้รับ
                    forAll(recvData, i)
                    {
                        field[faceCells[i]] = recvData[i];
                    }
                }
            }
        }
        
        // ซิงโครไนซ์โปรเซสเซอร์ทั้งหมด
        Pstream::scatter(field);
    }
    
    // การคูณเมทริกซ์-เวกเตอร์แบบขนานที่ปรับให้เหมาะสมสำหรับเมทริกซ์ CFD
    List<scalar> parallelMatrixVectorMultiply(const lduMatrix& matrix, const List<scalar>& x) const
    {
        List<scalar> result(x.size(), 0.0);
        
        // การคูณเมทริกซ์-เวกเตอร์ในเครื่อง
        const scalarField& diag = matrix.diag();
        const scalarField& upper = matrix.upper();
        const scalarField& lower = matrix.lower();
        const labelList& upperAddr = matrix.lduAddr().upperAddr();
        const labelList& lowerAddr = matrix.lduAddr().lowerAddr();
        
        // ส่วนส่วนของเส้นแทยง
        forAll(result, i)
        {
            result[i] = diag[i] * x[i];
        }
        
        // ส่วนส่วนนอกเส้นแทยง
        forAll(upper, faceI)
        {
            label own = upperAddr[faceI];
            label nei = lowerAddr[faceI];
            
            result[own] += upper[faceI] * x[nei];
            result[nei] += lower[faceI] * x[own];
        }
        
        // จัดการกับส่วนส่วนขอบเขตโปรเซสเซอร์
        handleProcessorBoundaries(matrix, result, x);
        
        return result;
    }

private:
    void handleProcessorBoundaries(const lduMatrix& matrix, List<scalar>& result, const List<scalar>& x) const
    {
        // การจัดการขอบเขตโปรเซสเซอร์ที่ทำให้ง่าย
        const lduInterfaceFieldPtrsList& interfaces = matrix.interfaces();
        
        forAll(interfaces, interfaceI)
        {
            if (interfaces.set(interfaceI))
            {
                const lduInterface& interface = interfaces[interfaceI].interface();
                
                if (isA<processorLduInterface>(interface))
                {
                    const processorLduInterface& procInterface = 
                        refCast<const processorLduInterface>(interface);
                    
                    // แลกเปลี่ยนข้อมูลอินเทอร์เฟซ
                    scalarField interfaceData = interface.interfaceField(x);
                    
                    // เพิ่มส่วนส่วนอินเทอร์เฟซไปยังผลลัพธ์
                    const labelList& faceCells = interface.faceCells();
                    forAll(faceCells, i)
                    {
                        result[faceCells[i]] += interfaceData[i];
                    }
                }
            }
        }
    }
};
```

### การวิเคราะห์การใช้หน่วยความจำ

การทำความเข้าใจรูปแบบการใช้หน่วยความจำเป็นสิ่งจำเป็นสำหรับการปรับให้เหมาะสมการจำลองแบบ CFD ขนาดใหญ่:

#### สถิติการใช้หน่วยความจำ

| การจำลองแบบ | เมช | ปริมาณฟิลด์ | หน่วยความจำ | ประสิทธิภาพ |
|--------------|------|-------------|-----------|-----------|
| Lid-driven cavity | 50×50 | 3-5 | < 100 MB | สูง |
| Backward-facing step | 200×100 | 5-8 | 500 MB - 1 GB | ปานกลาง |
| Turbulent pipe flow | 1000×200 | 8-12 | 2-5 GB | ต่ำ |
| DNS turbulence | 512³ | 10-15 | > 50 GB | ต่ำมาก |

```cpp
// การวิเคราะห์และการปรับให้เหมาะสมการใช้หน่วยความจำ
class MemoryProfiler
{
private:
    struct MemoryStats
    {
        size_t totalAllocated;
        size_t peakUsage;
        size_t fragmentation;
        size_t cacheMisses;
        double allocationTime;
        double accessTime;
    };
    
    MemoryStats stats_;
    std::chrono::high_resolution_clock::time_point startTime_;

public:
    MemoryProfiler() : stats_{0, 0, 0, 0, 0.0, 0.0}
    {
        startTime_ = std::chrono::high_resolution_clock::now();
    }
    
    // วิเคราะห์รูปแบบการจัดสรรหน่วยความจำ
    template<class Type>
    void profileAllocation(const List<Type>& list, const std::string& description)
    {
        auto start = std::chrono::high_resolution_clock::now();
        
        size_t memoryUsage = list.size() * sizeof(Type);
        stats_.totalAllocated += memoryUsage;
        stats_.peakUsage = max(stats_.peakUsage, memoryUsage);
        
        auto end = std::chrono::high_resolution_clock::now();
        stats_.allocationTime += 
            std::chrono::duration<double>(end - start).count();
        
        Info << "Memory allocation for " << description << ":" << endl;
        Info << "  Elements: " << list.size() << endl;
        Info << "  Memory usage: " << memoryUsage / (1024.0 * 1024.0) << " MB" << endl;
        Info << "  Total allocated: " << stats_.totalAllocated / (1024.0 * 1024.0) << " MB" << endl;
        Info << "  Peak usage: " << stats_.peakUsage / (1024.0 * 1024.0) << " MB" << endl;
    }
    
    // วิเคราะห์รูปแบบการเข้าถึงหน่วยความจำ
    template<class Type>
    void profileAccessPatterns(const List<Type>& list, const std::string& pattern)
    {
        auto start = std::chrono::high_resolution_clock::now();
        
        if (pattern == "sequential")
        {
            // รูปแบบการเข้าถึงตามลำดับ
            forAll(list, i)
            {
                volatile Type value = list[i];  // ป้องกันการปรับให้เหมาะสม
                (void)value;  // ระงับคำเตือนตัวแปรที่ไม่ได้ใช้
            }
        }
        else if (pattern == "random")
        {
            // รูปแบบการเข้าถึงแบบสุ่ม
            List<label> indices(list.size());
            forAll(indices, i)
            {
                indices[i] = (i * 7919) % list.size();  // การสับเปลี่ยนเทียมสุ่ม
            }
            
            forAll(indices, i)
            {
                volatile Type value = list[indices[i]];
                (void)value;
            }
        }
        else if (pattern == "strided")
        {
            // รูปแบบการเข้าถึงแบบ strided
            const label stride = 16;
            for (label i = 0; i < list.size(); i += stride)
            {
                volatile Type value = list[i];
                (void)value;
            }
        }
        
        auto end = std::chrono::high_resolution_clock::now();
        stats_.accessTime += 
            std::chrono::duration<double>(end - start).count();
        
        Info << "Access pattern '" << pattern << "' completed in " 
             << std::chrono::duration<double>(end - start).count() << " seconds" << endl;
    }
    
    // วิเคราะห์การแตกส่วนของหน่วยความจำ
    template<class Type>
    void analyzeFragmentation(const List<List<Type>>& nestedList)
    {
        size_t totalElements = 0;
        size_t totalMemory = 0;
        size_t overhead = 0;
        
        forAll(nestedList, i)
        {
            const List<Type>& innerList = nestedList[i];
            totalElements += innerList.size();
            totalMemory += innerList.capacity() * sizeof(Type);
            overhead += sizeof(List<Type>);
        }
        
        if (totalMemory > 0)
        {
            stats_.fragmentation = totalMemory - (totalElements * sizeof(Type));
        }
        
        Info << "Memory fragmentation analysis:" << endl;
        Info << "  Total elements: " << totalElements << endl;
        Info << "  Total allocated memory: " << totalMemory / (1024.0 * 1024.0) << " MB" << endl;
        Info << "  Used memory: " << (totalElements * sizeof(Type)) / (1024.0 * 1024.0) << " MB" << endl;
        Info << "  Fragmentation: " << stats_.fragmentation / (1024.0 * 1024.0) << " MB" << endl;
        Info << "  Container overhead: " << overhead / (1024.0) << " KB" << endl;
        Info << "  Fragmentation ratio: " 
             << (double)stats_.fragmentation / totalMemory * 100.0 << "%" << endl;
    }
    
    // ปรับโครงสร้างหน่วยความจำให้เหมาะสมสำหรับประสิทธิภาพแคชที่ดีขึ้น
    template<class Type>
    List<Type> optimizeMemoryLayout(const List<List<Type>>& nestedList)
    {
        // นับองค์ประกอบทั้งหมด
        label totalElements = 0;
        forAll(nestedList, i)
        {
            totalElements += nestedList[i].size();
        }
        
        // สร้างการจัดเก็บต่อเนื่อง
        List<Type> flatList(totalElements);
        label offset = 0;
        
        forAll(nestedList, i)
        {
            const List<Type>& innerList = nestedList[i];
