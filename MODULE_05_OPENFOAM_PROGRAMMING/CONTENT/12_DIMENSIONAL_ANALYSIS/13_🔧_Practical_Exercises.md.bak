## แบบฝึกปฏิบัติที่ 3: Solver ไร้มิติ (Non-Dimensional Solver)

### **พื้นฐานทฤษฎี**
สำหรับการไหลแบบไม่บีบอัด สมการควบคุมสามารถทำให้ไร้มิติได้โดยใช้สเกลลักษณะเฉพาะ:

**สมการความต่อเนื่อง:**
$$\nabla \cdot \mathbf{u}^* = 0$$

**สมการโมเมนตัม:**
$$\frac{\partial \mathbf{u}^*}{\partial t^*} + (\mathbf{u}^* \cdot \nabla^*) \mathbf{u}^* = -\nabla^* p^* + \frac{1}{Re} \nabla^{*2} \mathbf{u}^*$$

โดยที่:
- $\mathbf{u}^* = \mathbf{u}/U_{ref}$ (ความเร็วไร้มิติ)
- $p^* = p/(\rho U_{ref}^2)$ (ความดันไร้มิติ)
- $t^* = t U_{ref}/L_{ref}$ (เวลาไร้มิติ)
- $Re = \frac{\rho U_{ref} L_{ref}}{\mu}$ (จำนวนเรย์โนลด์)

[Diagram: การเปลี่ยนแปลงตัวแปรมิติเป็นตัวแปรไร้มิติใน CFD]

### **ขั้นตอนการทำให้ไร้มิติ**
1. **เลือกสเกลอ้างอิง**: $U_{ref}$, $L_{ref}$, $\rho$, $\mu$
2. **กำหนดจำนวนไร้มิติ**: $Re$, $Fr$, $We$ เป็นต้น
3. **ทำให้สมการไร้มิติ**: แทนค่าตัวแปรจริงด้วยตัวแปรไร้มิติ
4. **ปรับขอบเขต**: เปลี่ยนเงื่อนไขขอบเขตเป็นรูปแบบไร้มิติ

### **โครงสร้าง Solver ที่แก้ไข**
```cpp
// icoFoamNonDim.C
#include "fvCFD.H"
#include "pimpleControl.H"

int main(int argc, char *argv[])
{
    #include "setRootCase.H"
    #include "createTime.H"
    #include "createMesh.H"
    #include "createControl.H"
    #include "createFields.H"
    #include "initContinuityErrs.H"

    // อ่านพารามิเตอร์ไร้มิติ
    const scalar Re = readScalar(mesh.lookupObject<dictionary>("transportProperties").lookup("Re"));
    const dimensionedScalar Uref(mesh.lookupObject<dictionary>("transportProperties").lookup("Uref"));
    const dimensionedScalar Lref(mesh.lookupObject<dictionary>("transportProperties").lookup("Lref"));

    // * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

    Info<< "\nStarting time loop\n" << endl;

    while (runTime.loop())
    {
        Info<< "Time = " << runTime.timeName() << nl << endl;

        #include "CourantNo.H"
        #include "UEqn.H"

        // --- PISO loop
        while (pimple.correct())
        {
            #include "pEqn.H"
        }

        runTime.write();
    }

    Info<< "End\n" << endl;

    return 0;
}
```

### **OpenFOAM Code Implementation: สมการโมเมนตัมไร้มิติ**
```cpp
// UEqn.H - แก้ไขสำหรับรูปแบบไร้มิติ
{
    // สมการโมเมนตัม (ไร้มิติ)
    fvVectorMatrix UEqn
    (
        fvm::ddt(U)
      + fvm::div(phi, U)
      - fvm::laplacian(1.0/Re, U)  // 1/Re แทนความหนืดลักษณะ
    );

    UEqn.relax();

    if (pimple.momentumPredictor())
    {
        solve(UEqn == -fvc::grad(p));
    }
}
```

### **OpenFOAM Code Implementation: สมการความดันไร้มิติ**
```cpp
// pEqn.H - แก้ไขสำหรับรูปแบบไร้มิติ
{
    volScalarField rAU(1.0/UEqn.A());
    surfaceScalarField rAUf(fvc::interpolate(rAU));

    U = rAU*UEqn.H();
    surfaceScalarField phiU("phiU", (fvc::interpolate(U) & mesh.Sf()));

    adjustPhi(phiU, U, p);

    // การแก้ไขความดันไร้มิติ
    for (int nonOrth=0; nonOrth<=pimple.nNonOrthCorr(); nonOrth++)
    {
        fvScalarMatrix pEqn
        (
            fvm::laplacian(rAUf, p) == fvc::div(phiU)
        );

        pEqn.setReference(pRefCell, pRefValue);
        pEqn.solve();

        if (nonOrth == pimple.nNonOrthCorr())
        {
            phi -= pEqn.flux();
        }
    }

    #include "continuityErrs.H"

    U -= rAU*fvc::grad(p);
    U.correctBoundaryConditions();
}
```

