# 🔧 แบบฝึกปฏิบัติขั้นสูง: ระบบมิติและการขยาย OpenFOAM

## แบบฝึกปฏิบัติที่ 1: เครื่องมือตรวจสอบมิติ (Dimension Inspector Utility)

### **วัตถุประสงค์**
สร้าง Utility สำหรับสแกนและตรวจสอบความสม่ำเสมอของมิติของ Field ทั้งหมดใน OpenFOAM Case

### **ฟังก์ชันหลัก**
- **สแกนไดเรกทอรี**: `0/`, `system/`, และ `constant/`
- **วิเคราะห์ Field ทุกประเภท**: volScalarField, volVectorField, surfaceScalarField
- **แสดง Object มิติ** และการตรวจสอบความสม่ำเสมอ

[Diagram: Dimension Inspector แสดงภาพรวมของ Field ทั้งหมดใน Case พร้อมมิติและหน่วย]

### **การใช้งาน**
```bash
dimensionInspector <caseDirectory>
```

### **โค้ดพื้นฐาน**
```cpp
// dimensionInspector.C
#include "fvCFD.H"
#include "dictionary.H"
#include "dimensionSet.H"
#include "volFields.H"
#include "surfaceFields.H"

int main(int argc, char *argv[])
{
    #include "setRootCase.H"
    #include "createTime.H"
    #include "createMesh.H"

    // รับไฟล์ Field ทั้งหมดในไดเรกทอรี 0/
    const fileName fieldDir(runTime.timePath());
    const wordList fieldNames(mesh.objectNames(fieldDir));

    Info << "=== Dimension Inspector Report ===" << nl << nl;

    forAll(fieldNames, i)
    {
        const word& fieldName = fieldNames[i];
        const word fieldType = mesh.type(fieldDir/fieldName);

        Info << "Field: " << fieldName << nl;
        Info << "Type: " << fieldType << nl;

        // อ่านมิติของ Field
        if (fieldType == "volScalarField")
        {
            volScalarField field
            (
                IOobject
                (
                    fieldName,
                    runTime.timeName(),
                    mesh,
                    IOobject::MUST_READ,
                    IOobject::NO_WRITE
                ),
                mesh
            );
            Info << "Dimensions: " << field.dimensions() << nl;
        }
        else if (fieldType == "volVectorField")
        {
            volVectorField field
            (
                IOobject
                (
                    fieldName,
                    runTime.timeName(),
                    mesh,
                    IOobject::MUST_READ,
                    IOobject::NO_WRITE
                ),
                mesh
            );
            Info << "Dimensions: " << field.dimensions() << nl;
        }
        // เพิ่มประเภท Field อื่นๆ ตามต้องการ
        Info << nl;
    }

    return 0;
}
```

---

## แบบฝึกปฏิบัติที่ 2: เครื่องมือแปลงหน่วย (Unit Converter Utility)

### **วัตถุประสงค์**
สร้าง Utility สำหรับแปลง Field ระหว่างระบบหน่วย (SI → Imperial) โดยรักษาความถูกต้องทางฟิสิกส์

### **ปัจจัยการแปลงหน่วย**
| ปริมาณ | SI → Imperial | ค่าแปลง |
|----------|---------------|-----------|
| ความยาว | m → ft | 3.28084 |
| มวล | kg → lb | 2.20462 |
| เวลา | s → s | 1.0 |
| อุณหภูมิ | K → R | 1.8 |
| มุม | rad → deg | 57.2958 |

[Diagram: การแปลงหน่วยจาก SI เป็น Imperial โดยคงค่ามิติไว้]

### **Framework การแปลง**
```cpp
// unitConverter.H
#ifndef unitConverter_H
#define unitConverter_H

#include "dimensionSet.H"
#include "dictionary.H"

class unitConverter
{
private:
    // ปัจจัยการแปลง (จาก SI เป็น Imperial)
    static const scalar lengthConversion_;
    static const scalar massConversion_;
    static const scalar timeConversion_;
    static const scalar temperatureConversion_;
    static const scalar angleConversion_;

public:
    // แปลง dimensionSet
    static dimensionSet convertDimensions
    (
        const dimensionSet& siDimensions,
        const word& fromSystem = "SI",
        const word& toSystem = "imperial"
    );

    // แปลงค่า Scalar
    static scalar convertValue
    (
        const scalar value,
        const dimensionSet& dimensions,
        const word& fromSystem = "SI",
        const word& toSystem = "imperial"
    );
};

#endif
```

### **การคำนวณการแปลง**
```cpp
// unitConverter.C
#include "unitConverter.H"

const scalar unitConverter::lengthConversion_ = 3.28084;     // m to ft
const scalar unitConverter::massConversion_ = 2.20462;      // kg to lb
const scalar unitConverter::timeConversion_ = 1.0;          // s to s (เหมือนเดิม)
const scalar unitConverter::temperatureConversion_ = 1.8;    // K to R
const scalar unitConverter::angleConversion_ = 57.2958;      // rad to deg

scalar unitConverter::convertValue
(
    const scalar value,
    const dimensionSet& dimensions,
    const word& fromSystem,
    const word& toSystem
)
{
    if (fromSystem == toSystem)
    {
        return value;
    }

    scalar conversionFactor = 1.0;

    if (fromSystem == "SI" && toSystem == "imperial")
    {
        // ใช้ปัจจัยการแปลงมิติ
        conversionFactor *= pow(lengthConversion_, dimensions[dimLength]);
        conversionFactor *= pow(massConversion_, dimensions[dimMass]);
        conversionFactor *= pow(timeConversion_, dimensions[dimTime]);
        conversionFactor *= pow(temperatureConversion_, dimensions[dimTemperature]);
        conversionFactor *= pow(angleConversion_, dimensions[dimCurrent]); // สำหรับมุม
    }

    return value * conversionFactor;
}
```

