    ├── 03.1.3_Conservation_Laws_per_Phase
    └── EQUATIONS_MASS_CONSERVATION.md
        ├── 03.1.2_Multiple_Continua_Hypothesis
        ├── 03.1.4_Phase_Averaging_Methods
        └── EQUATIONS_MOMENTUM_CONSERVATION.md
            └── EQUATIONS_CLOSURE_MODELS.md
```

