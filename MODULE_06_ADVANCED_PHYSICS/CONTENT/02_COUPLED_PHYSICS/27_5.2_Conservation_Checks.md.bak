# 6. แบบฝึกหัดปฏิบัติ

ส่วนนี้ให้แบบฝึกหัดปฏิบัติเพื่อพัฒนาความชำนาญในการนำไปใช้และทดสอบแบบจำลองการถ่ายเทความร้อนแบบหลายเฟสใน OpenFOAM แต่ละแบบฝึกหัดสร้างบนแนวคิดก่อนหน้าและให้ประสบการณ์จริงกับแอปพลิเคชัน CFD

## แบบฝึกหัด 6.1: การนำไปใช้แบบจำลองการถ่ายเทความร้อนแบบกำหนดเอง

**วัตถุประสงค์**: สร้างแบบจำลองสัมประสิทธิ์การถ่ายเทความร้อนแบบกำหนดเองและนำไปใช้ใน OpenFOAM

### ภารกิจ 6.1.1: การกำหนดรูปแบบแบบจำลอง

นำไปใช้ความสัมพันธ์ Nusselt ที่ขึ้นกับอุณหภูมิสำหรับการถ่ายเทความร้อนระหว่างส่วนติดต่อ:

### OpenFOAM Code Implementation

```cpp
class TemperatureDependentNuModel
:
    public heatTransferModel
{
    private:
        // Model constants
        dimensionedScalar Pr_;
        dimensionedScalar A_;
        dimensionedScalar n_;
        dimensionedScalar Tref_;
        
        // Temperature field reference
        const volScalarField& T_;
        
    public:
        TypeName("temperatureDependentNu");
        
        TemperatureDependentNuModel
        (
            const dictionary& dict,
            const phasePair& pair,
            const bool registerObject
        )
        :
            heatTransferModel(dict, pair, registerObject),
            Pr_(dict.lookupOrDefault<dimensionedScalar>("Pr", dimensionedScalar("Pr", dimless, 0.7))),
            A_(dict.lookupOrDefault<dimensionedScalar>("A", dimensionedScalar("A", dimless, 0.023))),
            n_(dict.lookupOrDefault<dimensionedScalar>("n", dimensionedScalar("n", dimless, 0.8))),
            Tref_(dict.lookupOrDefault<dimensionedScalar>("Tref", dimensionedScalar("Tref", dimTemperature, 293.15))),
            T_(mesh().lookupObject<volScalarField>("T"))
        {}
        
        virtual tmp<volScalarField> K() const
        {
            const phaseModel& phase1 = pair_.phase1();
            const phaseModel& phase2 = pair_.phase2();
            
            // Calculate Reynolds number
            const volScalarField& rho = phase1.rho();
            const volScalarField& mu = phase1.mu();
            const volScalarField& d = phase1.d();
            const volVectorField& U = phase1.U();
            
            volScalarField Re = rho*mag(U)*d/mu;
            
            // Temperature-dependent Nusselt number
            volScalarField T_ratio = T_/Tref_;
            volScalarField Nu = A_ * pow(Re, n_) * pow(T_ratio, 0.3) * pow(Pr_.value(), 0.333);
            
            // Heat transfer coefficient
            const volScalarField& k = phase1.thermo().kappa();
            return Nu*k/d;
        }
        
        virtual bool read(const dictionary& dict)
        {
            heatTransferModel::read(dict);
            dict.readIfPresent("Pr", Pr_);
            dict.readIfPresent("A", A_);
            dict.readIfPresent("n", n_);
            dict.readIfPresent("Tref", Tref_);
            return true;
        }
};
```

### ภารกิจ 6.1.2: การลงทะเบียนแบบจำลอง

ลงทะเบียนแบบจำลองใหม่ในไฟล์ต้นฉบับที่เหมาะสม:

```cpp
addToRunTimeSelectionTable
(
    heatTransferModel,
    TemperatureDependentNuModel,
    dictionary
);
```

### ภารกิจ 6.1.3: กรณีทดสอบความถูกต้อง

สร้างกรณีทดสอบความถูกต้องที่ง่ายด้วยวิธีแก้ปัญหาวิเคราะห์ที่ทราบ:

```cpp
// validationDictionary
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      validationDictionary;
}

// Model parameters
A           0.023;
n           0.8;
Pr          0.7;
Tref        293.15;

// Validation conditions
T_hot       373.15;  // K
T_cold      293.15;  // K
flowRate    0.001;   // m³/s
```

[Diagram: การไหลงานของการพัฒนาและทดสอบแบบจำลอมการถ่ายเทความร้อนแบบกำหนดเอง]

## แบบฝึกหัด 6.2: การจำลองการถ่ายเทความร้อนแบบหลายเฟส

**วัตถุประสงค์**: ตั้งค่าและรันการจำลองการถ่ายเทความร้อนแบบหลายเฟสที่สมบูรณ์

### ภารกิจ 6.2.1: เรขาคณิตและ Mesh

สร้างท่อแนวตั้งด้วยเงื่อนไขขอบเขตผนังที่มีความร้อน:

### OpenFOAM Code Implementation

```cpp
// blockMeshDict
convertToMeters 1;

vertices
(
    (0 0 0)                    // 0
    (0.05 0 0)                // 1
    (0.05 0.05 0)             // 2
    (0 0.05 0)                // 3
    (0 0 2)                   // 4
    (0.05 0 2)                // 5
    (0.05 0.05 2)             // 6
    (0 0.05 2)                // 7
);

blocks
(
    hex (0 1 2 3 4 5 6 7) (20 20 100) simpleGrading (1 1 1)
);

edges();

boundary
(
    inlet
    {
        type patch;
        faces ((0 4 7 3));
    }
    outlet
    {
        type patch;
        faces ((1 5 6 2));
    }
    wall
    {
        type wall;
        faces ((0 1 5 4) (1 2 6 5) (2 3 7 6) (3 0 4 7));
    }
);
```

### ภารกิจ 6.2.2: คุณสมบัติทางความร้อน

กำหนดคุณสมบัติทางความร้อนของสองเฟส:

### OpenFOAM Code Implementation

```cpp
// thermophysicalProperties
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties;
}

phase1
{
    type            compressible::icoPolynomial;
    mixture         1 100;
    
    rhoCoeffs<8>    ( 1000 0 0 0 0 0 0 0 );  // Water density
    CpCoeffs<8>     ( 4186 0 0 0 0 0 0 0 );  // Specific heat
    muCoeffs<8>     ( 0.001 0 0 0 0 0 0 0 ); // Dynamic viscosity
    kappaCoeffs<8>  ( 0.6 0 0 0 0 0 0 0 );   // Thermal conductivity
}

phase2
{
    type            compressible::icoPolynomial;
    mixture         1 100;
    
    rhoCoeffs<8>    ( 1.2 0 0 0 0 0 0 0 );   // Air density
    CpCoeffs<8>     ( 1005 0 0 0 0 0 0 0 );  // Specific heat
    muCoeffs<8>     ( 1.8e-5 0 0 0 0 0 0 0 ); // Dynamic viscosity
    kappaCoeffs<8>  ( 0.025 0 0 0 0 0 0 0 ); // Thermal conductivity
}

// Interfacial heat transfer model
interfacialHeatTransferModel temperatureDependentNu;
```

### คุณสมบัติทางความร้อนของเฟส:

| คุณสมบัติ | น้ำ (Phase 1) | อากาศ (Phase 2) | หน่วย |
|----------|---------------|------------------|--------|
| ความหนาแน่น (ρ) | 1000 | 1.2 | kg/m³ |
| ความจุความร้อนจำเพาะ (Cp) | 4186 | 1005 | J/kg·K |
| ความหนืดพลศาสตร์ (μ) | 0.001 | 1.8×10⁻⁵ | Pa·s |
| ความนำความร้อน (k) | 0.6 | 0.025 | W/m·K |

### ภารกิจ 6.2.3: เงื่อนไขเริ่มต้น

ตั้งค่าสัดส่วนปริมาตรเฟสและฟิลด์อุณหภูมิ:

### OpenFOAM Code Implementation

```cpp
// 0/alpha.water
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      alpha.water;
}

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0.5;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 0.8;  // 80% water at inlet
    }
    outlet
    {
        type            zeroGradient;
    }
    wall
    {
        type            zeroGradient;
    }
}

// 0/T
FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      T;
}

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 293.15;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 293.15;  // Cold inlet
    }
    outlet
    {
        type            zeroGradient;
    }
    wall
    {
        type            fixedValue;
        value           uniform 373.15;  // Hot wall
    }
}
```

### ภารกิจ 6.2.4: การกำหนดค่า Solver

กำหนดค่าการตั้งค่า solver แบบหลายเฟส:

### OpenFOAM Code Implementation

```cpp
// fvSolution
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}

solvers
{
    p
    {
        solver          GAMG;
        tolerance       1e-6;
        relTol          0.1;
        smoother        GaussSeidel;
        nPreSweeps      0;
        nPostSweeps     2;
        nFinestSweeps   2;
        cacheAgglomeration on;
        agglomerator    faceAreaPair;
        nCellsInCoarsestLevel 10;
        mergeLevels     1;
    }

    pFinal
    {
        solver          GAMG;
        tolerance       1e-8;
        relTol          0;
        smoother        GaussSeidel;
        nPreSweeps      0;
        nPostSweeps     2;
        nFinestSweeps   2;
        cacheAgglomeration on;
        agglomerator    faceAreaPair;
        nCellsInCoarsestLevel 10;
        mergeLevels     1;
    }

    "U.*"
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        tolerance       1e-6;
        relTol          0.1;
        nSweeps         1;
    }

    "U.*Final"
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        tolerance       1e-8;
        relTol          0;
        nSweeps         2;
    }

    "h.*"
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        tolerance       1e-6;
        relTol          0.1;
        nSweeps         1;
    }

    "h.*Final"
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        tolerance       1e-8;
        relTol          0;
        nSweeps         2;
    }
}

PIMPLE
{
    nCorrectors      2;
    nNonOrthogonalCorrectors 0;
    nOuterCorrectors 1;
    nAlphaCorr       1;
    nAlphaSubCycles  2;
    cAlpha           1;
}
```

