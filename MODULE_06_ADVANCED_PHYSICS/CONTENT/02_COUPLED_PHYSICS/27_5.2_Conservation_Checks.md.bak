## แบบฝึกหัด 6.3: การนำไปใช้การตรวจสอบการอนุรักษ์

**วัตถุประสงค์**: นำไปใช้ระบบตรวจสอบการอนุรักษ์ที่ครอบคลุมสำหรับการถ่ายเทความร้อนแบบหลายเฟส

### ภารกิจ 6.3.1: คลาสตรวจสอบการอนุรักษ์

สร้าง function object สำหรับตรวจสอบการอนุรักษ์ที่สมบูรณ์:

### OpenFOAM Code Implementation

```cpp
class multiphaseConservationMonitor
:
    public fvMeshFunctionObject
{
    private:
        // Reference to phase system
        const phaseSystem& phaseSystem_;
        
        // Conservation tolerances
        scalar massTolerance_;
        scalar energyTolerance_;
        scalar phaseTolerance_;
        
        // Time history storage
        HashTable<List<scalar>> conservationHistory_;
        
        // Output control
        label writeInterval_;
        word outputFileName_;
        
        // Conservation state tracking
        struct ConservationState
        {
            scalar currentTime;
            scalar massError;
            scalar energyError;
            scalar phaseError;
            scalar totalMass;
            scalar totalEnergy;
        };
        
        List<ConservationState> stateHistory_;
        
    public:
        TypeName("multiphaseConservationMonitor");
        
        multiphaseConservationMonitor
        (
            const word& name,
            const Time& runTime,
            const dictionary& dict
        )
        :
            fvMeshFunctionObject(name, runTime, dict),
            phaseSystem_
            (
                mesh_.lookupObject<phaseSystem>
                (
                    dict.lookupOrDefault<word>("phaseSystem", "phaseProperties")
                )
            ),
            massTolerance_(dict.lookupOrDefault<scalar>("massTolerance", 1e-8)),
            energyTolerance_(dict.lookupOrDefault<scalar>("energyTolerance", 1e-6)),
            phaseTolerance_(dict.lookupOrDefault<scalar>("phaseTolerance", 1e-6)),
            writeInterval_(dict.lookupOrDefault<label>("writeInterval", 1)),
            outputFileName_(dict.lookupOrDefault<word>("outputFileName", "conservation.dat"))
        {
            // Initialize conservation tracking
            initializeConservationTracking();
        }
        
        virtual void execute()
        {
            if (mesh_.time().timeIndex() % writeInterval_ != 0) return;
            
            // Calculate current conservation state
            ConservationState currentState = calculateConservationState();
            
            // Check conservation errors
            checkConservationErrors(currentState);
            
            // Store state
            stateHistory_.append(currentState);
            
            // Report current status
            reportConservationStatus(currentState);
        }
        
        virtual bool write()
        {
            writeConservationData();
            return true;
        }
        
    private:
        void initializeConservationTracking()
        {
            Info << "Initializing multiphase conservation monitoring" << nl
                 << "Mass tolerance: " << massTolerance_ << nl
                 << "Energy tolerance: " << energyTolerance_ << nl
                 << "Phase tolerance: " << phaseTolerance_ << endl;
        }
        
        ConservationState calculateConservationState()
        {
            ConservationState state;
            state.currentTime = mesh_.time().value();
            
            // Calculate total system mass
            state.totalMass = 0.0;
            forAll(phaseSystem_.phases(), phasei)
            {
                const phaseModel& phase = phaseSystem_.phases()[phasei];
                const volScalarField& alpha = phase;
                const volScalarField& rho = phase.rho();
                
                state.totalMass += fvc::domainIntegrate(alpha * rho).value();
            }
            
            // Calculate total system energy
            state.totalEnergy = 0.0;
            forAll(phaseSystem_.phases(), phasei)
            {
                const phaseModel& phase = phaseSystem_.phases()[phasei];
                const volScalarField& alpha = phase;
                const volScalarField& rho = phase.rho();
                const volScalarField& h = phase.thermo().he();
                
                state.totalEnergy += fvc::domainIntegrate(alpha * rho * h).value();
            }
            
            // Calculate conservation errors
            state.massError = calculateMassError();
            state.energyError = calculateEnergyError();
            state.phaseError = calculatePhaseError();
            
            return state;
        }
        
        scalar calculateMassError()
        {
            if (stateHistory_.empty()) return 0.0;
            
            scalar initialMass = stateHistory_[0].totalMass;
            scalar currentMass = stateHistory_.last().totalMass;
            
            return mag(currentMass - initialMass)/(mag(initialMass) + SMALL);
        }
        
        scalar calculateEnergyError()
        {
            if (stateHistory_.empty()) return 0.0;
            
            scalar initialEnergy = stateHistory_[0].totalEnergy;
            scalar currentEnergy = stateHistory_.last().totalEnergy;
            
            // Account for heat flux through boundaries
            scalar netHeatFlux = calculateNetHeatFlux();
            scalar expectedEnergyChange = netHeatFlux * mesh_.time().deltaTValue();
            
            scalar actualEnergyChange = currentEnergy - initialEnergy;
            scalar energyError = mag(actualEnergyChange - expectedEnergyChange);
            
            return energyError/(mag(initialEnergy) + mag(expectedEnergyChange) + SMALL);
        }
        
        scalar calculateNetHeatFlux()
        {
            scalar netFlux = 0.0;
            
            // Calculate heat flux through all boundaries
            forAll(phaseSystem_.phases(), phasei)
            {
                const phaseModel& phase = phaseSystem_.phases()[phasei];
                const volScalarField& alpha = phase;
                const volScalarField& h = phase.thermo().he();
                const surfaceScalarField& phi = phase.phi();
                
                forAll(phi.boundaryField(), patchi)
                {
                    const fvsPatchScalarField& phiP = phi.boundaryField()[patchi];
                    const fvPatchScalarField& hP = h.boundaryField()[patchi];
                    
                    netFlux += sum(phiP * hP);
                }
            }
            
            return netFlux;
        }
        
        scalar calculatePhaseError()
        {
            // Calculate maximum deviation from unity sum
            volScalarField alphaSum
            (
                IOobject("alphaSum", mesh_.time().timeName(), mesh_),
                mesh_,
                dimensionedScalar("zero", dimless, 0.0)
            );
            
            forAll(phaseSystem_.phases(), phasei)
            {
                const phaseModel& phase = phaseSystem_.phases()[phasei];
                alphaSum += phase;
            }
            
            volScalarField alphaError = mag(alphaSum - 1.0);
            return max(alphaError).value();
        }
        
        void checkConservationErrors(const ConservationState& state)
        {
            bool conservationViolated = false;
            
            if (state.massError > massTolerance_)
            {
                WarningInFunction
                    << "Mass conservation violation: " << state.massError 
                    << " (tolerance: " << massTolerance_ << ")" << endl;
                conservationViolated = true;
            }
            
            if (state.energyError > energyTolerance_)
            {
                WarningInFunction
                    << "Energy conservation violation: " << state.energyError 
                    << " (tolerance: " << energyTolerance_ << ")" << endl;
                conservationViolated = true;
            }
            
            if (state.phaseError > phaseTolerance_)
            {
                WarningInFunction
                    << "Phase fraction violation: " << state.phaseError 
                    << " (tolerance: " << phaseTolerance_ << ")" << endl;
                conservationViolated = true;
            }
            
            if (conservationViolated)
            {
                writeDetailedConservationReport(state);
            }
        }
        
        void reportConservationStatus(const ConservationState& state)
        {
            Info << "Conservation Report at t=" << state.currentTime << nl
                 << "  Mass error: " << state.massError << nl
                 << "  Energy error: " << state.energyError << nl
                 << "  Phase error: " << state.phaseError << nl
                 << "  Total mass: " << state.totalMass << nl
                 << "  Total energy: " << state.totalEnergy << endl;
        }
        
        void writeConservationData()
        {
            OFstream file
            (
                mesh_.time().timePath() / outputFileName_
            );
            
            // Write header
            file << "# Time MassError EnergyError PhaseError TotalMass TotalEnergy" << nl;
            
            // Write data
            forAll(stateHistory_, i)
            {
                const ConservationState& state = stateHistory_[i];
                file << state.currentTime << " "
                     << state.massError << " "
                     << state.energyError << " "
                     << state.phaseError << " "
                     << state.totalMass << " "
                     << state.totalEnergy << nl;
            }
            
            Info << "Conservation data written to " << outputFileName_ << endl;
        }
        
        void writeDetailedConservationReport(const ConservationState& state)
        {
            OFstream file
            (
                mesh_.time().timePath() / "conservationViolation.dat"
            );
            
            file << "Conservation Violation Report" << nl
                 << "Time: " << state.currentTime << nl
                 << "Mass Error: " << state.massError << nl
                 << "Energy Error: " << state.energyError << nl
                 << "Phase Error: " << state.phaseError << nl
                 << "Total Mass: " << state.totalMass << nl
                 << "Total Energy: " << state.totalEnergy << nl;
            
            // Write phase-specific details
            file << nl << "Phase Details:" << nl;
            forAll(phaseSystem_.phases(), phasei)
            {
                const phaseModel& phase = phaseSystem_.phases()[phasei];
                const volScalarField& alpha = phase;
                const volScalarField& rho = phase.rho();
                const volScalarField& h = phase.thermo().he();
                
                scalar phaseMass = fvc::domainIntegrate(alpha * rho).value();
                scalar phaseEnergy = fvc::domainIntegrate(alpha * rho * h).value();
                
                file << "  Phase " << phase.name() << nl
                     << "    Mass: " << phaseMass << nl
                     << "    Energy: " << phaseEnergy << nl
                     << "    Volume Fraction (avg): " << average(alpha).value() << nl;
            }
        }
};
```

### ภารกิจ 6.3.2: การผสานรวมกับ Control Dictionary

เพิ่ม conservation monitor ในการควบคุมการจำลอง:

### OpenFOAM Code Implementation

```cpp
// system/controlDict
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}

application     multiphaseEulerFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         10.0;

deltaT          0.001;

adjustTimeStep  yes;

maxCo           0.5;
maxAlphaCo      0.5;
maxDeltaT       1.0;

writeControl    timeStep;

writeInterval   100;

purgeWrite      0;

runTimeModifiable true;

functions
{
    conservationMonitor
    {
        type            multiphaseConservationMonitor;
        
        phaseSystem     phaseProperties;
        
        massTolerance   1e-8;
        energyTolerance 1e-6;
        phaseTolerance  1e-6;
        
        writeInterval   10;
        outputFileName  conservation.dat;
    }
    
    heatFluxMonitor
    {
        type            surfaceField;
        
        functionObjectLibs ("libutilityFunctionObjects.so");
        
        outputControl   timeStep;
        outputInterval  50;
        
        fields
        (
            phi
            alpha.water
            h.water
            h.air
        );
        
        patches
        (
            wall
        );
        
        writeFields     false;
    }
}
```

