## แบบฝึกหัด 6.4: การเพิ่มประสิทธิภาพประสิทธิภาพการคำนวณ

**วัตถุประสงค์**: เพิ่มประสิทธิภาพประสิทธิภาพการคำนวณของการจำลองการถ่ายเทความร้อนแบบหลายเฟส

### ภารกิจ 6.4.1: การเพิ่มประสิทธิภาพ Solver เชิงเส้น

กำหนดค่า solvers ที่เหมาะสมสำหรับระบบที่เชื่อมโยงกันของเฟส:

### OpenFOAM Code Implementation

```cpp
// Optimized fvSolution
solvers
{
    p
    {
        solver          GAMG;
        tolerance       1e-7;
        relTol          0.05;
        smoother        symGaussSeidel;
        nPreSweeps      1;
        nPostSweeps     2;
        nFinestSweeps   3;
        cacheAgglomeration true;
        agglomerator    faceAreaPair;
        nCellsInCoarsestLevel 50;
        mergeLevels     1;
        directSolveCoarsest false;
    }
    
    "alpha.*"
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        tolerance       1e-8;
        relTol          0;
        nSweeps         2;
    }
    
    "U.*"
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        tolerance       1e-6;
        relTol          0.1;
        nSweeps         2;
    }
    
    "h.*"
    {
        solver          smoothSolver;
        smoother        GaussSeidel;
        tolerance       1e-6;
        relTol          0.1;
        nSweeps         1;
    }
}

relaxationFactors
{
    fields
    {
        p               0.3;
        "alpha.*"       0.5;
    }
    equations
    {
        "U.*"           0.7;
        "h.*"           0.8;
    }
}

PIMPLE
{
    nCorrectors      3;
    nNonOrthogonalCorrectors 0;
    nOuterCorrectors 2;
    nAlphaCorr       2;
    nAlphaSubCycles  1;
    cAlpha           1;
    pRefCell        0;
    pRefValue       0;
}
```

### การตั้งค่า Solver เชิงเส้นที่เหมาะสม:

| ตัวแปร | ประเภท | Tolerance | Relaxation | คำอธิบาย |
|----------|---------|-----------|------------|------------|
| p | GAMG | 1e-7 | 0.3 | ความดัน |
| alpha.* | smoothSolver | 1e-8 | 0.5 | สัดส่วนปริมาตรเฟส |
| U.* | smoothSolver | 1e-6 | 0.7 | ความเร็ว |
| h.* | smoothSolver | 1e-6 | 0.8 | เอนทาลปี |

### ภารกิจ 6.4.2: การวิเคราะห์คุณภาพ Mesh

นำไปใช้การตรวจสอบคุณภาพ mesh สำหรับการถ่ายเทความร้อนแบบหลายเฟส:

### OpenFOAM Code Implementation

```cpp
// meshQualityCheck function object
class multiphaseMeshQuality
:
    public fvMeshFunctionObject
{
    private:
        // Quality criteria thresholds
        scalar maxNonOrthogonality_;
        scalar maxSkewness_;
        scalar maxAspectRatio_;
        
        // Phase-specific requirements
        scalar maxAlphaGradient_;
        scalar minInterfaceResolution_;
        
    public:
        multiphaseMeshQuality
        (
            const word& name,
            const Time& runTime,
            const dictionary& dict
        )
        :
            fvMeshFunctionObject(name, runTime, dict),
            maxNonOrthogonality_(dict.lookupOrDefault<scalar>("maxNonOrthogonality", 70)),
            maxSkewness_(dict.lookupOrDefault<scalar>("maxSkewness", 4)),
            maxAspectRatio_(dict.lookupOrDefault<scalar>("maxAspectRatio", 1000)),
            maxAlphaGradient_(dict.lookupOrDefault<scalar>("maxAlphaGradient", 10)),
            minInterfaceResolution_(dict.lookupOrDefault<scalar>("minInterfaceResolution", 3))
        {}
        
        virtual void execute()
        {
            checkBasicMeshQuality();
            checkPhaseResolution();
            checkInterfaceCapturing();
        }
        
    private:
        void checkBasicMeshQuality()
        {
            const fvMesh& mesh = mesh_;
            
            // Non-orthogonality check
            scalar maxNonOrth = max
            (
                mesh.nonOrthogonalAngles()
            ).value();
            
            if (maxNonOrth > maxNonOrthogonality_)
            {
                WarningInFunction
                    << "Maximum non-orthogonality (" << maxNonOrth 
                    << ") exceeds recommended limit (" << maxNonOrthogonality_ << ")" << endl;
            }
            
            // Skewness check
            scalar maxSkew = max
            (
                mesh.skewness()
            ).value();
            
            if (maxSkew > maxSkewness_)
            {
                WarningInFunction
                    << "Maximum skewness (" << maxSkew 
                    << ") exceeds recommended limit (" << maxSkewness_ << ")" << endl;
            }
            
            // Aspect ratio check
            scalar maxAR = max
            (
                mesh.aspectRatio()
            ).value();
            
            if (maxAR > maxAspectRatio_)
            {
                WarningInFunction
                    << "Maximum aspect ratio (" << maxAR 
                    << ") exceeds recommended limit (" << maxAspectRatio_ << ")" << endl;
            }
        }
        
        void checkPhaseResolution()
        {
            if (!mesh_.foundObject<phaseSystem>("phaseProperties")) return;
            
            const phaseSystem& phases = 
                mesh_.lookupObject<phaseSystem>("phaseProperties");
            
            forAll(phases.phases(), phasei)
            {
                const phaseModel& phase = phases.phases()[phasei];
                const volScalarField& alpha = phase;
                
                // Check phase fraction gradients
                volScalarField magGradAlpha = mag(fvc::grad(alpha));
                scalar maxGradAlpha = max(magGradAlpha).value();
                
                if (maxGradAlpha > maxAlphaGradient_)
                {
                    WarningInFunction
                        << "Phase " << phase.name() 
                        << " maximum gradient (" << maxGradAlpha 
                        << ") exceeds recommended limit (" << maxAlphaGradient_ << ")" << endl;
                }
            }
        }
        
        void checkInterfaceCapturing()
        {
            // Interface thickness relative to cell size
            const fvMesh& mesh = mesh_;
            const volScalarField::Internal& V = mesh.V();
            const surfaceScalarField& magSf = mesh.magSf();
            
            // Calculate characteristic cell size
            volScalarField cellSize
            (
                IOobject
                (
                    "cellSize",
                    mesh.time().timeName(),
                    mesh
                ),
                mesh,
                dimensionedScalar("cellSize", dimLength, 0.0)
            );
            
            cellSize.primitiveFieldRef() = pow(V, 1.0/3.0);
            
            // Check interface resolution
            if (mesh_.foundObject<volScalarField>("alpha1"))
            {
                const volScalarField& alpha1 = mesh_.lookupObject<volScalarField>("alpha1");
                
                // Interface cells (where 0.01 < alpha < 0.99)
                forAll(alpha1, celli)
                {
                    if (alpha1[celli] > 0.01 && alpha1[celli] < 0.99)
                    {
                        scalar interfaceThickness = cellSize[celli];
                        
                        if (interfaceThickness > minInterfaceResolution_)
                        {
                            WarningInFunction
                                << "Interface cell " << celli 
                                << " too coarse for accurate interface capturing" << endl;
                        }
                    }
                }
            }
        }
};
```

[Diagram: กระบวนการตรวจสอบคุณภาพ Mesh สำหรับการจำลองแบบหลายเฟส]

## แบบฝึกหัด 6.5: การตรวจสอบความถูกต้องกับข้อมูลทดลอง

**วัตถุประสงค์**: ตรวจสอบความถูกต้องของแบบจำลองการถ่ายเทความร้อนแบบหลายเฟสกับกรณีมาตรฐาน

### ภารกิจ 6.5.1: การเลือกกรณีมาตรฐาน

เลือกกรณีทดสอบความถูกต้องที่เหมาะสม:

1. **การถ่ายเทความร้อนฟองเดี่ยว**: เรขาคณิตง่ายด้วยวิธีแก้ปัญหาวิเคราะห์
2. **การไหลในท่อแบบสองเฟส**: ข้อมูลทดลองที่ได้รับการบันทึกอย่างดี
3. **การระเหยของฟิล์มหย่อน**: การตรวจสอบความสัมพันธ์การถ่ายเทความร้อนแบบคลาสสิก

### ภารกิจ 6.5.2: การประมาณความผิดพลาด

นำไปใช้การวิเคราะห์ความผิดพลาดอย่างครอบคลุม:

### OpenFOAM Code Implementation

```cpp
// validationAnalysis function object
class validationAnalysis
:
    public fvMeshFunctionObject
{
    private:
        // Experimental data file
        fileName experimentalDataFile_;
        
        // Reference solution data
        fileName referenceDataFile_;
        
        // Error metrics storage
        List<scalar> l2NormHistory_;
        List<scalar> maxErrorHistory_;
        List<scalar> correlationCoeff_;
        
    public:
        validationAnalysis
        (
            const word& name,
            const Time& runTime,
            const dictionary& dict
        )
        :
            fvMeshFunctionObject(name, runTime, dict),
            experimentalDataFile_(dict.lookupOrDefault<fileName>("experimentalDataFile", "experimental.dat")),
            referenceDataFile_(dict.lookupOrDefault<fileName>("referenceDataFile", "reference.dat"))
        {
            loadExperimentalData();
        }
        
        virtual void execute()
        {
            if (mesh_.time().timeIndex() % 10 == 0)
            {
                calculateValidationMetrics();
                reportValidationStatus();
            }
        }
        
    private:
        void loadExperimentalData()
        {
            // Load experimental data from file
            // Parse and store for comparison
        }
        
        void calculateValidationMetrics()
        {
            // Compare numerical results with experimental data
            // Calculate L2 norm, maximum error, correlation coefficient
        }
        
        void reportValidationStatus()
        {
            // Report validation results
            // Identify regions of poor agreement
            // Suggest model improvements
        }
};
```

### การวิเคราะห์ความผิดพลาดสำหรับการตรวจสอบความถูกต้อง:

| เมตริก | สูตร | การใช้งาน | ค่าที่ยอมรับได้ |
|----------|--------|--------------|------------------|
| L2 Norm | $\|e\|_{L2} = \sqrt{\sum_{i=1}^{N} (u_i^{\text{num}} - u_i^{\text{exp}})^2}$ | ข้อผิดพลาดโดยรวม | < 5% |
| Maximum Error | $|e|_{\max} = \max_i |u_i^{\text{num}} - u_i^{\text{exp}}|$ | ข้อผิดพลาดสูงสุด | < 10% |
| Correlation Coefficient | $R = \frac{\sum_i (u_i^{\text{num}} - \bar{u}^{\text{num}})(u_i^{\text{exp}} - \bar{u}^{\text{exp}})}{\sigma^{\text{num}} \sigma^{\text{exp}}}$ | ความสัมพันธ์ | > 0.9 |

แบบฝึกหัดเหล่านี้ให้ประสบการณ์จริงอย่างครอบคลุมกับการนำไปใช้ ทดสอบ และตรวจสอบความถูกต้องของแบบจำลองการถ่ายเทความร้อนแบบหลายเฟสใน OpenFOAM ครอบคลุมทุกแง่มุมตั้งแต่การพัฒนาแบบจำลองไปจนถึงการเพิ่มประสิทธิภาพประสิทธิภาพและการตรวจสอบความถูกต้อง
